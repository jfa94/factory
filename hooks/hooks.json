{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/branch-protection.sh",
            "timeout": 5,
            "statusMessage": "Checking branch protection"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/secret-commit-guard.sh",
            "timeout": 15,
            "statusMessage": "Scanning staged changes for secrets"
          }
        ]
      },
      {
        "matcher": "^(Edit|Write|MultiEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/write-protection.sh",
            "timeout": 5,
            "statusMessage": "Checking write-blocklist"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|Write|Edit)$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/run-tracker.sh",
            "timeout": 5,
            "statusMessage": "Logging action"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop-gate.sh",
            "timeout": 10,
            "statusMessage": "Checking run state"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/subagent-stop-gate.sh",
            "timeout": 10,
            "statusMessage": "Validating subagent artifacts"
          }
        ]
      }
    ]
  }
}
