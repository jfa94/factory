#!/usr/bin/env bash
# Validate spec generation output (spec.md + tasks.json).
# Usage: pipeline-validate-spec <spec-dir>
# Exit: 0=valid, 1=invalid

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

spec_dir="${1:?missing spec directory}"

errors=()

# Check spec.md
spec_file="$spec_dir/spec.md"
if [[ ! -f "$spec_file" ]]; then
  errors+=("spec.md not found in $spec_dir")
elif [[ ! -s "$spec_file" ]]; then
  errors+=("spec.md is empty")
fi

# Check tasks.json — delegate to pipeline-validate-tasks, the single source of
# truth for the tasks.json contract. This script previously re-implemented a
# weaker subset (no task_id charset / control-char / array-type / enum checks)
# and drifted from validate-tasks.
tasks_file="$spec_dir/tasks.json"
if [[ ! -f "$tasks_file" ]]; then
  errors+=("tasks.json not found in $spec_dir")
else
  vt_out=$("$(dirname "$0")/pipeline-validate-tasks" "$tasks_file" 2>/dev/null) || true
  if [[ "$(printf '%s' "$vt_out" | jq -r '.valid // false' 2>/dev/null)" != "true" ]]; then
    _before=${#errors[@]}
    while IFS= read -r _e; do
      [[ -n "$_e" ]] && errors+=("$_e")
    done < <(printf '%s' "$vt_out" | jq -r '.errors[]?' 2>/dev/null)
    [[ ${#errors[@]} -eq "$_before" ]] && errors+=("tasks.json failed validation (pipeline-validate-tasks)")
  fi
  task_count=$(printf '%s' "$vt_out" | jq -r '.task_count // 0' 2>/dev/null)
fi

# Build output
error_count=${#errors[@]}
if [[ $error_count -eq 0 ]]; then
  jq -n \
    --argjson valid true \
    --argjson task_count "${task_count:-0}" \
    '{valid: $valid, errors: [], task_count: $task_count}'
else
  errors_json=$(printf '%s\n' "${errors[@]}" | jq -R -s 'split("\n") | map(select(length > 0))')
  jq -n \
    --argjson valid false \
    --argjson errors "$errors_json" \
    --argjson task_count "${task_count:-0}" \
    '{valid: $valid, errors: $errors, task_count: $task_count}'
  exit 1
fi
