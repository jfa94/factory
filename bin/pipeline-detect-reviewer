#!/usr/bin/env bash
# Detect available reviewer: Codex (preferred) or Claude Code (fallback).
# Usage: pipeline-detect-reviewer [--base <ref>]
# Exit: always 0 (detection never fails, just selects fallback)

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

base_ref="staging"
base_explicit=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --base) base_ref="$2"; base_explicit=true; shift 2 ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

if ! git rev-parse --verify "$base_ref" >/dev/null 2>&1; then
  if [[ "$base_explicit" == "false" ]] && git rev-parse --verify origin/staging >/dev/null 2>&1; then
    base_ref="origin/staging"
  else
    # Surface the silent fallback: previously a missing base ref was passed
    # through as-is, which only blew up downstream in pipeline-codex-review.
    # detect-reviewer still exits 0 (its contract), but the operator now sees
    # the signal in structured logs.
    log_warn "pipeline-detect-reviewer: base ref '$base_ref' not resolvable; passing through (downstream review tools may fail)"
  fi
fi

# Check Codex availability
if command -v codex &>/dev/null; then
  if codex login status &>/dev/null 2>&1; then
    PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
    jq -n \
      --arg reviewer "codex" \
      --arg base "$base_ref" \
      --arg plugin_root "$PLUGIN_ROOT" \
      '{reviewer: $reviewer, command: ($plugin_root + "/bin/pipeline-codex-review --base " + $base)}'
    exit 0
  fi
fi

# Fallback to Claude Code quality-reviewer agent — Codex performs adversarial code-quality review, so its fallback is the quality reviewer
jq -n \
  --arg reviewer "claude-code" \
  --arg agent "quality-reviewer" \
  '{reviewer: $reviewer, agent: $agent}'
