#!/usr/bin/env bash
# Create project scaffolding files if absent (idempotent).
# Usage: pipeline-scaffold <project-root> [--force] [--merge-package-json]
# Exit: 0=success

source "$(dirname "$0")/pipeline-lib.sh"

PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
TEMPLATES_DIR="$PLUGIN_ROOT/templates"

root="${1:?missing project root}"
shift

force=false
merge_pkg_json=false
check_only=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --force) force=true; shift ;;
    --merge-package-json) merge_pkg_json=true; shift ;;
    --check) check_only=true; shift ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

# --check mode: read-only report. Exit 0 when all required scaffold files
# are present, exit 1 with a missing-files list otherwise. Node-specific
# templates (.stryker.config.json, .dependency-cruiser.cjs) are required ONLY
# when a package.json exists, matching the scaffold's own conditional copy.
if [[ "$check_only" == "true" ]]; then
  required=(
    "$root/claude-progress.json"
    "$root/feature-status.json"
    "$root/init.sh"
    "$root/.github/workflows/quality-gate.yml"
  )
  if [[ -f "$root/package.json" ]]; then
    required+=(
      "$root/.stryker.config.json"
      "$root/.dependency-cruiser.cjs"
    )
  fi
  missing=()
  for f in "${required[@]}"; do
    [[ -f "$f" ]] || missing+=("$f")
  done
  if (( ${#missing[@]} == 0 )); then
    json_output action "check" status "scaffolded" root "$root"
    exit 0
  else
    missing_json=$(printf '%s\n' "${missing[@]}" | jq -R . | jq -s .)
    jq -cn --arg root "$root" --argjson missing "$missing_json" \
      '{action:"check", status:"missing", root:$root, missing:$missing}'
    exit 1
  fi
fi

created=()

_create_if_absent() {
  local path="$1" content="$2"
  if [[ "$force" == "true" ]] || [[ ! -f "$path" ]]; then
    mkdir -p "$(dirname "$path")"
    printf '%s\n' "$content" > "$path"
    created+=("$path")
    log_info "created $path"
  fi
}

_copy_template_if_absent() {
  local src="$1" dest="$2"
  if [[ ! -f "$src" ]]; then
    log_warn "template missing: $src"
    return 0
  fi
  if [[ "$force" == "true" ]] || [[ ! -f "$dest" ]]; then
    mkdir -p "$(dirname "$dest")"
    cp "$src" "$dest"
    created+=("$dest")
    log_info "created $dest"
  fi
}

_create_if_absent "$root/claude-progress.json" '{
  "issues": {},
  "last_updated": null
}'

_create_if_absent "$root/feature-status.json" '{
  "features": {},
  "last_updated": null
}'

_create_if_absent "$root/init.sh" '#!/usr/bin/env bash
# Project bootstrap — install deps and set env vars
set -euo pipefail

if [[ -f "pnpm-lock.yaml" ]]; then
  pnpm install
elif [[ -f "bun.lockb" ]] || [[ -f "bun.lock" ]]; then
  bun install
elif [[ -f "yarn.lock" ]]; then
  yarn install
elif [[ -f "package-lock.json" ]]; then
  npm install
fi

echo "Project initialized."'
chmod +x "$root/init.sh" 2>/dev/null || true

_detect_pkg_manager() {
  if [[ -f "$root/pnpm-lock.yaml" ]]; then echo pnpm
  elif [[ -f "$root/bun.lockb" ]] || [[ -f "$root/bun.lock" ]]; then echo bun
  elif [[ -f "$root/yarn.lock" ]]; then echo yarn
  elif [[ -f "$root/package-lock.json" ]]; then echo npm
  else echo npm
  fi
}

_quality_gate_yml() {
  local pm="$1"
  local setup install lint typecheck test
  case "$pm" in
    pnpm)
      setup='      - uses: pnpm/action-setup@v4
      - uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: pnpm'
      install='      - run: pnpm install --frozen-lockfile'
      lint='      - run: pnpm lint'
      typecheck='      - run: pnpm typecheck'
      test='      - run: pnpm test -- --coverage'
      ;;
    yarn)
      setup='      - uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: yarn'
      install='      - run: yarn install --immutable'
      lint='      - run: yarn lint'
      typecheck='      - run: yarn typecheck'
      test='      - run: yarn test --coverage'
      ;;
    bun)
      setup='      - uses: oven-sh/setup-bun@v2'
      install='      - run: bun install --frozen-lockfile'
      lint='      - run: bun run lint'
      typecheck='      - run: bun run typecheck'
      test='      - run: bun test --coverage'
      ;;
    npm|*)
      setup='      - uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: npm'
      install='      - run: npm ci'
      lint='      - run: npm run lint'
      typecheck='      - run: npm run typecheck'
      test='      - run: npm test -- --coverage'
      ;;
  esac
  cat <<YML
name: Quality Gate
on:
  pull_request:
    branches: [staging, main, develop]

jobs:
  quality:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
$setup
$install
$lint
$typecheck
$test
YML
}

_create_if_absent "$root/.github/workflows/quality-gate.yml" "$(_quality_gate_yml "$(_detect_pkg_manager)")"

# Node-specific templates — only when target has package.json.
# Ported from the old pipeline's config-deployer.sh (task_10_02).
merged=false
if [[ -f "$root/package.json" ]]; then
  _copy_template_if_absent \
    "$TEMPLATES_DIR/.stryker.config.json" \
    "$root/.stryker.config.json"

  _copy_template_if_absent \
    "$TEMPLATES_DIR/.dependency-cruiser.cjs" \
    "$root/.dependency-cruiser.cjs"

  # package.json merge (task_10_03) — gated behind --merge-package-json so the
  # default scaffold run never mutates an existing manifest. Merges scripts and
  # devDependencies from templates/package.scaffold.json, preserving any user
  # entries already present (existing keys win). No-op when nothing changes.
  scaffold_pkg="$TEMPLATES_DIR/package.scaffold.json"
  if [[ "$merge_pkg_json" == "true" && -f "$scaffold_pkg" ]]; then
    if ! merge_result=$(jq -s '
      .[0] as $pkg
      | .[1] as $scaffold
      | $pkg
      | .scripts = (($scaffold.scripts // {}) + ($pkg.scripts // {}))
      | .devDependencies = (($scaffold.devDependencies // {}) + ($pkg.devDependencies // {}))
    ' "$root/package.json" "$scaffold_pkg" 2>&1); then
      log_error "package.json merge failed: $merge_result"
      exit 1
    fi

    # Compare stable-serialized forms to detect no-op.
    current=$(jq -S . "$root/package.json")
    next=$(printf '%s' "$merge_result" | jq -S .)
    if [[ "$current" != "$next" ]]; then
      tmp=$(mktemp "${root}/package.json.XXXXXX")
      printf '%s\n' "$merge_result" | jq '.' > "$tmp"
      mv -f "$tmp" "$root/package.json"
      created+=("$root/package.json (merged)")
      merged=true
      log_info "merged scaffold scripts/devDependencies into package.json"
    else
      log_info "package.json already up to date; no merge performed"
    fi
  fi
fi

# .gitignore management
gitignore="$root/.gitignore"
entries=(
  "# dark-factory plugin state"
  ".claude-plugin-data/"
  "*.worktree"
)
if [[ -f "$gitignore" ]]; then
  for entry in "${entries[@]}"; do
    if ! grep -qF "$entry" "$gitignore" 2>/dev/null; then
      printf '\n%s\n' "$entry" >> "$gitignore"
      log_info "appended to .gitignore: $entry"
    fi
  done
else
  printf '%s\n' "${entries[@]}" > "$gitignore"
  created+=("$gitignore")
fi

if [[ ${#created[@]} -gt 0 ]]; then
  created_json=$(printf '%s\n' "${created[@]}" | jq -R -s 'split("\n") | map(select(length > 0))')
else
  created_json='[]'
fi

jq -n \
  --argjson files_created "$created_json" \
  --argjson count "${#created[@]}" \
  '{files_created: $files_created, count: $count}'
