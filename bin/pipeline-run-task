#!/usr/bin/env bash
# Stage-machine wrapper that drives a single task (or the run-level
# finalize step) through the pipeline protocol. Every validation,
# classification, state-write, quota-gate, quality-gate, coverage-gate,
# holdout, review dispatch, PR-open, CI-wait, and cleanup step lives
# inside this wrapper - the orchestrator LLM never names them.
#
# Usage:
#   pipeline-run-task <run-id> <task-id> --stage <stage> [--worktree <path>]
#                     [--review-file <path>]... [--ci-status <green|red|timeout>]
#   pipeline-run-task <run-id> RUN       --stage finalize-run
#
# Exit codes (common across stages):
#    0   stage complete -> advance to next
#    2   end_gracefully (quota cap, circuit breaker, retries exhausted)
#    3   wait_retry (quota chunk slept, still over) - re-invoke same stage
#   10   spawn_required; stdout is a JSON spawn manifest
#   20   human_gate_pause - orchestrator halts, /factory:run resume restarts
#   30   task_terminal_failed / needs_human_review - skip task, continue loop
#
# Spawn manifest shape (exit 10):
#   { "action":"spawn_agents",
#     "stage_after":"<next-stage>",
#     "agents":[ { "subagent_type":"...",
#                  "isolation":"worktree",
#                  "model":"...",
#                  "maxTurns":N,
#                  "prompt_file":".state/<run-id>/<task-id>.<role>-prompt.md" } ] }

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

run_id="${1:?missing run-id}"
task_id="${2:?missing task-id}"
shift 2

stage=""
worktree=""
review_files=()
ci_status=""
merge_status=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --stage)        stage="$2"; shift 2 ;;
    --worktree)     worktree="$2"; shift 2 ;;
    --review-file)  review_files+=("$2"); shift 2 ;;
    --ci-status)    ci_status="$2"; shift 2 ;;
    --merge-status) merge_status="$2"; shift 2 ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

[[ -z "$stage" ]] && { log_error "--stage required"; exit 1; }

run_dir="${CLAUDE_PLUGIN_DATA}/runs/${run_id}"
state_file="$run_dir/state.json"
[[ -f "$state_file" ]] || { log_error "state file not found: $state_file"; exit 1; }

_now_ms() {
  if command -v gdate &>/dev/null; then gdate +%s%3N; return; fi
  local v; v=$(date +%s%3N 2>/dev/null)
  if [[ -n "$v" && "$v" != *N ]]; then printf '%s' "$v"
  else printf '%s000' "$(date +%s)"
  fi
}

_task_field() {
  local v
  v=$(pipeline-state task-read "$run_id" "$task_id" "$1" 2>/dev/null || printf '')
  [[ "$v" == "null" ]] && printf '' || printf '%s' "$v"
}

_task_write() {
  pipeline-state task-write "$run_id" "$task_id" "$1" "$2" >/dev/null
}

# Idempotent resume: every stage records its terminal marker in
# .tasks.<id>.stage. If invoked after a successful stage run (crash,
# resume, manual repeat), short-circuit so we don't double-spawn.
_already_past() {
  local want="$1"
  local cur
  cur=$(_task_field stage 2>/dev/null || printf '')
  case "$cur" in null|"") return 1 ;; esac
  local order=(preflight_done preexec_tests_done postexec_spawn_pending postexec_done postreview_done ship_done)
  local cur_rank=-1 want_rank=-1 i
  for i in "${!order[@]}"; do
    [[ "${order[$i]}" == "$cur"  ]] && cur_rank=$i
    [[ "${order[$i]}" == "$want" ]] && want_rank=$i
  done
  (( cur_rank >= want_rank && cur_rank >= 0 && want_rank >= 0 ))
}

_emit_manifest() {
  jq -cn --arg after "$1" --argjson agents "$2" \
    '{action:"spawn_agents", stage_after:$after, agents:$agents}'
}

_prompt_path() {
  printf '%s/.state/%s/%s.%s-prompt.md' "$run_dir" "$run_id" "$task_id" "$1"
}

_ensure_prompt_dir() {
  mkdir -p "$run_dir/.state/$run_id"
}

# --- preflight --------------------------------------------------------------
_stage_preflight() {
  local t0 t1 rc
  t0=$(_now_ms)
  log_step_begin "preflight" "task_id=\"$task_id\""

  if _already_past preflight_done; then
    t1=$(_now_ms)
    log_step_end "preflight" "skipped" "$((t1-t0))" "task_id=\"$task_id\""
    return 0
  fi

  if ! pipeline-circuit-breaker "$run_id" >/dev/null; then
    t1=$(_now_ms)
    log_step_end "preflight" "end_gracefully" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"circuit_breaker\""
    return 2
  fi

  if ! pipeline-state deps-satisfied "$run_id" "$task_id"; then
    t1=$(_now_ms)
    log_step_end "preflight" "skipped" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"deps_unsatisfied\""
    return 30
  fi

  local task_json
  task_json=$(pipeline-state task-read "$run_id" "$task_id" 2>/dev/null)
  if [[ -z "$task_json" || "$task_json" == "null" ]]; then
    log_error "task $task_id not found in state"
    t1=$(_now_ms)
    log_step_end "preflight" "failed" "$((t1-t0))" "task_id=\"$task_id\""
    return 30
  fi

  local classify risk tier
  classify=$(pipeline-classify-task "$task_json") || { log_error "classify-task failed"; return 30; }
  risk=$(pipeline-classify-risk "$task_json") || { log_error "classify-risk failed"; return 30; }
  tier=$(printf '%s' "$risk" | jq -r '.tier // "routine"')

  _task_write classify  "$classify"
  _task_write risk      "$risk"
  _task_write risk_tier "\"$tier\""

  pipeline_quota_gate "$run_id" "$tier" "task-$task_id" "$task_id"
  rc=$?
  case $rc in
    0) : ;;
    2) t1=$(_now_ms); log_step_end "preflight" "end_gracefully" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"quota\""; return 2 ;;
    3) t1=$(_now_ms); log_step_end "preflight" "wait_retry"     "$((t1-t0))" "task_id=\"$task_id\""; return 3 ;;
    *) t1=$(_now_ms); log_step_end "preflight" "failed"         "$((t1-t0))" "task_id=\"$task_id\""; return 30 ;;
  esac

  _ensure_prompt_dir
  local spec_path prompt_file
  spec_path=$(pipeline-state read "$run_id" '.spec.path // ""' 2>/dev/null || printf '')
  prompt_file=$(_prompt_path test-writer)
  {
    printf '[task:%s]\n' "$task_id"
    printf 'mode: pre-impl\n'
    printf 'task_id: %s\n' "$task_id"
    [[ -n "$spec_path" ]] && printf 'spec_path: %s\n' "$spec_path"
    printf 'Write failing tests derived purely from the spec.\n'
    printf 'Commit with message: test(<scope>): failing tests for %s [%s]\n' "$task_id" "$task_id"
    printf 'End with STATUS: RED_READY or STATUS: BLOCKED.\n'
  } > "$prompt_file"

  _task_write stage '"preflight_done"'
  pipeline-state task-status "$run_id" "$task_id" executing >/dev/null || true

  local cov_base snapshotted="false"
  cov_base=$(pipeline-state read "$run_id" '.orchestrator.worktree // empty' 2>/dev/null || true)
  if [[ -n "$cov_base" && -d "$cov_base" ]]; then
    local cov_before="$run_dir/.state/$run_id/$task_id.coverage-before.json"
    mkdir -p "$(dirname "$cov_before")"
    local _pkg_mgr
    _pkg_mgr=$(detect_pkg_manager "$cov_base" 2>/dev/null || echo "npm")
    if ( cd "$cov_base" && "$_pkg_mgr" run -s test:coverage >/dev/null 2>&1 ); then
      if [[ -f "$cov_base/coverage/coverage-summary.json" ]]; then
        cp "$cov_base/coverage/coverage-summary.json" "$cov_before"
        snapshotted="true"
      fi
    fi
  fi
  log_metric "task.coverage.snapshot" "task_id=\"$task_id\"" "snapshotted=$snapshotted"

  local agents_json
  agents_json=$(jq -cn --arg pf "$prompt_file" \
    '[{subagent_type:"test-writer", isolation:"worktree", model:"opus", maxTurns:25, prompt_file:$pf}]')
  _emit_manifest preexec_tests "$agents_json"

  t1=$(_now_ms)
  log_step_end "preflight" "spawn_test_writer" "$((t1-t0))" "task_id=\"$task_id\""
  log_metric "task.test_writer_spawned" "task_id=\"$task_id\""
  return 10
}

# Detect test runner from config or project files in $1 (worktree path).
# Prints: vitest | jest | pytest | cargo | "" (empty = unknown)
_detect_red_test_runner() {
  local wt="$1"
  local runner
  runner=$(read_config '.redTestRunner' '')
  if [[ -n "$runner" ]]; then printf '%s' "$runner"; return; fi
  if [[ -f "$wt/package.json" ]]; then
    if jq -e '.devDependencies.vitest // .dependencies.vitest' "$wt/package.json" &>/dev/null; then
      printf 'vitest'; return
    fi
    if jq -e '.devDependencies.jest // .dependencies.jest // ."devDependencies"."@jest/core"' \
        "$wt/package.json" &>/dev/null; then
      printf 'jest'; return
    fi
  fi
  if [[ -f "$wt/Cargo.toml" ]]; then printf 'cargo'; return; fi
  if [[ -f "$wt/pyproject.toml" ]] || [[ -f "$wt/pytest.ini" ]] || [[ -f "$wt/setup.py" ]]; then
    printf 'pytest'; return
  fi
  printf ''
}

# Resolve a usable base ref in <git_dir>: prefers local staging, falls back to origin/staging.
# Prints the ref name or nothing if neither exists.
_resolve_base_ref() {
  local git_dir="$1"
  if git -C "$git_dir" rev-parse --verify staging >/dev/null 2>&1; then
    printf 'staging'
  elif git -C "$git_dir" rev-parse --verify origin/staging >/dev/null 2>&1; then
    printf 'origin/staging'
  fi
}

# Verify that new test files written by the test-writer actually fail.
# Args: <tw_wt> (test-writer worktree path)
# Returns 0 (ok / skip), 1 (verification failed → block preexec_tests).
_verify_red_tests() {
  local tw_wt="$1"

  # Skip for tdd_exempt tasks
  local tdd_exempt
  tdd_exempt=$(jq -r --arg t "$task_id" \
    '.tasks[$t].tdd_exempt // false' "$state_file" 2>/dev/null || printf 'false')
  if [[ "$tdd_exempt" == "true" ]]; then
    log_info "red-test verification skipped (tdd_exempt) task_id=\"$task_id\""
    return 0
  fi

  # Find new test files added by test-writer (expanded pattern covers major ecosystems)
  local base_ref new_tests=()
  base_ref=$(_resolve_base_ref "$tw_wt")
  if [[ -z "$base_ref" ]]; then
    log_error "red-test verification: base ref not found (staging and origin/staging both missing) task_id=\"$task_id\""
    _task_write quality_gates.red_test '{"ok":false,"reason":"missing_base_ref"}'
    return 1
  fi
  while IFS= read -r f; do
    [[ -n "$f" ]] && new_tests+=("$f")
  done < <(cd "$tw_wt" && git diff "$base_ref..HEAD" --name-only --diff-filter=AM \
    | grep -E '\.(test|spec)\.(ts|tsx|js|jsx|mjs|cjs|py|rb|go|rs)$|_test\.(go|py|rb)$|Test\.(php|java)$|_spec\.rb$' || true)

  if [[ ${#new_tests[@]} -eq 0 ]]; then
    log_error "red-test verification: no new or modified test files found task_id=\"$task_id\""
    _task_write quality_gates.red_test '{"ok":false,"reason":"no_new_tests"}'
    return 1
  fi

  # Check for an explicit verification command first — escape hatch for exotic toolchains.
  # Command receives new test file paths as positional args.
  local custom_cmd
  custom_cmd=$(read_config '.quality.redTestCommand' '')
  if [[ -n "$custom_cmd" ]]; then
    log_info "red-test verification: using .quality.redTestCommand escape hatch task_id=\"$task_id\""
    local out_log rc=0
    out_log=$(mktemp)
    # shellcheck disable=SC2086
    (cd "$tw_wt" && $custom_cmd "${new_tests[@]}" >"$out_log" 2>&1) || rc=$?
    local out
    out=$(cat "$out_log" 2>/dev/null || printf '')
    rm -f "$out_log"
    # Apply same rc taxonomy as the built-in runners below.
    if [[ $rc -eq 0 ]]; then
      log_error "red-test verification: tests passed (not red) via .quality.redTestCommand task_id=\"$task_id\""
      _task_write quality_gates.red_test '{"ok":false,"reason":"tests_not_red"}'
      return 1
    elif [[ $rc -ge 126 ]]; then
      log_error "red-test verification: infra error (rc=$rc) via .quality.redTestCommand; failing closed task_id=\"$task_id\""
      _task_write quality_gates.red_test "{\"ok\":false,\"reason\":\"infra_error\",\"rc\":$rc}"
      return 1
    fi
    _task_write quality_gates.red_test '{"ok":true}'
    return 0
  fi

  # Detect runner
  local runner
  runner=$(_detect_red_test_runner "$tw_wt")
  if [[ -z "$runner" ]]; then
    log_error "red-test verification: cannot detect test runner; set .quality.redTestCommand or mark tdd_exempt task_id=\"$task_id\""
    _task_write quality_gates.red_test '{"ok":false,"reason":"runner_undetectable"}'
    return 1
  fi

  local pkg_mgr
  pkg_mgr=$(detect_pkg_manager "$tw_wt")

  # Build scoped command. Cargo: scope to the specific test target derived from path to
  # avoid running the entire workspace and conflating unrelated failures.
  local cmd=()
  case "$runner" in
    vitest) cmd=("$pkg_mgr" exec vitest run "${new_tests[@]}") ;;
    jest)   cmd=("$pkg_mgr" exec jest -- "${new_tests[@]}") ;;
    pytest) cmd=(pytest "${new_tests[@]}") ;;
    cargo)
      # Derive test target from the first new test file.
      # tests/<name>.rs → --test <name>; src/**/*_test.rs → --lib (best effort)
      local first_test="${new_tests[0]}"
      local cargo_target=""
      if [[ "$first_test" =~ ^tests/([^/]+)\.rs$ ]]; then
        cargo_target="--test ${BASH_REMATCH[1]}"
      elif [[ "$first_test" =~ src/ ]]; then
        cargo_target="--lib"
      fi
      if [[ -z "$cargo_target" ]]; then
        log_warn "red-test verification: cannot scope cargo test for '$first_test'; failing closed task_id=\"$task_id\""
        _task_write quality_gates.red_test '{"ok":false,"reason":"cargo_unscopable"}'
        return 1
      fi
      # shellcheck disable=SC2086
      cmd=(cargo test $cargo_target)
      ;;
    *)
      log_error "red-test verification: unsupported runner '$runner'; set .quality.redTestCommand or mark tdd_exempt task_id=\"$task_id\""
      _task_write quality_gates.red_test "{\"ok\":false,\"reason\":\"unsupported_runner\",\"runner\":\"$runner\"}"
      return 1
      ;;
  esac

  # Capture output to apply rc taxonomy — infra failures must not masquerade as red tests.
  local out_log
  out_log=$(mktemp)
  local rc=0
  (cd "$tw_wt" && "${cmd[@]}" >"$out_log" 2>&1) || rc=$?
  local out
  out=$(cat "$out_log" 2>/dev/null || printf '')
  rm -f "$out_log"

  # rc taxonomy: fail closed on infra signals so only genuine assertion failures count.
  if [[ $rc -eq 0 ]]; then
    log_error "red-test verification failed: new tests passed (no-op assertions?) task_id=\"$task_id\""
    _task_write quality_gates.red_test '{"ok":false,"reason":"tests_passed"}'
    return 1
  fi

  if [[ $rc -eq 127 ]]; then
    log_error "red-test verification: command not found (rc=127) — infra failure task_id=\"$task_id\""
    _task_write quality_gates.red_test '{"ok":false,"reason":"command_not_found"}'
    return 1
  fi

  # Detect infra-level failure patterns in output regardless of rc
  if printf '%s' "$out" | grep -qE \
    'ModuleNotFoundError|ImportError|SyntaxError|collection error|compile error|error\[E[0-9]+\]|^panic:|no tests ran|ran 0 tests|0 passed.*0 failed|0 tests collected|FAILED TO COLLECT'; then
    log_error "red-test verification: infra/compile failure detected in output task_id=\"$task_id\""
    _task_write quality_gates.red_test '{"ok":false,"reason":"infra_failure"}'
    return 1
  fi

  log_info "red-test verification passed: ${#new_tests[@]} new test(s) are red task_id=\"$task_id\""
  _task_write quality_gates.red_test '{"ok":true}'
  return 0
}

# --- preexec_tests ----------------------------------------------------------
_stage_preexec_tests() {
  local t0 t1
  t0=$(_now_ms)
  log_step_begin "preexec_tests" "task_id=\"$task_id\""

  if _already_past preexec_tests_done; then
    t1=$(_now_ms)
    log_step_end "preexec_tests" "skipped" "$((t1-t0))" "task_id=\"$task_id\""
    return 0
  fi

  local tw_status
  tw_status=$(_task_field test_writer_status)
  tw_status=$(printf '%s' "$tw_status" | tr -d '"')

  # Resume path: status not recorded; check for an existing test commit.
  if [[ -z "$tw_status" ]]; then
    local tw_wt
    tw_wt=$(_task_field worktree)
    tw_wt=$(printf '%s' "$tw_wt" | tr -d '"')
    [[ -z "$tw_wt" ]] && tw_wt="$worktree"
    if [[ -n "$tw_wt" && -d "$tw_wt" ]]; then
      local resume_base
      resume_base=$(_resolve_base_ref "$tw_wt")
      if [[ -n "$resume_base" ]] \
         && ( cd "$tw_wt" && git log --format=%s "$resume_base..HEAD" 2>/dev/null \
                | grep -qE "^test\(.*\):.*\[${task_id}\]" 2>/dev/null ); then
        tw_status="RED_READY"
      fi
    fi
  fi

  if [[ -z "$tw_status" ]]; then
    _ensure_prompt_dir
    local spec_path pf
    spec_path=$(pipeline-state read "$run_id" '.spec.path // ""' 2>/dev/null || printf '')
    pf=$(_prompt_path test-writer)
    {
      printf '[task:%s]\n' "$task_id"
      printf 'mode: pre-impl\n'
      printf 'task_id: %s\n' "$task_id"
      [[ -n "$spec_path" ]] && printf 'spec_path: %s\n' "$spec_path"
      printf 'Write failing tests derived purely from the spec.\n'
      printf 'Commit: test(<scope>): failing tests for %s [%s]\n' "$task_id" "$task_id"
      printf 'End with STATUS: RED_READY or STATUS: BLOCKED.\n'
    } > "$pf"
    local agents_json
    agents_json=$(jq -cn --arg pf "$pf" \
      '[{subagent_type:"test-writer", isolation:"worktree", model:"opus", maxTurns:25, prompt_file:$pf}]')
    _emit_manifest preexec_tests "$agents_json"
    t1=$(_now_ms)
    log_step_end "preexec_tests" "spawn_test_writer" "$((t1-t0))" "task_id=\"$task_id\""
    return 10
  fi

  if [[ "$tw_status" == "BLOCKED" ]]; then
    log_warn "test-writer blocked for $task_id"
    pipeline-state task-status "$run_id" "$task_id" failed >/dev/null || true
    t1=$(_now_ms)
    log_step_end "preexec_tests" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"test_writer_blocked\""
    return 30
  fi

  # RED_READY (or other non-blocked): verify tests are actually red before spawning executor.
  local tw_wt
  tw_wt=$(_task_field worktree)
  tw_wt=$(printf '%s' "$tw_wt" | tr -d '"')
  [[ -z "$tw_wt" ]] && tw_wt="$worktree"

  if ! _verify_red_tests "$tw_wt"; then
    _task_write test_writer_status '"BLOCKED"'
    pipeline-state task-status "$run_id" "$task_id" failed >/dev/null || true
    t1=$(_now_ms)
    log_step_end "preexec_tests" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"red_tests_not_verified\""
    return 30
  fi

  # Spawn task-executor for GREEN phase.
  _ensure_prompt_dir
  local spec_path prompt_file holdout_pct task_json
  spec_path=$(pipeline-state read "$run_id" '.spec.path // ""' 2>/dev/null || printf '')
  holdout_pct=$(read_config '.quality.holdoutPercent' '20')
  task_json=$(pipeline-state task-read "$run_id" "$task_id" 2>/dev/null)
  prompt_file=$(_prompt_path executor)
  local args=()
  [[ -n "$spec_path" ]] && args+=(--spec-path "$spec_path")
  args+=(--holdout "$holdout_pct")
  local _tmp_prompt; _tmp_prompt=$(mktemp)
  if ! pipeline-build-prompt "$task_json" "${args[@]}" > "$_tmp_prompt"; then
    rm -f "$_tmp_prompt"
    log_error "build-prompt failed"
    t1=$(_now_ms)
    log_step_end "preexec_tests" "failed" "$((t1-t0))" "task_id=\"$task_id\""
    return 30
  fi
  { printf '[task:%s]\n' "$task_id"; cat "$_tmp_prompt"; } > "$prompt_file"
  rm -f "$_tmp_prompt"

  _task_write stage '"preexec_tests_done"'

  local classify_json model max_turns agents_json
  classify_json=$(_task_field classify)
  if [[ -n "$classify_json" && "$classify_json" != "null" ]]; then
    model=$(printf '%s' "$classify_json" | jq -r '.model // "sonnet"' 2>/dev/null || printf 'sonnet')
    max_turns=$(printf '%s' "$classify_json" | jq -r '.maxTurns // .max_turns // 60' 2>/dev/null || printf '60')
  else
    model="sonnet"
    max_turns="60"
  fi
  agents_json=$(jq -cn \
    --arg role "task-executor" \
    --arg pf   "$prompt_file" \
    --arg m    "$model" \
    --argjson mt "$max_turns" \
    '[{subagent_type:$role, isolation:"worktree", model:$m, maxTurns:$mt, prompt_file:$pf}]')
  _emit_manifest postexec "$agents_json"

  t1=$(_now_ms)
  log_step_end "preexec_tests" "spawn_executor" "$((t1-t0))" "task_id=\"$task_id\""
  log_metric "task.executor_spawned" "task_id=\"$task_id\"" "model=\"$model\""
  return 10
}

# --- postexec ---------------------------------------------------------------
_stage_postexec() {
  local t0 t1
  t0=$(_now_ms)
  log_step_begin "postexec" "task_id=\"$task_id\""

  # REQUEST_CHANGES re-entry: postreview set reviewer_only=true and spawned an
  # executor-fix. Executor has now committed fixes; gates MUST re-run regardless
  # of current stage rank. Check this BEFORE the spawn-pending crash-recovery
  # guard so stale review_files from the prior round don't trigger a spurious skip.
  if _already_past postexec_done; then
    local reviewer_only
    reviewer_only=$(_task_field postexec_reviewer_only)
    reviewer_only=$(printf '%s' "$reviewer_only" | tr -d '"')
    if [[ "$reviewer_only" != "true" ]]; then
      t1=$(_now_ms)
      log_step_end "postexec" "skipped" "$((t1-t0))" "task_id=\"$task_id\""
      return 0
    fi
    # Clear flag and stale review_files so the new review round starts fresh.
    _task_write postexec_reviewer_only 'null'
    _task_write review_files '[]'
    # Reset stage to preexec_tests_done so _emit_postexec_manifest can advance it.
    _task_write stage '"preexec_tests_done"'
  fi

  # postexec_spawn_pending: gates passed + manifest emitted last run but
  # postreview hasn't written postexec_done yet (crash window).
  # Only reached when reviewer_only was false/absent (handled above).
  # Re-check review_files: populated means Codex ran sync — resume into postreview.
  # Empty means agent path — re-emit manifest (idempotent).
  if _already_past postexec_spawn_pending; then
    local existing_rf
    existing_rf=$(_task_field review_files 2>/dev/null || printf 'null')
    local rf_count
    rf_count=$(printf '%s' "$existing_rf" | jq 'if type=="array" then length else 0 end' 2>/dev/null || printf '0')
    if (( rf_count > 0 )); then
      t1=$(_now_ms)
      log_step_end "postexec" "skipped_resume_codex" "$((t1-t0))" "task_id=\"$task_id\""
      return 0
    fi
    local wt_resume
    wt_resume=$(_task_field worktree)
    wt_resume=$(printf '%s' "$wt_resume" | sed -e 's/^"//' -e 's/"$//')
    _emit_postexec_manifest "$wt_resume"
    t1=$(_now_ms)
    log_step_end "postexec" "re_emit_manifest" "$((t1-t0))" "task_id=\"$task_id\""
    return 10
  fi

  local wt
  wt=$(_task_field worktree)
  wt=$(printf '%s' "$wt" | sed -e 's/^"//' -e 's/"$//')
  [[ -z "$wt" ]] && wt="$worktree"
  if [[ -z "$wt" ]]; then
    log_error "worktree not set for task $task_id (SubagentStop hook missing?); pass --worktree"
    t1=$(_now_ms)
    log_step_end "postexec" "failed" "$((t1-t0))" "task_id=\"$task_id\""
    return 30
  fi
  _task_write worktree "\"$wt\""

  if ! pipeline-quality-gate "$run_id" "$task_id" "$wt" >/dev/null; then
    log_warn "quality gate failed for $task_id"
    t1=$(_now_ms)
    log_step_end "postexec" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"quality\""
    return 30
  fi

  if ! ( cd "$wt" && pipeline-tdd-gate --task-id "$task_id" --run-id "$run_id" ) >/dev/null; then
    _task_write quality_gates.tdd '{"ok":false}'
    log_warn "tdd gate failed for $task_id"
    t1=$(_now_ms)
    log_step_end "postexec" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"tdd\""
    return 30
  fi
  _task_write quality_gates.tdd '{"ok":true}'

  local cov_before="$run_dir/.state/$run_id/$task_id.coverage-before.json"
  local cov_after="$wt/coverage/coverage-summary.json"
  if [[ -f "$cov_before" && -f "$cov_after" ]]; then
    if ! pipeline-coverage-gate "$cov_before" "$cov_after" --task-id "$task_id" >/dev/null; then
      log_warn "coverage gate failed for $task_id"
      _task_write quality_gates.coverage '"fail"'
      t1=$(_now_ms)
      log_step_end "postexec" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"coverage\""
      return 30
    fi
    _task_write quality_gates.coverage '"ok"'
  else
    _task_write quality_gates.coverage '"skipped"'
  fi

  local holdout_file="$run_dir/holdouts/$task_id.json"
  if [[ -f "$holdout_file" ]]; then
    local reviewer_output
    reviewer_output=$(_task_field holdout_review_file)
    reviewer_output=$(printf '%s' "$reviewer_output" | sed -e 's/^"//' -e 's/"$//')
    if [[ -n "$reviewer_output" && -f "$reviewer_output" ]]; then
      if pipeline-holdout-validate check "$run_id" "$task_id" "$reviewer_output" >/dev/null; then
        _task_write quality_gates.holdout '"pass"'
      else
        _task_write quality_gates.holdout '"fail"'
        log_warn "holdout failed for $task_id"
        t1=$(_now_ms)
        log_step_end "postexec" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"holdout\""
        return 30
      fi
    else
      # holdout_review_file not wired by SubagentStop yet — record skip so the
      # scorer can distinguish "not configured" from "passed". Do not spawn a
      # dedicated holdout reviewer here; infinite re-entry risk.
      _task_write quality_gates.holdout '"skipped"'
      log_warn "holdout file present but reviewer output not wired for $task_id; skipping Layer 4"
    fi
  fi

  local _manifest_rc
  _emit_postexec_manifest "$wt" && _manifest_rc=$? || _manifest_rc=$?
  if (( _manifest_rc == 30 )); then
    t1=$(_now_ms)
    log_step_end "postexec" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"manifest\""
    return 30
  fi
  t1=$(_now_ms)
  log_step_end "postexec" "spawn" "$((t1-t0))" "task_id=\"$task_id\"" "reviewers=\"implementation+quality\""
  return 10
}

# Helper: build + emit reviewer manifest. Writes postexec_spawn_pending before
# any asynchronous work so a crash leaves a recoverable intermediate stage.
# Returns 0 for Codex (sync, caller falls through to postreview).
# Returns 10 for agent path (caller should exit 10 to yield to subagent).
# Returns 30 on failure.
_emit_postexec_manifest() {
  local wt="$1"
  local detect provider
  detect=$(pipeline-detect-reviewer)
  provider=$(printf '%s' "$detect" | jq -r '.reviewer')
  log_metric "task.review.provider" "task_id=\"$task_id\"" "reviewer=\"$provider\""

  local tier
  tier=$(_task_field risk_tier)
  tier=$(printf '%s' "$tier" | sed -e 's/^"//' -e 's/"$//')
  [[ -z "$tier" ]] && tier="routine"

  _ensure_prompt_dir
  local pf
  pf=$(_prompt_path reviewer)
  {
    printf '[task:%s]\n' "$task_id"
    printf 'Review task %s in the worktree at %s.\n' "$task_id" "$wt"
    printf 'End your response with exactly one of:\n'
    printf '  STATUS: DONE | DONE_WITH_CONCERNS | BLOCKED | NEEDS_CONTEXT\n'
  } > "$pf"

  local prior_blockers
  prior_blockers=$(_task_field postreview_prior_blockers 2>/dev/null || printf 'null')
  local pb_len
  pb_len=$(printf '%s' "$prior_blockers" | jq 'if type=="array" then length else 0 end' 2>/dev/null || printf '0')
  if (( pb_len > 0 )); then
    {
      printf '\nPrior review round raised these blockers. For EACH blocker, include a\n'
      printf '"prior_blocker_map" array in your JSON verdict section:\n'
      printf '  {"prior_blocker_map": [{"id": <N>, "status": "resolved|still-present|invalidated", "notes": "..."}]}\n'
      printf '\nPrior blockers:\n'
      printf '%s' "$prior_blockers" | jq -r '.[] | "  [\(.id)] \(.severity // "?"): \(.description // "(none)") [\(.file // "?"):\(.line // "?")]"' 2>/dev/null || true
    } >> "$pf"
  fi

  if [[ "$provider" == "codex" ]]; then
    local review_file="$run_dir/.state/$run_id/$task_id.review.codex.json"
    local spec_path
    spec_path=$(pipeline-state read "$run_id" '.spec.path // ""' 2>/dev/null || printf '')
    local cargs=(--task-id "$task_id")
    [[ -n "$spec_path" ]] && cargs+=(--spec-dir "$spec_path")
    if ! pipeline-codex-review "${cargs[@]}" > "$review_file"; then
      log_warn "codex review failed for $task_id"
      return 30
    fi
    _task_write review_files "$(jq -n --arg f "$review_file" '[$f]')"
    # Codex review is synchronous — no crash window, advance directly to postexec_done.
    _task_write stage '"postexec_done"'
    local codex_agents_json
    codex_agents_json=$(jq -cn --arg pf "$pf" \
      '[{subagent_type:"implementation-reviewer", isolation:"worktree", model:"sonnet", maxTurns:1, prompt_file:$pf}]')
    case "$tier" in
      feature)
        codex_agents_json=$(printf '%s' "$codex_agents_json" | jq -c --arg pf "$pf" \
          '. + [{subagent_type:"architecture-reviewer", isolation:"worktree", model:"sonnet", maxTurns:30, prompt_file:$pf}]') ;;
      security)
        codex_agents_json=$(printf '%s' "$codex_agents_json" | jq -c --arg pf "$pf" \
          '. + [{subagent_type:"security-reviewer", isolation:"worktree", model:"sonnet", maxTurns:30, prompt_file:$pf},
                {subagent_type:"architecture-reviewer", isolation:"worktree", model:"sonnet", maxTurns:30, prompt_file:$pf}]') ;;
    esac
    _emit_manifest postreview "$codex_agents_json"
    return 10
  fi

  # Agent path: write stage before manifest emission — crash between means
  # resume re-enters postexec_spawn_pending and re-emits (idempotent).
  _task_write stage '"postexec_spawn_pending"'

  local agents_json
  agents_json=$(jq -cn --arg pf "$pf" \
    '[{subagent_type:"implementation-reviewer", isolation:"worktree", model:"sonnet", maxTurns:30, prompt_file:$pf}]')

  case "$tier" in
    feature)
      agents_json=$(printf '%s' "$agents_json" | jq -c --arg pf "$pf" \
        '. + [{subagent_type:"architecture-reviewer", isolation:"worktree", model:"sonnet", maxTurns:30, prompt_file:$pf}]') ;;
    security)
      agents_json=$(printf '%s' "$agents_json" | jq -c --arg pf "$pf" \
        '. + [{subagent_type:"security-reviewer", isolation:"worktree", model:"sonnet", maxTurns:30, prompt_file:$pf},
              {subagent_type:"architecture-reviewer", isolation:"worktree", model:"sonnet", maxTurns:30, prompt_file:$pf}]') ;;
  esac

  agents_json=$(printf '%s' "$agents_json" | jq -c --arg pf "$pf" \
    '. + [{subagent_type:"quality-reviewer", isolation:"worktree", model:"sonnet", maxTurns:30, prompt_file:$pf}]')

  _emit_manifest postreview "$agents_json"
  return 10
}

# --- postreview -------------------------------------------------------------
_stage_postreview() {
  local t0 t1
  t0=$(_now_ms)
  log_step_begin "postreview" "task_id=\"$task_id\""

  if _already_past postreview_done; then
    t1=$(_now_ms)
    log_step_end "postreview" "skipped" "$((t1-t0))" "task_id=\"$task_id\""
    return 0
  fi

  local -a files=()
  if (( ${#review_files[@]} )); then
    files=("${review_files[@]}")
  else
    local list
    local raw
    raw=$(_task_field review_files)
    list=$(printf '%s' "$raw" | jq -r 'if type=="array" then .[] else empty end' 2>/dev/null || printf '')
    while IFS= read -r f; do [[ -n "$f" ]] && files+=("$f"); done <<< "$list"
  fi
  if (( ${#files[@]} == 0 )); then
    log_error "no review files provided"
    t1=$(_now_ms)
    log_step_end "postreview" "failed" "$((t1-t0))" "task_id=\"$task_id\""
    return 30
  fi

  # Strict: every listed artifact must exist before advancing state.
  for f in "${files[@]}"; do
    if [[ ! -f "$f" ]]; then
      log_error "review file missing: $f"
      t1=$(_now_ms)
      log_step_end "postreview" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"missing_review_file\""
      return 30
    fi
  done

  # Durable commit point: all review artifacts confirmed present.
  _task_write stage '"postexec_done"'

  # Resolve task worktree so pipeline-parse-review can run `git diff` from
  # the right place when --base is supplied (validator drops findings whose
  # verbatim_line isn't in the diff).
  local pr_wt
  pr_wt=$(_task_field worktree)
  pr_wt=$(printf '%s' "$pr_wt" | sed -e 's/^"//' -e 's/"$//')
  [[ -z "$pr_wt" ]] && pr_wt="$worktree"

  local any_changes=false any_discuss=false f verdict decision raw_json still_count
  for f in "${files[@]}"; do
    [[ ! -f "$f" ]] && { log_warn "review file missing: $f"; continue; }
    if [[ "$f" == *.json ]]; then
      # Already-normalized verdict JSON (e.g. pipeline-codex-review output, which
      # runs validate_findings internally before writing the file).
      verdict=$(cat "$f") || { log_warn "read failed on $f"; any_changes=true; continue; }
      if ! printf '%s' "$verdict" | jq -e 'has("verdict") or has("decision")' >/dev/null 2>&1; then
        log_warn "normalized review missing .verdict/.decision field: $f"; any_changes=true; continue
      fi
    elif [[ -n "$pr_wt" && -d "$pr_wt" ]]; then
      local base_ref
      base_ref=$(_resolve_base_ref "$pr_wt")
      if [[ -z "$base_ref" ]]; then
        log_warn "postreview: base ref not found (staging and origin/staging both missing) — treating $f as REQUEST_CHANGES task_id=\"$task_id\""
        any_changes=true
        continue
      fi
      verdict=$(cd "$pr_wt" && pipeline-parse-review --base "$base_ref" < "$f") || { log_warn "parse-review failed on $f"; any_changes=true; continue; }
    else
      log_warn "postreview: worktree unresolved — running parse-review without diff validation on $f task_id=\"$task_id\""
      verdict=$(pipeline-parse-review < "$f") || { log_warn "parse-review failed on $f"; any_changes=true; continue; }
    fi
    # pipeline-parse-review emits `.verdict`; accept legacy `.decision` for
    # backward compatibility with older reviewer outputs / test fixtures.
    decision=$(printf '%s' "$verdict" | jq -r '.verdict // .decision // "UNKNOWN"')
    case "$decision" in
      APPROVE) : ;;
      REQUEST_CHANGES) any_changes=true ;;
      NEEDS_DISCUSSION) any_discuss=true ;;
      *) any_changes=true ;;
    esac
  done

  # Check prior_blocker_map for still-present entries
  local prior_blockers_raw
  prior_blockers_raw=$(_task_field postreview_prior_blockers 2>/dev/null || printf 'null')
  local pb_active_len
  pb_active_len=$(printf '%s' "$prior_blockers_raw" | jq 'if type=="array" then length else 0 end' 2>/dev/null || printf '0')
  if (( pb_active_len > 0 )); then
    for f in "${files[@]}"; do
      [[ ! -f "$f" ]] && continue
      if [[ "$f" == *.json ]]; then
        raw_json=$(cat "$f" 2>/dev/null || printf '{}')
      else
        # Extract last ```json...``` block from markdown (matches pipeline-parse-review behaviour)
        raw_json=$(awk '/^```json/{p=1;buf="";next}/^```/{if(p){last=buf;p=0};next}p{buf=buf $0 "\n"}END{printf "%s",last}' "$f" 2>/dev/null || printf '{}')
      fi
      still_count=$(printf '%s' "$raw_json" | \
        jq '[.prior_blocker_map // [] | .[] | select(.status == "still-present")] | length' 2>/dev/null || printf '0')
      if (( still_count > 0 )); then
        log_warn "postreview: $still_count prior blocker(s) still-present in $f"
        any_changes=true
      fi
    done
  fi

  if $any_discuss; then
    _task_write stage '"postreview_pending_human"'
    pipeline-state task-status "$run_id" "$task_id" needs_human_review >/dev/null || true
    t1=$(_now_ms)
    log_step_end "postreview" "needs_human_review" "$((t1-t0))" "task_id=\"$task_id\""
    return 30
  fi

  if $any_changes; then
    local attempts
    attempts=$(_task_field review_attempts)
    [[ -z "$attempts" ]] && attempts=0
    attempts=$((attempts + 1))
    _task_write review_attempts "$attempts"
    if (( attempts > 3 )); then
      _task_write stage '"postreview_exhausted"'
      pipeline-state task-status "$run_id" "$task_id" failed >/dev/null || true
      t1=$(_now_ms)
      log_step_end "postreview" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"review_exhausted\""
      return 30
    fi

    # Extract blockers from all review files as numbered JSON array
    local prior_blockers_json
    prior_blockers_json='[]'
    local idx=0
    for f in "${files[@]}"; do
      [[ ! -f "$f" ]] && continue
      local fverdict
      if [[ "$f" == *.json ]]; then
        fverdict=$(cat "$f" 2>/dev/null) || continue
        printf '%s' "$fverdict" | jq -e 'has("verdict")' >/dev/null 2>&1 || continue
      else
        fverdict=$(pipeline-parse-review < "$f" 2>/dev/null) || continue
      fi
      local ffindings
      ffindings=$(printf '%s' "$fverdict" | jq -c '.findings // [] | map(select(type=="object"))' 2>/dev/null || printf '[]')
      local count
      count=$(printf '%s' "$ffindings" | jq 'length' 2>/dev/null || printf '0')
      if (( count > 0 )); then
        local numbered
        numbered=$(printf '%s' "$ffindings" | jq -c --argjson start "$idx" \
          '[to_entries[] | {id: (.key + $start + 1), file: .value.file, line: .value.line, evidence: .value.evidence, severity: .value.severity, description: .value.description}]' 2>/dev/null || printf '[]')
        prior_blockers_json=$(printf '%s\n%s' "$prior_blockers_json" "$numbered" | jq -cs 'add // []' 2>/dev/null || printf '[]')
        idx=$(( idx + count ))
      fi
    done
    _task_write postreview_prior_blockers "$prior_blockers_json"
    _task_write postexec_reviewer_only '"true"'

    _ensure_prompt_dir
    local pf
    pf=$(_prompt_path executor-fix)
    {
      printf '[task:%s]\n' "$task_id"
      printf 'Fix reviewer-reported blockers for task %s.\n' "$task_id"
      printf 'Review files:\n'
      for f in "${files[@]}"; do printf '  - %s\n' "$f"; done
      local pb_len
      pb_len=$(printf '%s' "$prior_blockers_json" | jq 'length' 2>/dev/null || printf '0')
      if (( pb_len > 0 )); then
        printf '\nPrior blockers to address (numbered for tracking):\n'
        printf '%s\n' "$prior_blockers_json" | jq -r '.[] | "  [\(.id)] \(.severity // "?"): \(.description // "(no description)") [\(.file // "?"):\(.line // "?")]"' 2>/dev/null || true
      fi
      printf 'End with STATUS: DONE|DONE_WITH_CONCERNS|BLOCKED|NEEDS_CONTEXT.\n'
    } > "$pf"
    local agents_json
    agents_json=$(jq -cn --arg pf "$pf" \
      '[{subagent_type:"task-executor", isolation:"worktree", model:"sonnet", maxTurns:60, prompt_file:$pf}]')
    _emit_manifest postexec "$agents_json"
    t1=$(_now_ms)
    log_step_end "postreview" "spawn" "$((t1-t0))" "task_id=\"$task_id\"" "attempt=$attempts"
    return 10
  fi

  _task_write stage '"postreview_done"'
  _task_write postreview_prior_blockers 'null'
  _task_write postexec_reviewer_only 'null'
  t1=$(_now_ms)
  log_step_end "postreview" "ok" "$((t1-t0))" "task_id=\"$task_id\""
  return 0
}

# Write a ship checklist JSON to .tasks/<task_id>.ship_checklist.json inside
# the run directory. Reads gate results already stored in state.
_write_ship_checklist() {
  local checklist_dir="$run_dir/.tasks"
  mkdir -p "$checklist_dir"
  local checklist_file="$checklist_dir/${task_id}.ship_checklist.json"

  # tdd_gate: read from quality_gates.tdd.ok (true/false/null) + exempt flag.
  local tdd_ok tdd_exempt tdd_gate
  tdd_ok=$(jq -r --arg t "$task_id" '.tasks[$t].quality_gates.tdd.ok // "null"' "$state_file" 2>/dev/null || printf 'null')
  tdd_exempt=$(jq -r --arg t "$task_id" '.tasks[$t].quality_gates.tdd.exempt // false' "$state_file" 2>/dev/null || printf 'false')
  if [[ "$tdd_exempt" == "true" ]]; then
    tdd_gate="skipped"
  elif [[ "$tdd_ok" == "true" ]]; then
    tdd_gate="ok"
  elif [[ "$tdd_ok" == "false" ]]; then
    tdd_gate="fail"
  else
    # tdd_gate result absent — treat as skipped (task may be tdd_exempt at tasks.json level)
    tdd_gate="skipped"
  fi

  # coverage_gate: read from quality_gates.coverage (ok|fail|skipped).
  local cov_raw coverage_gate
  cov_raw=$(_task_field 'quality_gates.coverage' 2>/dev/null || printf '')
  cov_raw=$(printf '%s' "$cov_raw" | tr -d '"')
  case "$cov_raw" in
    ok|fail|skipped) coverage_gate="$cov_raw" ;;
    *) coverage_gate="skipped" ;;
  esac

  # quality_gate: from quality_gate.ok (true/false).
  local qok quality_gate
  qok=$(jq -r --arg t "$task_id" '.tasks[$t].quality_gate.ok // false' "$state_file" 2>/dev/null || printf 'false')
  quality_gate=$([[ "$qok" == "true" ]] && printf 'ok' || printf 'fail')

  # review_blockers_resolved: true if postreview_done (no pending blockers).
  local stage_cur review_blockers_resolved
  stage_cur=$(_task_field stage 2>/dev/null || printf '')
  stage_cur=$(printf '%s' "$stage_cur" | tr -d '"')
  review_blockers_resolved=$([[ "$stage_cur" == "postreview_done" ]] && printf 'true' || printf 'false')

  # ci_status: from task state (green|pending|red). Map to checklist values.
  local ci_raw ci_status
  ci_raw=$(_task_field ci_status 2>/dev/null || printf '')
  ci_raw=$(printf '%s' "$ci_raw" | tr -d '"')
  case "$ci_raw" in
    green) ci_status="green" ;;
    red)   ci_status="red"   ;;
    *)     ci_status="pending" ;;
  esac

  local iso_now
  iso_now=$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || printf 'unknown')

  jq -n \
    --arg task_id        "$task_id" \
    --arg tdd_gate       "$tdd_gate" \
    --arg coverage_gate  "$coverage_gate" \
    --arg quality_gate   "$quality_gate" \
    --argjson review_blockers_resolved "$review_blockers_resolved" \
    --arg ci_status      "$ci_status" \
    --arg generated_at   "$iso_now" \
    '{
      task_id:                  $task_id,
      tdd_gate:                 $tdd_gate,
      coverage_gate:            $coverage_gate,
      quality_gate:             $quality_gate,
      review_blockers_resolved: $review_blockers_resolved,
      ci_status:                $ci_status,
      generated_at:             $generated_at
    }' > "${checklist_file}.tmp" && mv "${checklist_file}.tmp" "$checklist_file"

  log_metric "task.ship_checklist_written" "task_id=\"$task_id\"" "tdd=\"$tdd_gate\"" \
    "coverage=\"$coverage_gate\"" "quality=\"$quality_gate\"" "ci=\"$ci_status\""
}

# --- ship -------------------------------------------------------------------
_stage_ship() {
  local t0 t1
  t0=$(_now_ms)
  log_step_begin "ship" "task_id=\"$task_id\""

  if _already_past ship_done; then
    t1=$(_now_ms)
    log_step_end "ship" "skipped" "$((t1-t0))" "task_id=\"$task_id\""
    return 0
  fi

  if [[ -n "$ci_status" ]]; then
    _task_write ci_status "\"$ci_status\""
    [[ -n "$merge_status" ]] && _task_write merge_status "\"$merge_status\""
    case "$ci_status" in
      green)
        if [[ "$merge_status" == "stalled" ]]; then
          pipeline-state task-status "$run_id" "$task_id" failed >/dev/null || true
          _task_write failure_reason '"auto-merge stalled despite green CI; manual investigation required"'
          t1=$(_now_ms)
          log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"merge_stalled\""
          return 30
        fi
        pipeline-state task-status "$run_id" "$task_id" done >/dev/null || true
        _task_write stage '"ship_done"'
        t1=$(_now_ms)
        log_step_end "ship" "ok" "$((t1-t0))" "task_id=\"$task_id\"" "ci=\"green\""
        return 0 ;;
      red)
        local attempts
        attempts=$(_task_field ci_fix_attempts)
        [[ -z "$attempts" ]] && attempts=0
        attempts=$((attempts + 1))
        _task_write ci_fix_attempts "$attempts"
        if (( attempts > 2 )); then
          pipeline-state task-status "$run_id" "$task_id" failed >/dev/null || true
          t1=$(_now_ms)
          log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"ci_exhausted\""
          return 30
        fi
        pipeline-state task-status "$run_id" "$task_id" ci_fixing >/dev/null || true
        _ensure_prompt_dir
        local pf; pf=$(_prompt_path executor-ci-fix)
        printf '[task:%s]\nFix failing CI on PR for task %s.\nSTATUS: DONE|...\n' "$task_id" "$task_id" > "$pf"
        local agents_json
        agents_json=$(jq -cn --arg pf "$pf" \
          '[{subagent_type:"task-executor", isolation:"worktree", model:"sonnet", maxTurns:60, prompt_file:$pf}]')
        _emit_manifest ship "$agents_json"
        t1=$(_now_ms)
        log_step_end "ship" "spawn" "$((t1-t0))" "task_id=\"$task_id\"" "attempt=$attempts"
        return 10 ;;
      *)
        log_warn "ci_status=$ci_status treated as timeout"
        pipeline-state task-status "$run_id" "$task_id" needs_human_review >/dev/null || true
        t1=$(_now_ms)
        log_step_end "ship" "needs_human_review" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"ci_timeout\""
        return 30 ;;
    esac
  fi

  local gate_lvl
  gate_lvl=$(read_config '.humanReviewLevel' '2')
  if (( gate_lvl >= 1 )); then
    if ! pipeline-human-gate "$run_id" pre-merge; then
      t1=$(_now_ms)
      log_step_end "ship" "human_gate_pause" "$((t1-t0))" "task_id=\"$task_id\""
      return 20
    fi
  fi

  local wt
  wt=$(_task_field worktree)
  wt=$(printf '%s' "$wt" | sed -e 's/^"//' -e 's/"$//')
  if [[ -z "$wt" ]]; then
    log_error "worktree missing at ship stage"
    t1=$(_now_ms)
    log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\""
    return 30
  fi

  if ! pipeline-branch task-commit "$task_id" --worktree "$wt" --run-id "$run_id" >/dev/null; then
    log_error "task-commit failed"
    t1=$(_now_ms)
    log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\""
    return 30
  fi

  _write_ship_checklist

  local pr_url pr_number pr_title
  pr_title=$(pipeline-branch task-pr-title "$task_id" --run-id "$run_id")
  pr_url=$(cd "$wt" && gh pr create --base staging --title "$pr_title" --body "Automated task PR for $task_id in run $run_id." 2>/dev/null || true)
  pr_number=$(printf '%s' "$pr_url" | grep -oE '[0-9]+$' || printf '')
  if [[ -z "$pr_number" ]]; then
    log_error "gh pr create returned no PR number"
    t1=$(_now_ms)
    log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\""
    return 30
  fi
  _task_write pr_number "$pr_number"
  _task_write pr_url    "\"$pr_url\""
  pipeline-state task-status "$run_id" "$task_id" reviewing >/dev/null || true
  log_metric "task.pr_created" "task_id=\"$task_id\"" "pr_number=$pr_number"

  if [[ "${FACTORY_ASYNC_CI:-auto}" == "off" ]]; then
    _ensure_prompt_dir
    if pipeline-wait-pr "$pr_number" > "$run_dir/.state/$run_id/$task_id.ci.json"; then
      emit_ci_metric task "$pr_number" green
      pipeline-state task-status "$run_id" "$task_id" done >/dev/null || true
      _task_write stage '"ship_done"'
      _task_write ci_status '"green"'
      t1=$(_now_ms)
      log_step_end "ship" "ok" "$((t1-t0))" "task_id=\"$task_id\"" "ci=\"green\""
      return 0
    fi
    emit_ci_metric task "$pr_number" red
    t1=$(_now_ms)
    log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"ci_red\""
    return 30
  fi

  t1=$(_now_ms)
  log_step_end "ship" "wait_ci" "$((t1-t0))" "task_id=\"$task_id\"" "pr_number=$pr_number"
  return 0
}

# --- finalize-run -----------------------------------------------------------
_stage_finalize_run() {
  local t0 t1
  t0=$(_now_ms)
  log_step_begin "finalize-run"

  local pending
  pending=$(jq -r '[.tasks[] | select(.status != "done" and .status != "failed" and .status != "needs_human_review")] | length' "$state_file")
  if (( pending > 0 )); then
    log_warn "finalize-run: $pending task(s) still non-terminal"
    t1=$(_now_ms)
    log_step_end "finalize-run" "wait_retry" "$((t1-t0))" "pending=$pending"
    return 3
  fi

  # Verify every task PR is actually merged into origin/staging before proceeding.
  # Tasks reach status=done on CI-green (async path) but auto-merge may still be
  # in-flight. This guard prevents the final PR opening against a stale staging.
  git fetch origin staging --quiet 2>/dev/null || true
  local staging_sha_missing=false
  while IFS= read -r pr_num; do
    [[ -z "$pr_num" || "$pr_num" == "null" ]] && continue
    local pr_data merge_sha
    pr_data=$(gh pr view "$pr_num" --json state,mergeCommit,headRefOid 2>/dev/null || printf '{}')
    local pr_state
    pr_state=$(printf '%s' "$pr_data" | jq -r '.state // "OPEN"')
    if [[ "$pr_state" != "MERGED" ]]; then
      log_warn "finalize-run: task PR #$pr_num not yet merged (state=$pr_state)"
      staging_sha_missing=true
      continue
    fi
    merge_sha=$(printf '%s' "$pr_data" | jq -r '.mergeCommit.oid // .headRefOid // ""')
    if [[ -n "$merge_sha" ]] && ! git merge-base --is-ancestor "$merge_sha" origin/staging 2>/dev/null; then
      log_warn "finalize-run: task PR #$pr_num merge SHA $merge_sha not yet visible on origin/staging"
      staging_sha_missing=true
    fi
  done < <(jq -r '.tasks[].pr_number // empty' "$state_file" 2>/dev/null)

  if [[ "$staging_sha_missing" == "true" ]]; then
    t1=$(_now_ms)
    log_step_end "finalize-run" "wait_retry" "$((t1-t0))" "reason=\"staging_not_settled\""
    return 3
  fi

  local scribe_done
  scribe_done=$(pipeline-state read "$run_id" '.scribe.status // ""' 2>/dev/null || printf '')
  if [[ "$scribe_done" != "done" ]]; then
    _ensure_prompt_dir
    local pf="$run_dir/.state/$run_id/RUN.scribe-prompt.md"
    printf 'Update /docs based on git diff for run %s.\nEnd with STATUS:.\n' "$run_id" > "$pf"
    local agents_json
    agents_json=$(jq -cn --arg pf "$pf" \
      '[{subagent_type:"scribe", model:"sonnet", maxTurns:40, prompt_file:$pf}]')
    pipeline-state write "$run_id" '.scribe.status' '"spawned"' >/dev/null || true
    _emit_manifest finalize-run "$agents_json"
    t1=$(_now_ms)
    log_step_end "finalize-run" "spawn" "$((t1-t0))" "stage=\"scribe\""
    return 10
  fi

  local final_pr_url
  final_pr_url=$(pipeline-state read "$run_id" '.final_pr.pr_url // ""' 2>/dev/null || printf '')
  if [[ -z "$final_pr_url" ]]; then
    final_pr_url=$(gh pr create --base develop --head staging \
      --title "Final: $run_id" \
      --body "Final PR merging staging into develop for run $run_id." \
      2>/dev/null || true)
    if [[ -n "$final_pr_url" ]]; then
      pipeline-state write "$run_id" '.final_pr.pr_url' "\"$final_pr_url\"" >/dev/null || true
      local final_pr_num
      final_pr_num=$(printf '%s' "$final_pr_url" | grep -oE '[0-9]+$' || printf '')
      [[ -n "$final_pr_num" ]] && pipeline-state write "$run_id" '.final_pr.pr_number' "$final_pr_num" >/dev/null || true
      log_metric "run.final_pr_created" "url=\"$final_pr_url\""
    else
      log_warn "final PR create failed"
    fi
  fi

  pipeline-cleanup "$run_id" --delete-branches --remove-worktrees --close-issues \
    >/dev/null 2>&1 || log_warn "cleanup failed"
  pipeline-state write "$run_id" '.status' '"done"' >/dev/null || true
  pipeline-state write "$run_id" '.ended_at' "\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"" >/dev/null || true

  t1=$(_now_ms)
  log_step_end "finalize-run" "ok" "$((t1-t0))"
  return 0
}

case "$stage" in
  preflight)      _stage_preflight ;;
  preexec_tests)  _stage_preexec_tests ;;
  postexec)       _stage_postexec ;;
  postreview)     _stage_postreview ;;
  ship)           _stage_ship ;;
  finalize-run)   _stage_finalize_run ;;
  *) log_error "unknown stage: $stage"; exit 1 ;;
esac
