#!/usr/bin/env bash
# Stage-machine wrapper that drives a single task (or the run-level
# finalize step) through the pipeline protocol. Every validation,
# classification, state-write, quota-gate, quality-gate, coverage-gate,
# holdout, review dispatch, PR-open, CI-wait, and cleanup step lives
# inside this wrapper - the orchestrator LLM never names them.
#
# Usage:
#   pipeline-run-task <run-id> <task-id> --stage <stage> [--worktree <path>]
#                     [--review-file <path>]... [--ci-status <green|red|timeout>]
#   pipeline-run-task <run-id> RUN       --stage finalize-run
#   pipeline-run-task <run-id> <task-id> --stage emit-ship-checklist
#     (diagnostic: rewrites .tasks/<task-id>.ship_checklist.json from state;
#      read-only against state.json; used by run-wrapper tests)
#
# Exit codes (common across stages):
#    0   stage complete -> advance to next
#    2   end_gracefully (quota cap, circuit breaker, retries exhausted)
#    3   wait_retry (quota chunk slept, still over) - re-invoke same stage
#   10   spawn_required; stdout is a JSON spawn manifest
#   20   human_gate_pause - orchestrator halts, /factory:run resume restarts
#   30   task_terminal_failed / needs_human_review - skip task, continue loop
#
# Spawn manifest shape (exit 10):
#   { "action":"spawn_agents",
#     "stage_after":"<next-stage>",
#     "agents":[ { "subagent_type":"...",
#                  "isolation":"worktree",
#                  "model":"...",
#                  "maxTurns":N,
#                  "prompt_file":".state/<run-id>/<task-id>.<role>-prompt.md" } ] }

source "$(dirname "$0")/pipeline-lib.sh"
source "$(dirname "$0")/pipeline-run-task-stages.sh"
require_command jq

# Script-relative resolution for sibling bin scripts. Bare names rely on PATH,
# which can be shadowed by stale binaries in user PATH dirs (see issue: a
# legacy /Users/.../dark-factory/pipeline-codex-review on PATH silently
# swallowed reviews). FACTORY_CODEX_REVIEW_BIN is a test-only override —
# production must leave it unset.
_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Resolve pipeline-state via _SCRIPT_DIR so a shadowing binary earlier in PATH
# cannot intercept state reads/writes (e.g. a stale copy in ~/bin or a legacy
# plugin path). Other sibling calls remain PATH-resolved so test stubs work.
_STATE_BIN="$_SCRIPT_DIR/pipeline-state"
_CODEX_REVIEW_BIN="${FACTORY_CODEX_REVIEW_BIN:-$_SCRIPT_DIR/pipeline-codex-review}"

# Config-driven model and turn limits — overridable via package.json.factory.
# Defaults match the historically hardcoded values.
_reviewer_model="$(read_config '.review.model' 'sonnet')"
_reviewer_max_turns_quick="$(read_config '.review.maxTurnsQuick' '25')"
_reviewer_max_turns_deep="$(read_config '.review.maxTurnsDeep' '30')"
_test_writer_max_turns="$(read_config '.testWriter.maxTurns' '40')"
_scribe_max_turns="$(read_config '.scribe.maxTurns' '60')"

run_id="${1:?missing run-id}"
task_id="${2:?missing task-id}"
shift 2
_validate_id "$run_id" "run-id" || exit 1
_validate_id "$task_id" "task-id" || exit 1

stage=""
worktree=""
review_files=()
ci_status=""
merge_status=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --stage)        stage="$2"; shift 2 ;;
    --worktree)     worktree="$2"; shift 2 ;;
    --review-file)  review_files+=("$2"); shift 2 ;;
    --ci-status)    ci_status="$2"; shift 2 ;;
    --merge-status) merge_status="$2"; shift 2 ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

[[ -z "$stage" ]] && { log_error "--stage required"; exit 1; }

run_dir="${CLAUDE_PLUGIN_DATA}/runs/${run_id}"
state_file="$run_dir/state.json"
[[ -f "$state_file" ]] || { log_error "state file not found: $state_file"; exit 1; }

# Resume safety: finalize-on-stop removes runs/current; on resume the
# SubagentStop transcript hook silent-exits when it is missing, skipping state
# writes. Restore it at stage entry. ensure-current refuses to clobber a
# different active run, so this is safe even if another run holds the symlink.
# Don't abort the stage on failure, but DO surface it: a missing symlink means
# the SubagentStop hook will silently drop state writes — exactly the failure
# this guards against — so swallowing it silently would defeat the purpose.
"$_STATE_BIN" ensure-current "$run_id" >/dev/null 2>&1 \
  || log_warn "ensure-current failed for $run_id; SubagentStop state writes may be dropped"

_now_ms() {
  if command -v gdate &>/dev/null; then gdate +%s%3N; return; fi
  local v; v=$(date +%s%3N 2>/dev/null)
  if [[ -n "$v" && "$v" != *N ]]; then printf '%s' "$v"
  else printf '%s000' "$(date +%s)"
  fi
}

_task_field() {
  local v
  v=$("$_STATE_BIN" task-read "$run_id" "$task_id" "$1" 2>/dev/null || printf '')
  [[ "$v" == "null" ]] && printf '' || printf '%s' "$v"
}

_task_write() {
  "$_STATE_BIN" task-write "$run_id" "$task_id" "$1" "$2" >/dev/null
}

# Write task-status=failed and log a uniform error message. Used by every
# terminal `return 30` site in _stage_postexec and _stage_postreview so the
# orchestrator's finalize-run group-completion check can drain instead of
# blocking on tasks stuck in status=executing.
_fail_task() {
  local _reason="${1:-unspecified}"
  if ! "$_STATE_BIN" task-status "$run_id" "$task_id" failed >/dev/null; then
    log_error "task-status failed write failed for $task_id (reason=$_reason)"
  fi
}

# Idempotent resume: every stage records its terminal marker in
# .tasks.<id>.stage. If invoked after a successful stage run (crash,
# resume, manual repeat), short-circuit so we don't double-spawn.
_already_past() {
  local want="$1"
  local cur
  cur=$(_task_field stage 2>/dev/null || printf '')
  case "$cur" in null|"") return 1 ;; esac
  local order=("${PIPELINE_STAGE_ORDER[@]}")
  local cur_rank=-1 want_rank=-1 i status
  for i in "${!order[@]}"; do
    [[ "${order[$i]}" == "$cur"  ]] && cur_rank=$i
    [[ "${order[$i]}" == "$want" ]] && want_rank=$i
  done
  if (( cur_rank < 0 )); then
    # Unknown stage (legacy state file). Treat as "past terminal" only when
    # the task already reached a terminal status — otherwise re-run the stage.
    status=$("$_STATE_BIN" task-read "$run_id" "$task_id" status 2>/dev/null)
    status=$(_unquote_json_string "$status")
    case "$status" in failed|needs_human_review) return 0 ;; esac
    return 1
  fi
  (( want_rank >= 0 )) && (( cur_rank >= want_rank ))
}

_emit_manifest() {
  jq -cn --arg after "$1" --argjson agents "$2" \
    '{action:"spawn_agents", stage_after:$after, agents:$agents}'
}

# Persist the currently-spawning task identity so the SubagentStop hook can
# write task-scoped state (worktree, etc.) without reverse-engineering it
# from the transcript. Called immediately before each _emit_manifest that
# spawns a task-scoped subagent (test-writer / task-executor / reviewer).
# A single per-run file; later spawns overwrite earlier ones.
_record_active_task_for_stop_hook() {
  local _r="${1:?run-id}"
  local _t="${2:?task-id}"
  local _wt="${3:-}"
  local _dir="$CLAUDE_PLUGIN_DATA/runs/$_r"
  mkdir -p "$_dir"
  local _now
  _now=$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || printf 'unknown')
  jq -n \
    --arg r "$_r" --arg t "$_t" --arg wt "$_wt" --arg ts "$_now" \
    '{run_id:$r, task_id:$t, worktree:$wt, written_at:$ts}' \
    > "$_dir/.active-spawn.json.tmp" 2>/dev/null && \
  mv "$_dir/.active-spawn.json.tmp" "$_dir/.active-spawn.json" 2>/dev/null || \
    log_warn "could not write .active-spawn.json for $_r/$_t (subagent-stop hook may be unreliable)"
}

# Resolve the per-task risk tier from state (written in preflight). Falls back
# to "routine" when missing — keeps mid-task gates working even on resumes
# from runs that predate per-task tier persistence.
_task_tier() {
  local t
  t=$(_task_field risk_tier 2>/dev/null)
  t=$(_unquote_json_string "$t")
  [[ -z "$t" || "$t" == "null" ]] && t="routine"
  printf '%s' "$t"
}

# Run pipeline_quota_gate at a mid-task stage boundary and translate the rc
# into a stage-level return code matching the preflight convention. Emits
# log_step_end on non-proceed paths so the caller can `return` immediately.
# Usage: _run_stage_quota_gate <stage> <t0_ms>
# Caller consumes the function's return code: 0=proceed, 2/3/30 to propagate.
_run_stage_quota_gate() {
  local stage="$1" t0="$2"
  local tier_local; tier_local=$(_task_tier)
  pipeline_quota_gate "$run_id" "$tier_local" "task-${task_id}-${stage}" "$task_id"
  local qrc=$? t1
  case $qrc in
    0) return 0 ;;
    2) t1=$(_now_ms); log_step_end "$stage" "end_gracefully" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"quota\""; return 2 ;;
    3) t1=$(_now_ms); log_step_end "$stage" "wait_retry"     "$((t1-t0))" "task_id=\"$task_id\""; return 3 ;;
    *) t1=$(_now_ms); log_step_end "$stage" "failed"         "$((t1-t0))" "task_id=\"$task_id\""; return 30 ;;
  esac
}

_prompt_path() {
  printf '%s/.state/%s/%s.%s-prompt.md' "$run_dir" "$run_id" "$task_id" "$1"
}

_ensure_prompt_dir() {
  mkdir -p "$run_dir/.state/$run_id"
}

# --- ship -------------------------------------------------------------------
_stage_ship() {
  local t0 t1
  t0=$(_now_ms)
  log_step_begin "ship" "task_id=\"$task_id\""

  if _already_past ship_done; then
    t1=$(_now_ms)
    log_step_end "ship" "skipped" "$((t1-t0))" "task_id=\"$task_id\""
    return 0
  fi

  if [[ -n "$ci_status" ]]; then
    _task_write ci_status "\"$ci_status\""
    [[ -n "$merge_status" ]] && _task_write merge_status "\"$merge_status\""
    case "$ci_status" in
      green)
        if [[ "$merge_status" == "stalled" ]]; then
          if ! "$_STATE_BIN" task-status "$run_id" "$task_id" failed >/dev/null; then
            log_error "task-status failed write failed for $task_id"
            return 30
          fi
          _task_write failure_reason '"auto-merge stalled despite green CI; manual investigation required"'
          t1=$(_now_ms)
          log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"merge_stalled\""
          return 30
        fi
        if ! "$_STATE_BIN" task-status "$run_id" "$task_id" done >/dev/null; then
          log_error "task-status done write failed for $task_id"
          return 30
        fi
        _task_write stage '"ship_done"'
        t1=$(_now_ms)
        log_step_end "ship" "ok" "$((t1-t0))" "task_id=\"$task_id\"" "ci=\"green\""
        return 0 ;;
      red)
        local attempts
        attempts=$(_task_field ci_fix_attempts)
        [[ -z "$attempts" ]] && attempts=0
        attempts=$((attempts + 1))
        _task_write ci_fix_attempts "$attempts"
        if (( attempts > 2 )); then
          if ! "$_STATE_BIN" task-status "$run_id" "$task_id" failed >/dev/null; then
            log_error "task-status failed write failed for $task_id"
            return 30
          fi
          t1=$(_now_ms)
          log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"ci_exhausted\""
          return 30
        fi
        "$_STATE_BIN" task-status "$run_id" "$task_id" ci_fixing >/dev/null \
          || log_warn "task-status ci_fixing write failed for $task_id (non-fatal)"
        _ensure_prompt_dir
        local pf; pf=$(_prompt_path executor-ci-fix)
        printf '[task:%s]\n[role:task-executor]\nFix failing CI on PR for task %s.\nSTATUS: DONE|...\n' "$task_id" "$task_id" > "$pf"
        local _ci_classify _ci_model _ci_max_turns
        _ci_classify=$(_task_field classify)
        if [[ -n "$_ci_classify" && "$_ci_classify" != "null" ]]; then
          _ci_model=$(printf '%s' "$_ci_classify" | jq -r '.model // "sonnet"' 2>/dev/null || printf 'sonnet')
          _ci_max_turns=$(printf '%s' "$_ci_classify" | jq -r '.maxTurns // .max_turns // 60' 2>/dev/null || printf '60')
        else
          _ci_model="sonnet"
          _ci_max_turns="60"
        fi
        local agents_json
        agents_json=$(jq -cn --arg pf "$pf" --arg _model "$_ci_model" \
          --argjson _max_turns "$_ci_max_turns" \
          '[{subagent_type:"task-executor", model:$_model, maxTurns:$_max_turns, prompt_file:$pf}]')
        local _ship_wt
        _ship_wt=$(_task_field worktree)
        _ship_wt=$(_unquote_json_string "$_ship_wt")
        _record_active_task_for_stop_hook "$run_id" "$task_id" "$_ship_wt"
        _emit_manifest ship "$agents_json"
        t1=$(_now_ms)
        log_step_end "ship" "spawn" "$((t1-t0))" "task_id=\"$task_id\"" "attempt=$attempts"
        return 10 ;;
      *)
        log_warn "ci_status=$ci_status treated as timeout"
        if ! "$_STATE_BIN" task-status "$run_id" "$task_id" needs_human_review >/dev/null; then
          log_error "task-status needs_human_review write failed for $task_id"
          return 30
        fi
        t1=$(_now_ms)
        log_step_end "ship" "needs_human_review" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"ci_timeout\""
        return 30 ;;
    esac
  fi

  _run_stage_quota_gate ship "$t0"
  local _qrc=$?
  (( _qrc != 0 )) && return $_qrc

  local gate_lvl
  gate_lvl=$(read_config '.humanReviewLevel' '0')
  if (( gate_lvl >= 1 )); then
    # A4: distinguish rc=42 (legitimate pause) from rc=1 (misuse/state-write
    # failure). Previously `if ! pipeline-human-gate ...` collapsed both into
    # return 20 (pause), hiding broken invocations from operators.
    # See docs/reference/exit-codes.md#pipeline-human-gate.
    # Note: lib sets `set -e`, so we use `|| rc=$?` to capture non-zero
    # exits without aborting the function.
    local _hg_rc=0
    pipeline-human-gate "$run_id" pre-merge || _hg_rc=$?
    case "$_hg_rc" in
      0)
        : # gate passed, fall through to PR-create path
        ;;
      42)
        t1=$(_now_ms)
        log_step_end "ship" "human_gate_pause" "$((t1-t0))" "task_id=\"$task_id\""
        return 20
        ;;
      *)
        log_error "pipeline-human-gate failed unexpectedly: rc=$_hg_rc"
        t1=$(_now_ms)
        log_step_end "ship" "failed" "$((t1-t0))" \
          "task_id=\"$task_id\"" \
          "reason=\"human_gate_error\"" \
          "rc=$_hg_rc"
        return 30
        ;;
    esac
  fi

  local wt
  wt=$(_task_field worktree)
  wt=$(_unquote_json_string "$wt")
  if [[ -z "$wt" ]]; then
    log_error "worktree missing at ship stage"
    t1=$(_now_ms)
    log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\""
    return 30
  fi

  if ! pipeline-branch task-commit "$task_id" --worktree "$wt" --run-id "$run_id" >/dev/null; then
    log_error "task-commit failed"
    t1=$(_now_ms)
    log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\""
    return 30
  fi

  local _ship_branch="task/${task_id}"

  if ! _run_ship_pregate "$wt"; then
    log_warn "ship-time pregate failed for $task_id"
    t1=$(_now_ms)
    log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"pregate\""
    return 30
  fi

  _write_ship_checklist

  if git -C "$wt" remote get-url origin >/dev/null 2>&1; then
    local _ship_push_err
    if ! _ship_push_err=$(git -C "$wt" push -u origin "$_ship_branch" 2>&1); then
      log_error "ship: git push origin $_ship_branch failed: ${_ship_push_err//$'\n'/ }"
      _task_write failure_reason "$(jq -Rs . <<<"ship push failed: ${_ship_push_err:0:300}")"
      t1=$(_now_ms); log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"ship_push\""
      return 30
    fi
  else
    log_warn "ship: no origin remote in $wt; skipping push (offline/test mode)"
  fi

  local pr_url pr_number pr_title _gh_err
  pr_title=$(pipeline-branch task-pr-title "$task_id" --run-id "$run_id")
  _gh_err=$(mktemp)
  pr_url=$(cd "$wt" && gh pr create --base staging --head "$_ship_branch" --title "$pr_title" \
    --body "Automated task PR for $task_id in run $run_id." 2>"$_gh_err") || pr_url=""
  if [[ -z "$pr_url" ]]; then
    local err_text; err_text=$(<"$_gh_err"); rm -f "$_gh_err"
    log_error "gh pr create failed for $task_id: ${err_text:-no stderr captured}"
    _task_write failure_reason "$(jq -Rs . <<<"gh pr create failed: ${err_text:0:500}")"
    t1=$(_now_ms); log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"gh_pr_create\""
    return 30
  fi
  rm -f "$_gh_err"
  pr_number=$(printf '%s' "$pr_url" | grep -oE '[0-9]+$' || printf '')
  if [[ -z "$pr_number" ]]; then
    log_error "gh pr create returned non-numeric URL: $pr_url"
    _task_write failure_reason "$(jq -Rs . <<<"gh pr create returned non-numeric URL: $pr_url")"
    t1=$(_now_ms); log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"gh_pr_url_malformed\""
    return 30
  fi
  _task_write pr_number "$pr_number"
  _task_write pr_url    "\"$pr_url\""
  "$_STATE_BIN" task-status "$run_id" "$task_id" reviewing >/dev/null \
    || log_warn "task-status reviewing write failed for $task_id (non-fatal)"
  log_metric "task.pr_created" "task_id=\"$task_id\"" "pr_number=$pr_number"

  if [[ "${FACTORY_ASYNC_CI:-auto}" == "off" ]]; then
    _ensure_prompt_dir
    local _wait_rc=0
    pipeline-wait-pr "$pr_number" > "$run_dir/.state/$run_id/$task_id.ci.json" || _wait_rc=$?
    case "$_wait_rc" in
      0)
        emit_ci_metric task "$pr_number" green
        if ! "$_STATE_BIN" task-status "$run_id" "$task_id" done >/dev/null; then
          log_error "task-status done write failed for $task_id"
          return 30
        fi
        _task_write stage '"ship_done"'
        _task_write ci_status '"green"'
        t1=$(_now_ms)
        log_step_end "ship" "ok" "$((t1-t0))" "task_id=\"$task_id\"" "ci=\"green\""
        return 0
        ;;
      1)
        emit_ci_metric task "$pr_number" timeout
        _task_write ci_status '"timeout"'
        _task_write failure_reason '"ci_timeout"'
        t1=$(_now_ms)
        log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"ci_timeout\""
        return 30
        ;;
      2)
        emit_ci_metric task "$pr_number" closed
        _task_write ci_status '"closed"'
        _task_write failure_reason '"pr_closed"'
        "$_STATE_BIN" task-status "$run_id" "$task_id" failed >/dev/null \
          || log_warn "task-status failed write failed for $task_id"
        t1=$(_now_ms)
        log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"pr_closed\""
        return 30
        ;;
      3)
        emit_ci_metric task "$pr_number" red
        _task_write ci_status '"red"'
        _task_write failure_reason '"ci_red"'
        t1=$(_now_ms)
        log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"ci_red\""
        return 30
        ;;
      4)
        emit_ci_metric task "$pr_number" conflict
        _task_write ci_status '"conflict"'
        _task_write failure_reason '"merge_conflict"'
        t1=$(_now_ms)
        log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"merge_conflict\""
        return 30
        ;;
      *)
        emit_ci_metric task "$pr_number" red
        _task_write ci_status '"red"'
        _task_write failure_reason "\"wait_pr_unexpected_rc_${_wait_rc}\""
        t1=$(_now_ms)
        log_step_end "ship" "failed" "$((t1-t0))" "task_id=\"$task_id\"" "reason=\"wait_pr_unexpected_rc_${_wait_rc}\""
        return 30
        ;;
    esac
  fi

  t1=$(_now_ms)
  log_step_end "ship" "wait_ci" "$((t1-t0))" "task_id=\"$task_id\"" "pr_number=$pr_number"
  return 0
}

# --- finalize-run -----------------------------------------------------------
_stage_finalize_run() {
  local t0 t1
  t0=$(_now_ms)
  log_step_begin "finalize-run"

  pipeline_quota_gate "$run_id" feature run-finalize ""
  local _qrc=$?
  case $_qrc in
    0) : ;;
    2) t1=$(_now_ms); log_step_end "finalize-run" "end_gracefully" "$((t1-t0))" "reason=\"quota\""; return 2 ;;
    3) t1=$(_now_ms); log_step_end "finalize-run" "wait_retry"     "$((t1-t0))"; return 3 ;;
    *) t1=$(_now_ms); log_step_end "finalize-run" "failed"         "$((t1-t0))"; return 30 ;;
  esac

  # Partial-rollup escape hatch. Default: every task must be status=done.
  # FACTORY_ALLOW_PARTIAL_ROLLUP=1 permits failed/needs_human_review tasks
  # (their PRs are still verified individually below if pr_number is set).
  local allow_partial="${FACTORY_ALLOW_PARTIAL_ROLLUP:-0}"
  local non_done_filter
  if [[ "$allow_partial" == "1" ]]; then
    non_done_filter='.value.status != "done" and .value.status != "failed" and .value.status != "needs_human_review"'
  else
    non_done_filter='.value.status != "done"'
  fi

  local _jq_err; _jq_err=$(mktemp)
  local non_done_detail non_done
  non_done_detail=$(jq -r --argjson empty 0 \
    "[.tasks | to_entries[] | select($non_done_filter) | \"\(.key)=\(.value.status // \"null\")\"] | join(\",\")" \
    "$state_file" 2>/dev/null || printf '')
  non_done=$(jq -r "[.tasks | to_entries[] | select($non_done_filter)] | length" "$state_file" 2>"$_jq_err") || {
    log_error "finalize-run: state.json parse failed: $(cat "$_jq_err")"
    rm -f "$_jq_err"
    return 30
  }
  rm -f "$_jq_err"
  if (( non_done > 0 )); then
    log_warn "finalize-run: $non_done task(s) not done: $non_done_detail (allow_partial=$allow_partial)"
    t1=$(_now_ms)
    log_step_end "finalize-run" "wait_retry" "$((t1-t0))" "non_done=$non_done" "allow_partial=$allow_partial"
    return 3
  fi

  # Stage consistency: every status=done task must also have stage=ship_done.
  # Catches state drift from rescue-apply or legacy runs where status was
  # mutated without the stage transition.
  local bad_stage_detail bad_stage
  bad_stage_detail=$(jq -r '[.tasks | to_entries[] | select(.value.status == "done" and .value.stage != "ship_done") | "\(.key)=\(.value.stage // "null")"] | join(",")' "$state_file" 2>/dev/null || printf '')
  local _jq_err2; _jq_err2=$(mktemp)
  bad_stage=$(jq -r '[.tasks | to_entries[] | select(.value.status == "done" and .value.stage != "ship_done")] | length' "$state_file" 2>"$_jq_err2") || {
    log_error "finalize-run: state.json parse failed: $(cat "$_jq_err2")"
    rm -f "$_jq_err2"
    return 30
  }
  rm -f "$_jq_err2"
  if (( bad_stage > 0 )); then
    log_error "finalize-run: $bad_stage done task(s) with stage!=ship_done: $bad_stage_detail"
    t1=$(_now_ms)
    log_step_end "finalize-run" "wait_retry" "$((t1-t0))" "reason=\"stage_inconsistent\""
    return 3
  fi

  # Fetch origin/staging fail-closed: a stale ref could let the SHA-ancestor
  # check pass against an outdated tip.
  local _ferr; _ferr=$(mktemp)
  if ! git fetch origin staging --quiet 2>"$_ferr"; then
    log_error "finalize-run: git fetch origin staging failed: $(cat "$_ferr")"
    rm -f "$_ferr"
    t1=$(_now_ms)
    log_step_end "finalize-run" "wait_retry" "$((t1-t0))" "reason=\"git_fetch_failed\""
    return 3
  fi
  rm -f "$_ferr"

  # Verify every status=done task PR is merged into origin/staging.
  # Iterate task entries (id+pr_number) so a done task without a pr_number is
  # caught instead of silently skipped.
  local staging_sha_missing=false
  while IFS=$'\t' read -r tid pr_num; do
    [[ -z "$tid" ]] && continue
    if [[ -z "$pr_num" || "$pr_num" == "null" ]]; then
      log_error "finalize-run: task $tid status=done but pr_number missing"
      staging_sha_missing=true
      continue
    fi
    local pr_data merge_sha pr_state
    local _vrc=0 _verr; _verr=$(mktemp)
    pr_data=$(gh pr view "$pr_num" --json state,mergeCommit,headRefOid 2>"$_verr") || _vrc=$?
    if (( _vrc != 0 )); then
      log_error "finalize-run: gh pr view #$pr_num failed (rc=$_vrc): $(cat "$_verr")"
      rm -f "$_verr"
      staging_sha_missing=true; continue
    fi
    rm -f "$_verr"
    if ! printf '%s' "$pr_data" | jq -e '.state' >/dev/null 2>&1; then
      log_error "finalize-run: gh pr view #$pr_num returned malformed JSON"
      staging_sha_missing=true; continue
    fi
    pr_state=$(printf '%s' "$pr_data" | jq -r '.state // "OPEN"')
    if [[ "$pr_state" != "MERGED" ]]; then
      log_warn "finalize-run: task $tid PR #$pr_num not yet merged (state=$pr_state)"
      staging_sha_missing=true
      continue
    fi
    merge_sha=$(printf '%s' "$pr_data" | jq -r '.mergeCommit.oid // .headRefOid // ""')
    if [[ -n "$merge_sha" ]] && ! git merge-base --is-ancestor "$merge_sha" origin/staging 2>/dev/null; then
      log_warn "finalize-run: task $tid PR #$pr_num merge SHA $merge_sha not yet visible on origin/staging"
      staging_sha_missing=true
    fi
  done < <(jq -r '.tasks | to_entries[] | select(.value.status == "done") | [.key, (.value.pr_number // "")] | @tsv' "$state_file" 2>/dev/null)

  if [[ "$staging_sha_missing" == "true" ]]; then
    t1=$(_now_ms)
    log_step_end "finalize-run" "wait_retry" "$((t1-t0))" "reason=\"staging_not_settled\""
    return 3
  fi

  local scribe_state
  scribe_state=$("$_STATE_BIN" read "$run_id" '.scribe.status // "pending"' 2>/dev/null)
  scribe_state=$(_unquote_json_string "$scribe_state")

  if [[ "$scribe_state" == "spawned" ]]; then
    # Spawned previously; SubagentStop hook should advance to done|failed.
    # If we still see "spawned" on re-entry, the hook failed — cap re-spawns.
    local scribe_attempts
    scribe_attempts=$("$_STATE_BIN" read "$run_id" '.scribe.attempts // 0' 2>/dev/null)
    if (( scribe_attempts >= 2 )); then
      log_error "finalize-run: scribe re-spawn cap hit (attempts=$scribe_attempts)"
      "$_STATE_BIN" write "$run_id" '.scribe.status' '"failed"' >/dev/null
      "$_STATE_BIN" write "$run_id" '.scribe.failure_reason' '"hook_did_not_terminate"' >/dev/null
      t1=$(_now_ms); log_step_end "finalize-run" "failed" "$((t1-t0))" "reason=\"scribe_loop\""
      return 30
    fi
    "$_STATE_BIN" write "$run_id" '.scribe.attempts' "$((scribe_attempts + 1))" >/dev/null
    scribe_state="pending"
  fi

  if [[ "$scribe_state" != "done" ]]; then
    _ensure_prompt_dir
    local pf="$run_dir/.state/$run_id/RUN.scribe-prompt.md"
    printf 'Update /docs based on git diff for run %s.\nEnd with STATUS:.\n' "$run_id" > "$pf"
    local agents_json
    agents_json=$(jq -cn --arg pf "$pf" --arg _model "$_reviewer_model" \
      --argjson _max_turns "$_scribe_max_turns" \
      '[{subagent_type:"scribe", isolation:"worktree", model:$_model, maxTurns:$_max_turns, prompt_file:$pf}]')
    # Write sentinel so pretooluse-pipeline-guards.sh can activate the scribe path-scope
    # guard. The hook cannot read FACTORY_SUBAGENT_ROLE (never exported at spawn time).
    # The guard depends on this sentinel — surface write failures instead of
    # silently swallowing them.
    if ! printf '%s' "$run_id" > "$run_dir/.scribe_active" 2>/dev/null; then
      log_warn "scribe sentinel write failed at $run_dir/.scribe_active (guard may not activate)"
    fi
    "$_STATE_BIN" write "$run_id" '.scribe.status' '"spawned"' >/dev/null \
      || log_warn "scribe.status spawned write failed (non-fatal; cap counter may not tick)"
    _emit_manifest finalize-run "$agents_json"
    t1=$(_now_ms)
    log_step_end "finalize-run" "spawn" "$((t1-t0))" "stage=\"scribe\""
    return 10
  fi

  local final_pr_url final_pr_num
  final_pr_url=$("$_STATE_BIN" read "$run_id" '.final_pr.pr_url // ""' 2>/dev/null || printf '')

  if [[ -z "$final_pr_url" ]]; then
    local _existing _err
    _err=$(mktemp)
    _existing=$(gh pr list --base develop --head staging --state open --json url,number 2>"$_err") || {
      log_error "finalize-run: gh pr list failed: $(cat "$_err")"
      rm -f "$_err"
      t1=$(_now_ms); log_step_end "finalize-run" "wait_retry" "$((t1-t0))" "reason=\"gh_pr_list_failed\""
      return 3
    }
    rm -f "$_err"
    final_pr_url=$(printf '%s' "$_existing" | jq -r '.[0].url // ""')

    if [[ -z "$final_pr_url" ]]; then
      _err=$(mktemp)
      final_pr_url=$(gh pr create --base develop --head staging \
        --title "Final: $run_id" \
        --body "Final PR merging staging into develop for run $run_id." 2>"$_err") || final_pr_url=""
      if [[ -z "$final_pr_url" ]]; then
        log_error "finalize-run: gh pr create failed: $(cat "$_err")"
        rm -f "$_err"
        t1=$(_now_ms); log_step_end "finalize-run" "wait_retry" "$((t1-t0))" "reason=\"final_pr_create_failed\""
        return 3
      fi
      rm -f "$_err"
    fi

    "$_STATE_BIN" write "$run_id" '.final_pr.pr_url' "\"$final_pr_url\"" >/dev/null \
      || { log_error "finalize-run: state write final_pr.pr_url failed"; return 3; }
    final_pr_num=$(printf '%s' "$final_pr_url" | grep -oE '[0-9]+$' || printf '')
    [[ -n "$final_pr_num" ]] && "$_STATE_BIN" write "$run_id" '.final_pr.pr_number' "$final_pr_num" >/dev/null
    log_metric "run.final_pr_created" "url=\"$final_pr_url\""
  fi

  # Write terminal status BEFORE cleanup so the state pipeline-cleanup archives
  # already reflects the completed run. pipeline-cleanup copies state.json to
  # archive/ then rm -rf's runs/$run_id, so any write after cleanup would land
  # in a deleted directory and the archived copy would be missing status=done.
  if ! "$_STATE_BIN" write "$run_id" '.status' '"done"' >/dev/null; then
    log_error "finalize-run: failed to write final status=done"
    return 3
  fi
  "$_STATE_BIN" write "$run_id" '.ended_at' "\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"" >/dev/null \
    || log_warn "finalize-run: failed to write ended_at (non-fatal)"

  local _cl_err; _cl_err=$(mktemp)
  if ! pipeline-cleanup "$run_id" --delete-branches --remove-worktrees --close-issues >"$_cl_err" 2>&1; then
    log_error "finalize-run: cleanup failed: $(cat "$_cl_err")"
    rm -f "$_cl_err"
    t1=$(_now_ms); log_step_end "finalize-run" "wait_retry" "$((t1-t0))" "reason=\"cleanup_failed\""
    return 3
  fi
  rm -f "$_cl_err"

  t1=$(_now_ms)
  log_step_end "finalize-run" "ok" "$((t1-t0))"
  return 0
}

case "$stage" in
  preflight)      _stage_preflight ;;
  preexec_tests)  _stage_preexec_tests ;;
  postexec)       _stage_postexec ;;
  postreview)     _stage_postreview ;;
  ship)           _stage_ship ;;
  finalize-run)   _stage_finalize_run ;;
  # Diagnostic entry point: write the ship-checklist JSON from current task
  # state without running the rest of the ship stage. Used by tests that
  # exercise _write_ship_checklist in isolation; safe in production because
  # the function is read-only against state and writes to .tasks/<id>.ship_checklist.json
  # which the orchestrator only consults at the postreview-done boundary.
  emit-ship-checklist) _write_ship_checklist ;;
  *) log_error "unknown stage: $stage"; exit 1 ;;
esac
