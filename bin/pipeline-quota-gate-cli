#!/usr/bin/env bash
# Thin CLI wrapper around pipeline_quota_gate (pipeline-lib.sh) so callers
# that aren't sourcing the lib (orchestrator skill, debug skill, ad-hoc shell)
# can invoke the canonical gate as a script.
#
# Usage:
#   pipeline-quota-gate-cli --run-id <id> --tier <routine|feature|security>
#                           --boundary <label> [--task-id <id>]
#
# Exit codes mirror pipeline_quota_gate exactly:
#   0 = proceed
#   2 = end_gracefully (halt)
#   3 = wait_retry (re-invoke same gate after another agent turn)
#
# Stdout: a single JSON line with the outcome shape (callers that prefer
# parsing JSON over reading exit codes can do so).

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

run_id=""
tier="routine"
boundary=""
task_id=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --run-id)   run_id="$2";   shift 2 ;;
    --tier)     tier="$2";     shift 2 ;;
    --boundary) boundary="$2"; shift 2 ;;
    --task-id)  task_id="$2";  shift 2 ;;
    -h|--help)
      sed -n '2,16p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

if [[ -z "$run_id" || -z "$boundary" ]]; then
  log_error "--run-id and --boundary are required"
  exit 1
fi

set +e
pipeline_quota_gate "$run_id" "$tier" "$boundary" "$task_id"
rc=$?
set -e

case $rc in
  0) action="proceed" ;;
  2) action="end_gracefully" ;;
  3) action="wait_retry" ;;
  *) action="error" ;;
esac

jq -cn \
  --arg action "$action" \
  --argjson rc "$rc" \
  --arg run_id "$run_id" \
  --arg tier "$tier" \
  --arg boundary "$boundary" \
  --arg task_id "$task_id" \
  '{action:$action, rc:$rc, run_id:$run_id, tier:$tier, boundary:$boundary, task_id:$task_id}'

exit $rc
