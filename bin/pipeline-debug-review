#!/usr/bin/env bash
# pipeline-debug-review — Codex reviewer path for /factory:debug.
#
# This script handles ONLY the Codex branch. The skill (skills/debug/SKILL.md)
# pre-checks `pipeline-detect-reviewer` and routes the Claude-fallback branch
# through the `quality-reviewer` agent + `pipeline-parse-review` instead.
# Both branches converge on `pipeline-debug-normalize` for severity mapping
# and threshold counting.
#
# Usage:
#   pipeline-debug-review --base <ref> --severity <critical|high|medium|all>
#                         --out-dir <dir> [--round <N>]
# Output (stdout, single line JSON):
#   {"blocking_count":N,"below_threshold_count":M,"verdict":"...","review_file":"<path>"}
# Exit: 0 on success, 1 on reviewer/IO failure.

set -euo pipefail
source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

base_ref=""
severity="medium"
out_dir=""
round=1

while [[ $# -gt 0 ]]; do
  case "$1" in
    --base)     base_ref="$2"; shift 2 ;;
    --severity) severity="$2"; shift 2 ;;
    --out-dir)  out_dir="$2";  shift 2 ;;
    --round)    round="$2";    shift 2 ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

[[ -z "$base_ref" ]] && { log_error "--base required"; exit 1; }
[[ -z "$out_dir"  ]] && { log_error "--out-dir required"; exit 1; }
case "$severity" in critical|high|medium|all) : ;; *) log_error "invalid --severity: $severity"; exit 1 ;; esac

# Defense-in-depth: skill should have already routed non-Codex reviewers
# through the quality-reviewer agent. If we land here without Codex, the
# skill has a routing bug — fail loudly.
detect_json=$(pipeline-detect-reviewer 2>/dev/null || printf '{}')
reviewer=$(printf '%s' "$detect_json" | jq -r '.reviewer // "unknown"')
if [[ "$reviewer" != "codex" ]]; then
  log_error "pipeline-debug-review is the Codex branch; reviewer=\"$reviewer\". Skill must route claude-code through pipeline-parse-review + pipeline-debug-normalize."
  exit 1
fi

raw_review=$(pipeline-codex-review --base "$base_ref" --task-id "debug-r${round}") \
  || { log_error "pipeline-codex-review failed"; exit 1; }

printf '%s' "$raw_review" \
  | pipeline-debug-normalize --severity "$severity" --out-dir "$out_dir" --round "$round"
