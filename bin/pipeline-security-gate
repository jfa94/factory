#!/usr/bin/env bash
# Run a configured security-analysis command and write structured results to state.
# Usage: pipeline-security-gate <run-id> <task-id> [<worktree>]
#
# Reads `.quality.securityCommand` from factory config. If unset the gate is
# skipped (exit 2). The command is validated against a token allowlist and a
# runner-prefix allowlist before execution (same discipline as redTestCommand).
#
# Stdout from the command is treated as the findings artifact and written to
# `$CLAUDE_PLUGIN_DATA/runs/<run-id>/<task-id>.security-findings.json`. The
# structured gate result is written to state under `.tasks.<id>.security_gate`.
#
# Security note (M14): the findings artifact is the raw stdout of the
# configured security command (typically `semgrep --json …`). Many semgrep
# rules embed offending source snippets, so raw stdout can contain
# secret-bearing material (API keys, tokens) lifted from the audited codebase.
#
# To keep secrets out of state at rest, the captured stdout is passed through
# `redact_secrets` (bin/_secret-patterns.sh — the same pattern set as
# hooks/secret-commit-guard.sh) in place — after the scan, before anything reads
# the file — replacing each match with `[REDACTED]`. This is on by default; set
# `quality.securityRedactFindings=false` to keep full fidelity for local
# debugging.
#
# Residual risk (opt-out path only): when securityRedactFindings=false the
# artifact may contain secrets. `$CLAUDE_PLUGIN_DATA` is operator-private state,
# so when redaction is disabled:
#   - do NOT publish findings files to PRs, gists, telemetry, or remote review
#     tools without re-running them through `redact_secrets`;
#   - retention sweeps in `pipeline-cleanup` treat these files as sensitive
#     (they inherit the runs/<run-id> lifetime).
#
# Scope: only the findings artifact (scanner stdout) is redacted. The companion
# `<task-id>.security-gate.log` (scanner stderr) is NOT redacted, regardless of
# the flag — a verbose/error-mode scanner that echoes offending snippets to
# stderr could leave secrets there. Treat that log as sensitive too (it shares
# the runs/<run-id> lifetime).
#
# Exit codes:
#   0  — gate passed (no findings or allowFailures=true)
#   1  — gate failed (findings present)
#   2  — gate skipped (no securityCommand configured)

source "$(dirname "$0")/pipeline-lib.sh"
# shellcheck source=_secret-patterns.sh
source "$(dirname "$0")/_secret-patterns.sh"
require_plugin_data
require_command jq

run_id="${1:?missing run-id}"
task_id="${2:?missing task-id}"
worktree="${3:-$PWD}"

if [[ ! -d "$worktree" ]]; then
  log_error "worktree does not exist: $worktree"
  printf '{"ok":false,"error":"worktree_missing"}\n'
  exit 1
fi

# --- Config ---
security_cmd=$(read_config '.quality.securityCommand' '')
if [[ -z "$security_cmd" ]]; then
  log_info "no .quality.securityCommand configured — security gate skipped task_id=\"$task_id\""
  result='{"ok":true,"skipped":true,"reason":"no-security-command"}'
  record_gate_result "$run_id" "$task_id" security_gate "$result" || exit 1
  log_metric "task.gate.security" "task_id=\"$task_id\"" \
    "status=\"skipped\"" "reason=\"no-security-command\""
  printf '%s\n' "$result"
  exit 2
fi

allow_failures=$(read_config '.quality.securityAllowFailures' 'false' | tr '[:upper:]' '[:lower:]')
# Redact secret-bearing material from the findings artifact before persistence.
# On by default; set quality.securityRedactFindings=false to keep full fidelity.
# Note: read_config uses `// empty` which collapses JSON false to the default.
# Use jq directly so an explicit false is honoured, defaulting to true when the
# key is absent or the config file is missing.
# Redaction is skipped only when the flag is explicitly false; any other value
# (absent, malformed) redacts (fail-closed).
_cfg_file="${CLAUDE_PLUGIN_DATA}/config.json"
if [[ -f "$_cfg_file" ]]; then
  redact_findings=$(jq -r 'if has("quality") and (.quality | has("securityRedactFindings")) then .quality.securityRedactFindings | tostring else "true" end' "$_cfg_file" 2>/dev/null || printf 'true')
else
  redact_findings='true'
fi

# --- Validate command tokens ---
# Tokens are split on whitespace (IFS); paths with spaces are not supported —
# the token allowlist rejects spaces, so any path containing one will fail
# validation with reason "unsafe_command". This matches redTestCommand behavior.
cmd_array=()
read -ra cmd_array <<< "$security_cmd"

for _token in "${cmd_array[@]}"; do
  if [[ ! "$_token" =~ ^[A-Za-z0-9._/=:+-]+$ ]]; then
    log_error "security gate: .quality.securityCommand token '$_token' contains unsafe characters task_id=\"$task_id\""
    result='{"ok":false,"skipped":false,"reason":"unsafe_command"}'
    record_gate_result "$run_id" "$task_id" security_gate "$result" || exit 1
    printf '%s\n' "$result"
    exit 1
  fi
done

# Runner-prefix allowlist — prevents arbitrary script execution.
_bin="${cmd_array[0]##*/}"
_bin1="${cmd_array[1]:-}"
_bin2="${cmd_array[2]:-}"
_allowed=false
case "$_bin" in
  semgrep|pytest|vitest|jest|mocha|phpunit|rspec) _allowed=true ;;
  go|cargo|deno) [[ "$_bin1" == "test" ]] && _allowed=true ;;
  bundle)        [[ "$_bin1" == "exec" && "$_bin2" == "rspec" ]] && _allowed=true ;;
esac
if ! $_allowed; then
  log_error "security gate: .quality.securityCommand prefix not in allowlist task_id=\"$task_id\" cmd=\"${cmd_array[*]:0:3}\""
  result="{\"ok\":false,\"skipped\":false,\"reason\":\"unallowed_runner\",\"runner\":\"$_bin\"}"
  record_gate_result "$run_id" "$task_id" security_gate "$result" || exit 1
  printf '%s\n' "$result"
  exit 1
fi

# --- Run ---
run_dir="${CLAUDE_PLUGIN_DATA}/runs/${run_id}"
mkdir -p "$run_dir"

findings_file="$run_dir/${task_id}.security-findings.json"
log_file="$run_dir/${task_id}.security-gate.log"
# M14: stdout is redacted in place below via redact_secrets before persistence
# (unless quality.securityRedactFindings=false). See header.

start=$(date +%s)
set +e
( cd "$worktree" && "${cmd_array[@]}" ) > "$findings_file" 2> "$log_file"
rc=$?
set -e
duration=$(( $(date +%s) - start ))

# M14: redact secret-bearing material from the findings artifact before it is
# persisted or consumed. Scanner stdout can embed offending source lines (API
# keys, tokens) lifted from the audited codebase. Fail closed: if the redaction
# pass errors, replace the artifact with an error envelope rather than leaving
# raw output on disk.
if [[ "$redact_findings" != "false" ]]; then
  if redact_secrets < "$findings_file" > "$findings_file.tmp" 2>/dev/null; then
    mv "$findings_file.tmp" "$findings_file"
  else
    rm -f "$findings_file.tmp"
    log_warn "security gate: redaction pass failed — replacing findings with error envelope (fail-closed) task_id=\"$task_id\""
    jq -n --argjson rc "$rc" '{"error":"redaction_failed","exit_code":$rc}' > "$findings_file"
  fi
fi

# If stdout wasn't JSON, wrap it so downstream consumers always get a JSON file.
if ! jq -e '.' "$findings_file" >/dev/null 2>&1; then
  raw_output=$(cat "$findings_file" 2>/dev/null || printf '')
  jq -n --arg out "$raw_output" --argjson rc "$rc" \
    '{"raw_output":$out,"exit_code":$rc}' > "$findings_file"
fi

if [[ $rc -eq 0 ]]; then
  gate_ok=true
  status="passed"
else
  gate_ok=false
  status="failed"
fi

_allow_json=false
[[ "$allow_failures" == "true" ]] && _allow_json=true
summary=$(jq -n \
  --argjson ok "$gate_ok" \
  --arg status "$status" \
  --arg cmd "$security_cmd" \
  --argjson duration "$duration" \
  --arg findings "$findings_file" \
  --arg log "$log_file" \
  --argjson allow "$_allow_json" \
  '{ok:$ok, status:$status, command:$cmd, duration_s:$duration, findings_file:$findings, log:$log, allow_failures:$allow}')

record_gate_result "$run_id" "$task_id" security_gate "$summary" || exit 1

printf '%s\n' "$summary"

log_metric "task.gate.security" "task_id=\"$task_id\"" \
  "status=\"$status\"" "duration_s=\"$duration\""

if [[ "$gate_ok" == "true" ]]; then
  exit 0
elif [[ "$allow_failures" == "true" ]]; then
  log_warn "security gate failed but securityAllowFailures=true — not blocking task_id=\"$task_id\""
  exit 0
else
  exit 1
fi
