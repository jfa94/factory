#!/usr/bin/env bash
# pipeline-tdd-gate — validate that each impl commit is preceded by a test-only
# commit with the same [task-id] tag. Writes structured JSON to stdout and
# (if state is available) to .tasks.<task-id>.quality_gates.tdd.
#
# Usage: pipeline-tdd-gate --task-id <id> [--base <ref>] [--run-id <id>] [--spec-dir <path>]
# Exit: 0 if ok or exempt; 1 on violation.
set -euo pipefail

# shellcheck source=/dev/null
source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

base_ref="staging"
base_explicit=false
task_id=""
run_id=""
spec_dir=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --base)     base_ref="$2"; base_explicit=true; shift 2 ;;
    --task-id)  task_id="$2";  shift 2 ;;
    --run-id)   run_id="$2";   shift 2 ;;
    --spec-dir) spec_dir="$2"; shift 2 ;;
    *) echo "unknown flag: $1" >&2; exit 1 ;;
  esac
done
[[ -z "$task_id" ]] && { printf '{"ok":false,"exempt":false,"violations":[],"error":"task_id_required"}\n'; exit 1; }

if ! git rev-parse --verify "$base_ref" >/dev/null 2>&1; then
  if [[ "$base_explicit" == "false" ]] && git rev-parse --verify origin/staging >/dev/null 2>&1; then
    base_ref="origin/staging"
  else
    printf '{"ok":false,"exempt":false,"violations":[],"error":"base_ref_not_found","base_ref":"%s"}\n' "$base_ref"
    exit 1
  fi
fi

_is_docs_path() {
  case "$1" in
    docs/*|*.md) return 0 ;;
    *) return 1 ;;
  esac
}
_is_config_path() {
  case "$1" in
    *.json|*.yml|*.yaml|*.toml|.gitignore) return 0 ;;
    *) return 1 ;;
  esac
}

_task_exempt() {
  task_tdd_exempt "$task_id" "$spec_dir"
}

_emit() {
  local ok="$1" exempt="$2" violations="$3"
  local out
  out=$(jq -n --argjson ok "$ok" --argjson exempt "$exempt" --argjson v "$violations" \
    '{ok:$ok, exempt:$exempt, violations:$v}')
  printf '%s\n' "$out"
  if [[ -n "$run_id" ]] && command -v pipeline-state >/dev/null 2>&1; then
    pipeline-state task-write "$run_id" "$task_id" quality_gates.tdd "$out" >/dev/null 2>&1 || true
  fi
  command -v log_metric >/dev/null && log_metric "task.gate.tdd" "task_id=\"$task_id\"" "ok=$ok" "exempt=$exempt" || true
}

# Classify ALL commits in base..HEAD, not just task-tagged ones.
all_commits=$(git log --format='%H' "${base_ref}..HEAD" 2>/dev/null)
if [[ -z "$all_commits" ]]; then
  _emit true true '[]'
  exit 0
fi

all_commits_oldest=$(printf '%s\n' "$all_commits" | awk '{a[NR]=$0} END{for(i=NR;i>0;i--) print a[i]}')
classes=()
while read -r sha; do
  [[ -z "$sha" ]] && continue
  # For merge commits, use --first-parent diff-tree to classify only the files
  # that the merge *introduces* into the first-parent line (i.e. the new content
  # not reachable from the first parent before the merge). This prevents a merge
  # commit that brings impl files from being silently skipped.
  num_parents=$(git show -s --format='%P' "$sha" | wc -w | tr -d ' ')
  if (( num_parents > 1 )); then
    # Merge commit: classify files the merge introduces relative to its first parent.
    # Use explicit "<first-parent> <sha>" form so we get the full diff, not the
    # combined (intersection) diff that `git diff-tree <sha>` emits for merges.
    first_parent=$(git show -s --format='%P' "$sha" | cut -d' ' -f1)
    files=$(git diff-tree --no-commit-id --name-only -r "$first_parent" "$sha" 2>/dev/null || true)
  else
    files=$(git diff-tree --no-commit-id --name-only -r "$sha" 2>/dev/null || true)
  fi
  kind="test-only"
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    if ! is_test_path "$f"; then
      if ! _is_docs_path "$f" && ! _is_config_path "$f"; then
        kind="impl"
      fi
    fi
  done <<<"$files"
  # An --allow-empty commit has no files; treat as neither test nor impl.
  if [[ -z "${files// }" ]]; then kind="empty"; fi
  # Determine whether commit is tagged with this task_id.
  tagged=0
  if git log -1 --format='%s%n%b' "$sha" | grep -qF "[$task_id]"; then
    tagged=1
  fi
  classes+=("$sha|$kind|$tagged")
done <<<"$all_commits_oldest"

has_impl=0
for c in "${classes[@]}"; do
  IFS='|' read -r _ kind _ <<<"$c"
  [[ "$kind" == "impl" ]] && has_impl=1
done
if (( has_impl == 0 )); then _emit true true '[]'; exit 0; fi
if _task_exempt;           then _emit true true '[]'; exit 0; fi

seen_test_only=0
violations='[]'
for c in "${classes[@]}"; do
  IFS='|' read -r sha kind tagged <<<"$c"
  if [[ "$kind" == "test-only" && "$tagged" == "1" ]]; then
    seen_test_only=1
  elif [[ "$kind" == "impl" ]]; then
    if [[ "$tagged" != "1" ]]; then
      violations=$(printf '%s' "$violations" | jq --arg s "$sha" '. + [{commit:$s, reason:"impl-commit-untagged"}]')
    elif (( seen_test_only == 0 )); then
      violations=$(printf '%s' "$violations" | jq --arg s "$sha" '. + [{commit:$s, reason:"impl-without-preceding-test"}]')
    fi
  fi
done

if [[ "$violations" != '[]' ]]; then
  _emit false false "$violations"
  exit 1
fi
_emit true false '[]'
