#!/usr/bin/env bash
# Initialize a new pipeline run.
# Creates directory structure, state.json, audit/metrics logs, symlink.
# Usage: pipeline-init <run-id> [--issue <N>] [--mode <mode>] [--json] [--simple-output]
# --json           Emit JSON on stdout (default: human-readable only)
# --simple-output  Force human-readable mode (override FACTORY_JSON=1)

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

run_id="${1:?missing run-id}"
shift

# Validate run-id: must match ^[a-zA-Z0-9_-]{1,64}$ (positive charset, E1)
_validate_id "$run_id" "run-id" || exit 1

issue=""
mode="prd"
force=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --issue)         issue="$2"; shift 2 ;;
    --mode)          mode="$2";  shift 2 ;;
    --force)         force=1;    shift ;;
    --json)          export FACTORY_JSON=1; shift ;;
    --simple-output) export FACTORY_JSON=0; shift ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

# Validate mode
case "$mode" in
  discover|prd|task|resume) ;;
  *) log_error "invalid mode: $mode (expected discover|prd|task|resume)"; exit 1 ;;
esac

runs_dir="${CLAUDE_PLUGIN_DATA}/runs"
run_dir="${runs_dir}/${run_id}"

plugin_manifest="$(dirname "$0")/../.claude-plugin/plugin.json"
plugin_version=$(jq -r '.version // "unknown"' "$plugin_manifest" 2>/dev/null || echo "unknown")

# Check for existing run
if [[ -d "$run_dir" ]]; then
  log_error "run already exists: $run_id"
  exit 1
fi

# Create directory structure
mkdir -p "$run_dir"/{holdouts,reviews}

# Build issue_numbers array
issue_numbers="[]"
if [[ -n "$issue" ]]; then
  if ! [[ "$issue" =~ ^[0-9]+$ ]]; then
    log_error "invalid issue number (must be a positive integer): $issue"
    exit 1
  fi
  issue_numbers=$(printf '[%s]' "$issue")
fi

now=$(date -u +%Y-%m-%dT%H:%M:%SZ)

# Initialize state.json
state=$(jq -n \
  --arg run_id "$run_id" \
  --arg mode "$mode" \
  --arg now "$now" \
  --arg version "$plugin_version" \
  --argjson issues "$issue_numbers" \
  '{
    run_id: $run_id,
    version: $version,
    status: "running",
    mode: $mode,
    started_at: $now,
    updated_at: $now,
    ended_at: null,
    input: {
      issue_numbers: $issues,
      resumed_from: null
    },
    spec: {
      status: "pending",
      path: null,
      review_iterations: 0,
      review_score: null
    },
    tasks: {},
    circuit_breaker: {
      tasks_completed: 0,
      consecutive_failures: 0,
      runtime_minutes: 0,
      pause_minutes: 0
    },
    cost: {
      total_tokens: 0,
      estimated_usd: 0,
      by_model: {}
    }
  }')

atomic_write "$run_dir/state.json" "$state"

# Create empty log files
touch "$run_dir/audit.jsonl"
touch "$run_dir/metrics.jsonl"

# Set 'current' symlink, refusing to clobber an actively-running run.
# Non-terminal run statuses — treat symlink target as owned until --force.
current_link="${runs_dir}/current"
if [[ -L "$current_link" ]]; then
  current_target=$(readlink "$current_link" 2>/dev/null || true)
  if [[ -n "$current_target" && -f "$current_target/state.json" ]]; then
    current_status=$(jq -r '.status // "unknown"' "$current_target/state.json" 2>/dev/null || echo "unknown")
    case "$current_status" in
      running)
        if [[ $force -eq 0 ]]; then
          other_run=$(basename "$current_target")
          log_error "current symlink points to active run '$other_run' (status=running). Pass --force to override."
          # Clean up the just-created run-dir so we don't leak state on the
          # refused init. The caller can retry with --force.
          rm -rf "$run_dir"
          exit 1
        fi
        log_warn "overriding active run with --force"
        ;;
      *) ;;
    esac
  fi
fi
# Atomic symlink swap: create a sibling tmp link, then atomically rename it
# over `$current_link`. The rename(2) is atomic on POSIX, so observers never
# see `$current_link` missing. BSD `mv` requires `-h` and GNU `mv` requires
# `-T` to avoid following a symlink-to-directory target.
_tmp_link="${current_link}.tmp.$$"
if ! ln -sfn "$run_dir" "$_tmp_link"; then
  log_error "ln -s tmp failed: $_tmp_link"
  rm -rf "$run_dir"
  exit 1
fi
_mv_ok=0
if mv -fh "$_tmp_link" "$current_link" 2>/dev/null; then
  _mv_ok=1
elif mv -fT "$_tmp_link" "$current_link" 2>/dev/null; then
  _mv_ok=1
fi
if [[ $_mv_ok -eq 0 ]]; then
  rm -f "$_tmp_link"
  log_error "mv current symlink failed: $current_link"
  rm -rf "$run_dir"
  exit 1
fi

log_metric "run.start" "mode=\"$mode\"" "issue=\"$issue\""
log_info "initialized run $run_id (mode=$mode, issue=$issue)"
human_summary "initialized run $run_id (mode=$mode, issue=${issue:-none})"

jq -n \
  --arg run_id "$run_id" \
  --arg state_path "$run_dir/state.json" \
  --argjson created true \
  '{run_id: $run_id, state_path: $state_path, created: $created}' | json_emit
