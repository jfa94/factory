#!/usr/bin/env bash
# State manager for pipeline runs.
# Usage: pipeline-state <action> <run-id> [key] [value]
#
# Actions:
#   read <run-id> [key]                         Read full state or jq key
#   write <run-id> <key> <value>                Atomic write to state key
#   task-write <run-id> <task-id> <field> <value>  Atomic per-task write (hyphen-safe)
#   task-array-append <run-id> <task-id> <field> <value>  Atomic append-to-array (unique)
#   task-read <run-id> <task-id> [field]        Read a per-task field or whole record
#   task-status <run-id> <task-id> <status>     Update task status
#   deps-satisfied <run-id> <task-id>           Check if deps done (exit 0/1)
#   interrupted <run-id>                        Check if run interrupted (exit 0/1)
#   resume-point <run-id>                       Find first incomplete task
#   list                                        List all runs

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

action="${1:?missing action}"
shift

# Known top-level task fields. New code should add to this list when it
# introduces a new state.tasks[].field. Unknown fields trigger a warning to
# surface typos like 'qualtiy_gate' early; they are NOT blocked (yet) for
# backwards compat. After one release cycle this should become a hard reject.
# (E3)
_KNOWN_TASK_FIELDS=(
  status started_at ended_at depends_on stage
  classify risk risk_tier
  test_writer_status executor_status
  worktree branch
  quality_gate quality_gates review_files review_attempts
  postexec_reviewer_only postreview_prior_blockers
  pr_number pr_url ci_status merge_status
  ci_fix_attempts subagent_retries failure_reason
  holdout_review_file
  tdd_exempt
)

# Per-run advisory lock using mkdir (atomic on all POSIX systems, no flock needed).
# Serialises concurrent read-modify-write cycles in write and task-status actions.
_state_lock_dir() { echo "$CLAUDE_PLUGIN_DATA/runs/$1/state.lock"; }

_state_lock() {
  local run_id="$1" lock_dir attempts=0
  lock_dir=$(_state_lock_dir "$run_id")
  while ! mkdir "$lock_dir" 2>/dev/null; do
    attempts=$((attempts + 1))
    if (( attempts > 200 )); then
      local pid_file="$lock_dir/pid"
      if [[ -f "$pid_file" ]]; then
        local holder
        holder=$(<"$pid_file")
        if [[ -n "$holder" ]] && ! kill -0 "$holder" 2>/dev/null; then
          rm -rf "$lock_dir"
          log_warn "removed stale state lock (dead PID $holder)"
          attempts=0
          continue
        fi
      fi
      log_error "state lock timeout for run $run_id after 10s"
      exit 1
    fi
    sleep 0.05
  done
  printf '%s' "$$" > "$lock_dir/pid"
}

_state_unlock() {
  rm -rf "$(_state_lock_dir "$1")"
}

# Parse a jq-style dotted/bracketed path into a JSON array for use with setpath.
# Accepts: .foo, .foo.bar, .foo.bar[0].baz
# Each identifier segment must match ^[a-zA-Z_][a-zA-Z0-9_]*$; index segments ^[0-9]+$.
# Returns a JSON array string on stdout, exits 1 on invalid input.
_parse_state_key() {
  local raw="$1"
  # Fast-fail: reject any character that isn't part of a valid path.
  # Negated class [^].a-zA-Z0-9_[-] means "any char NOT in {], ., alphanums, _, [, -}".
  # Putting ] first inside [^...] is the POSIX-portable way to include literal ];
  # hyphen trails to avoid being read as a range operator.
  if [[ "$raw" =~ [^].a-zA-Z0-9_[-] ]]; then
    log_error "invalid key (disallowed characters): $(printf '%s' "$raw" | cat -v)"
    return 1
  fi
  if [[ "$raw" != .* ]]; then
    log_error "key must start with '.' (got: $raw)"
    return 1
  fi
  local path="${raw#.}"
  if [[ -z "$path" ]]; then
    log_error "key must not be bare '.'"
    return 1
  fi
  # Normalise bracket indices to dot-separated: .foo[0].bar → .foo.0.bar
  path="${path//\[/.}"
  path="${path//\]/}"
  IFS='.' read -ra segs <<< "$path"
  local json_array='['
  local first=1
  for seg in "${segs[@]}"; do
    if [[ -z "$seg" ]]; then
      log_error "empty path segment in key: $raw"
      return 1
    fi
    if [[ "$seg" =~ ^[a-zA-Z_][a-zA-Z0-9_-]*$ ]]; then
      [[ $first -eq 0 ]] && json_array+=','
      json_array+="\"$seg\""
      first=0
    elif [[ "$seg" =~ ^[0-9]+$ ]]; then
      [[ $first -eq 0 ]] && json_array+=','
      json_array+="$seg"
      first=0
    else
      log_error "invalid path segment '$seg' in key: $raw"
      return 1
    fi
  done
  json_array+=']'
  printf '%s' "$json_array"
}

_state_file() {
  local run_id="$1"
  printf '%s/runs/%s/state.json' "$CLAUDE_PLUGIN_DATA" "$run_id"
}

_read_state_file() {
  local f
  f=$(_state_file "$1")
  if [[ ! -f "$f" ]]; then
    log_error "state file not found: $f"
    exit 1
  fi
  cat "$f"
}

case "$action" in
  read)
    run_id="${1:?missing run-id}"
    _validate_id "$run_id" "run-id" || exit 1
    key="${2:-}"
    state=$(_read_state_file "$run_id")
    if [[ -z "$key" ]]; then
      printf '%s' "$state"
    else
      # Split optional `// default` fallback off the key. Validate both halves
      # to prevent jq-expression injection via the key argument.
      raw_key="$key"
      default_expr=""
      if [[ "$raw_key" == *" // "* ]]; then
        default_expr="${raw_key##* // }"
        raw_key="${raw_key% // *}"
        # Strip whitespace
        default_expr="$(printf '%s' "$default_expr" | awk '{$1=$1; print}')"
      fi

      # Validate default, if present. Use jq -e empty as the parser: any input
      # that is valid JSON (numbers with exponents, escape-sequenced strings,
      # populated arrays/objects) is accepted; anything jq rejects is blocked.
      # jq parse is the actual security boundary — values that survive it are
      # safe to embed in a getpath(…) // <expr> expression (E4).
      if [[ -n "$default_expr" ]]; then
        if ! printf '%s' "$default_expr" | jq . >/dev/null 2>&1; then
          log_error "invalid JSON default expression: $default_expr"
          exit 1
        fi
      fi

      jq_path=$(_parse_state_key "$raw_key") || exit 1

      if [[ -n "$default_expr" ]]; then
        printf '%s' "$state" | jq -r --argjson path "$jq_path" \
          "getpath(\$path) // $default_expr"
      else
        printf '%s' "$state" | jq -r --argjson path "$jq_path" \
          'getpath($path)'
      fi
    fi
    ;;

  write)
    run_id="${1:?missing run-id}"
    _validate_id "$run_id" "run-id" || exit 1
    key="${2:?missing key}"
    value="${3:?missing value}"
    f=$(_state_file "$run_id")

    # Parse and validate key before acquiring lock to fail fast on bad input.
    jq_path=$(_parse_state_key "$key") || exit 1

    _state_lock "$run_id"
    trap '_state_unlock "$run_id"' EXIT
    state=$(_read_state_file "$run_id")

    # Determine if value is valid JSON; if so, use argjson
    if printf '%s' "$value" | jq empty 2>/dev/null; then
      updated=$(printf '%s' "$state" | jq --argjson path "$jq_path" --argjson v "$value" 'setpath($path; $v)')
    else
      updated=$(printf '%s' "$state" | jq --argjson path "$jq_path" --arg v "$value" 'setpath($path; $v)')
    fi

    # Update the updated_at timestamp
    updated=$(printf '%s' "$updated" | jq --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" '.updated_at = $t')

    atomic_write "$f" "$updated"
    _state_unlock "$run_id"
    trap - EXIT
    log_info "state updated: $key"
    ;;

  task-write)
    run_id="${1:?missing run-id}"
    _validate_id "$run_id" "run-id" || exit 1
    task_id="${2:?missing task-id}"
    _validate_id "$task_id" "task-id" || exit 1
    field="${3:?missing field}"
    value="${4:?missing value}"
    f=$(_state_file "$run_id")

    # Field is a dot-separated path relative to .tasks[<task_id>]; task_id is
    # injected via --arg so hyphenated ids are data-safe (no path-parser round
    # trip). Field still validates against identifier[.identifier]* to prevent
    # injection into the jq setpath expression.
    if [[ "$field" =~ ^\. ]]; then
      log_error "task-write field must not start with '.' (got: $field)"
      exit 1
    fi
    if ! [[ "$field" =~ ^[a-zA-Z_][a-zA-Z0-9_.-]*$ ]]; then
      log_error "invalid task-write field: $field"
      exit 1
    fi

    # Warn (not block) on unknown top-level field to surface typos early.
    # Strip nested suffix (.foo.bar → foo) to match against the allowlist root.
    # (E3: warn-only; becomes a hard reject after one release cycle.)
    field_root="${field%%.*}"
    _known=0
    for _k in "${_KNOWN_TASK_FIELDS[@]}"; do
      [[ "$_k" == "$field_root" ]] && { _known=1; break; }
    done
    if (( _known == 0 )); then
      log_warn "task-write unknown field: $field (known roots: ${_KNOWN_TASK_FIELDS[*]})"
    fi
    unset _known _k

    # Build path array ["tasks", $tid, <field segments>] via jq.
    jq_path=$(jq -n --arg tid "$task_id" --arg f "$field" \
      '["tasks", $tid] + ($f | split("."))') || {
        log_error "failed to build task path"
        exit 1
      }

    _state_lock "$run_id"
    trap '_state_unlock "$run_id"' EXIT
    state=$(_read_state_file "$run_id")

    if printf '%s' "$value" | jq empty 2>/dev/null; then
      updated=$(printf '%s' "$state" | jq --argjson path "$jq_path" --argjson v "$value" 'setpath($path; $v)')
    else
      updated=$(printf '%s' "$state" | jq --argjson path "$jq_path" --arg v "$value" 'setpath($path; $v)')
    fi
    updated=$(printf '%s' "$updated" | jq --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" '.updated_at = $t')

    atomic_write "$f" "$updated"
    _state_unlock "$run_id"
    trap - EXIT
    log_info "state updated: tasks[$task_id].$field"
    ;;

  task-array-append)
    run_id="${1:?missing run-id}"
    _validate_id "$run_id" "run-id" || exit 1
    task_id="${2:?missing task-id}"
    _validate_id "$task_id" "task-id" || exit 1
    field="${3:?missing field}"
    value="${4:?missing value}"
    f=$(_state_file "$run_id")

    if [[ "$field" =~ ^\. ]]; then
      log_error "task-array-append field must not start with '.' (got: $field)"
      exit 1
    fi
    if ! [[ "$field" =~ ^[a-zA-Z_][a-zA-Z0-9_.-]*$ ]]; then
      log_error "invalid task-array-append field: $field"
      exit 1
    fi

    field_root="${field%%.*}"
    _known=0
    for _k in "${_KNOWN_TASK_FIELDS[@]}"; do
      [[ "$_k" == "$field_root" ]] && { _known=1; break; }
    done
    if (( _known == 0 )); then
      log_warn "task-array-append unknown field: $field (known roots: ${_KNOWN_TASK_FIELDS[*]})"
    fi
    unset _known _k

    jq_path=$(jq -n --arg tid "$task_id" --arg f "$field" \
      '["tasks", $tid] + ($f | split("."))') || {
        log_error "failed to build task path"
        exit 1
      }

    _state_lock "$run_id"
    trap '_state_unlock "$run_id"' EXIT
    state=$(_read_state_file "$run_id")

    if printf '%s' "$value" | jq empty 2>/dev/null; then
      updated=$(printf '%s' "$state" | jq --argjson path "$jq_path" --argjson v "$value" \
        'setpath($path; ((getpath($path) // []) + [$v] | unique))')
    else
      updated=$(printf '%s' "$state" | jq --argjson path "$jq_path" --arg v "$value" \
        'setpath($path; ((getpath($path) // []) + [$v] | unique))')
    fi
    updated=$(printf '%s' "$updated" | jq --arg t "$(date -u +%Y-%m-%dT%H:%M:%SZ)" '.updated_at = $t')

    atomic_write "$f" "$updated"
    _state_unlock "$run_id"
    trap - EXIT
    log_info "state appended: tasks[$task_id].$field"
    ;;

  task-read)
    run_id="${1:?missing run-id}"
    _validate_id "$run_id" "run-id" || exit 1
    task_id="${2:?missing task-id}"
    _validate_id "$task_id" "task-id" || exit 1
    field="${3:-}"
    state=$(_read_state_file "$run_id")

    if [[ -z "$field" ]]; then
      # Entire task record
      printf '%s' "$state" | jq --arg tid "$task_id" '.tasks[$tid] // null'
    else
      # Allow optional "// default" suffix, same rules as `read`.
      raw_field="$field"
      default_expr=""
      if [[ "$raw_field" == *" // "* ]]; then
        default_expr="${raw_field##* // }"
        raw_field="${raw_field% // *}"
        default_expr="$(printf '%s' "$default_expr" | awk '{$1=$1; print}')"
      fi

      if [[ "$raw_field" =~ ^\. ]]; then
        log_error "task-read field must not start with '.' (got: $raw_field)"
        exit 1
      fi
      if ! [[ "$raw_field" =~ ^[a-zA-Z_][a-zA-Z0-9_.-]*$ ]]; then
        log_error "invalid task-read field: $raw_field"
        exit 1
      fi
      if [[ -n "$default_expr" ]]; then
        if ! printf '%s' "$default_expr" | jq . >/dev/null 2>&1; then
          log_error "invalid JSON default expression: $default_expr"
          exit 1
        fi
      fi

      jq_path=$(jq -n --arg tid "$task_id" --arg f "$raw_field" \
        '["tasks", $tid] + ($f | split("."))')

      if [[ -n "$default_expr" ]]; then
        printf '%s' "$state" | jq -r --argjson path "$jq_path" \
          "getpath(\$path) // $default_expr"
      else
        printf '%s' "$state" | jq -r --argjson path "$jq_path" 'getpath($path)'
      fi
    fi
    ;;

  task-status)
    run_id="${1:?missing run-id}"
    _validate_id "$run_id" "run-id" || exit 1
    task_id="${2:?missing task-id}"
    _validate_id "$task_id" "task-id" || exit 1
    status="${3:?missing status}"
    f=$(_state_file "$run_id")

    # Validate status before acquiring lock to fail fast on bad input.
    case "$status" in
      pending|executing|reviewing|done|failed|interrupted|needs_human_review|ci_fixing) ;;
      *) log_error "invalid task status: $status"; exit 1 ;;
    esac

    _state_lock "$run_id"
    trap '_state_unlock "$run_id"' EXIT
    state=$(_read_state_file "$run_id")
    now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    updated=$(printf '%s' "$state" | jq \
      --arg tid "$task_id" \
      --arg s "$status" \
      --arg now "$now" '
      .tasks[$tid].status = $s |
      .updated_at = $now |
      if $s == "executing" then .tasks[$tid].started_at = $now
      elif ($s == "done" or $s == "failed") then .tasks[$tid].ended_at = $now
      else . end |
      # Update circuit breaker counters
      if $s == "done" then
        .circuit_breaker.tasks_completed = (.circuit_breaker.tasks_completed + 1) |
        .circuit_breaker.consecutive_failures = 0
      elif $s == "failed" then
        .circuit_breaker.consecutive_failures = (.circuit_breaker.consecutive_failures + 1)
      else . end
    ')

    atomic_write "$f" "$updated"
    _state_unlock "$run_id"
    trap - EXIT
    log_info "task $task_id → $status"

    # task_16_11: emit lifecycle events (start/end) into metrics.jsonl.
    # log_metric is a no-op when observability.auditLog=false.
    case "$status" in
      executing) log_metric "task.start" "task_id=\"$task_id\"" ;;
      done|failed|needs_human_review|interrupted)
        log_metric "task.end" "task_id=\"$task_id\"" "status=\"$status\""
        ;;
    esac
    ;;

  deps-satisfied)
    run_id="${1:?missing run-id}"
    _validate_id "$run_id" "run-id" || exit 1
    task_id="${2:?missing task-id}"
    _validate_id "$task_id" "task-id" || exit 1
    state=$(_read_state_file "$run_id")

    # Check each dependency's status
    deps=$(printf '%s' "$state" | jq -r --arg tid "$task_id" '
      if .tasks[$tid].depends_on then .tasks[$tid].depends_on[] else empty end
    ' 2>/dev/null || true)

    if [[ -z "$deps" ]]; then
      exit 0
    fi

    while IFS= read -r dep_id; do
      dep_status=$(printf '%s' "$state" | jq -r --arg d "$dep_id" '.tasks[$d].status // "unknown"')
      if [[ "$dep_status" != "done" ]]; then
        log_info "dep $dep_id not satisfied (status: $dep_status)"
        exit 1
      fi
    done <<< "$deps"
    exit 0
    ;;

  interrupted)
    run_id="${1:?missing run-id}"
    _validate_id "$run_id" "run-id" || exit 1
    state=$(_read_state_file "$run_id")
    status=$(printf '%s' "$state" | jq -r '.status')
    [[ "$status" == "interrupted" ]]
    ;;

  resume-point)
    run_id="${1:?missing run-id}"
    _validate_id "$run_id" "run-id" || exit 1
    state=$(_read_state_file "$run_id")

    # Prefer .execution_order (validated topo-sort from pipeline-validate-tasks).
    # Each entry is {task_id, parallel_group}; array order is already grouped
    # so earlier parallel_groups appear first.
    task_id=$(printf '%s' "$state" | jq -r '
      . as $root
      | ($root.execution_order // []) as $order
      | if ($order | length) > 0 then
          $order
          | map(.task_id)
          | map(select(
              ($root.tasks[.].status // "pending") != "done"
              and ($root.tasks[.].status // "pending") != "failed"
            ))
          | .[0] // empty
        else
          empty
        end
    ')

    # Fallback: legacy state without .execution_order (pre-seeding).
    if [[ -z "$task_id" ]]; then
      if printf '%s' "$state" | jq -e '(.execution_order // []) | length == 0' >/dev/null; then
        log_warn "state has no execution_order, falling back to .tasks iteration order"
        task_id=$(printf '%s' "$state" | jq -r '
          [.tasks | to_entries[] | select(.value.status != "done" and .value.status != "failed")] |
          first | .key // empty
        ')
      fi
    fi

    if [[ -z "$task_id" ]]; then
      log_info "no incomplete tasks found"
      exit 1
    fi
    printf '%s' "$task_id"
    ;;

  list)
    runs_dir="${CLAUDE_PLUGIN_DATA}/runs"
    if [[ ! -d "$runs_dir" ]]; then
      printf '[]\n'
      exit 0
    fi
    # List all run directories (excluding 'current' symlink)
    find "$runs_dir" -maxdepth 1 -mindepth 1 -type d -exec basename {} \; \
      | sort \
      | jq -R -s 'split("\n") | map(select(length > 0))'
    ;;

  # C1: finalize-on-stop — atomically transition in-flight tasks and compute
  # run-level final status. Called exclusively by stop-gate.sh to ensure all
  # state writes go through the lock rather than direct tmp+mv.
  # Usage: pipeline-state finalize-on-stop <run-id>
  # Side-effect: removes the 'current' symlink after writing state.
  finalize-on-stop)
    run_id="${1:?missing run-id}"
    _validate_id "$run_id" "run-id" || exit 1
    f=$(_state_file "$run_id")

    _state_lock "$run_id"
    trap '_state_unlock "$run_id"' EXIT
    state=$(_read_state_file "$run_id")
    now=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    # Transition in-flight tasks to interrupted.
    # needs_human_review is preserved (human must act; not a pipeline failure).
    state=$(printf '%s' "$state" | jq --arg now "$now" '
      .tasks |= with_entries(
        if .value.status == "executing"
           or .value.status == "reviewing"
           or .value.status == "ci_fixing" then
          .value.status = "interrupted" | .value.ended_at = $now
        else . end
      )
    ')

    # Determine run-level final status from (post-transition) task statuses.
    final_status=$(printf '%s' "$state" | jq -r '
      .tasks | to_entries | map(.value.status) as $statuses |
      if ($statuses | length) == 0 then
        "interrupted"
      elif ($statuses | all(. == "done")) then
        "completed"
      elif ([$statuses[] | select(. == "interrupted" or . == "pending" or . == "needs_human_review")] | length) > 0 then
        if ([$statuses[] | select(. == "failed")] | length) > 0 then
          "partial"
        else
          "interrupted"
        end
      elif ([$statuses[] | select(. == "failed")] | length) > 0 then
        "partial"
      else
        "interrupted"
      end
    ')

    # Resume point: first task whose status is not done and not failed.
    resume_task=$(printf '%s' "$state" | jq -r '
      [.tasks | to_entries[] |
       select(.value.status != "done" and .value.status != "failed") |
       .key] | first // ""
    ')

    updated=$(printf '%s' "$state" | jq \
      --arg status "$final_status" \
      --arg now "$now" \
      --arg resume "$resume_task" '
      .status = $status |
      .ended_at = $now |
      .updated_at = $now |
      .resume_point = (if $resume != "" then $resume else null end)
    ')

    atomic_write "$f" "$updated"
    _state_unlock "$run_id"
    trap - EXIT

    # Remove the 'current' symlink — this run is no longer the active session.
    current_link="${CLAUDE_PLUGIN_DATA}/runs/current"
    rm -f "$current_link"

    log_info "run $run_id finalized: $final_status (resume: ${resume_task:-none})"
    ;;

  *)
    log_error "unknown action: $action"
    echo "Usage: pipeline-state <read|write|task-status|deps-satisfied|interrupted|resume-point|list|finalize-on-stop> <run-id> [args...]" >&2
    exit 1
    ;;
esac
