#!/usr/bin/env bash
# Lock manager — prevents two orchestrator instances from running simultaneously.
# Secondary safety mechanism (primary is worktree isolation).
# Usage: pipeline-lock <acquire|release|recover|status> [--timeout <seconds>] [--pid <pid>]

source "$(dirname "$0")/pipeline-lib.sh"

action="${1:?missing action: acquire|release|recover|status}"
shift

LOCK_FILE="${CLAUDE_PLUGIN_DATA}/pipeline.lock"
TIMEOUT=30
# PID defaults to the current shell. FACTORY_LOCK_TEST_PID is a test-only
# escape hatch — production code must never set it.
LOCK_PID="${FACTORY_LOCK_TEST_PID:-$$}"

# Parse flags — --pid is intentionally not accepted to prevent caller spoofing
while [[ $# -gt 0 ]]; do
  case "$1" in
    --timeout) TIMEOUT="$2"; shift 2 ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

_lock_info() {
  if [[ ! -f "$LOCK_FILE" ]]; then
    return 1
  fi
  cat "$LOCK_FILE"
}

_is_pid_alive() {
  kill -0 "$1" 2>/dev/null
}

# C2: Atomic lock install — write payload to a tmp file in the same directory
# then rename into place. rename(2) is atomic on the same filesystem so there
# is no window where the lock file is absent. Two concurrent callers racing
# on a dead-PID lock both mv successfully (last writer wins), so we always
# read back after the mv and verify the installed PID is ours; if not, we
# fall through to the normal retry loop on the next iteration.
# Returns 0 if we own the lock after the install; 1 if we lost the race.
_install_lock_atomically() {
  local payload="$1"
  local tmp_lock
  tmp_lock=$(mktemp "${LOCK_FILE}.install.XXXXXX")
  printf '%s' "$payload" > "$tmp_lock"
  if ! mv -f "$tmp_lock" "$LOCK_FILE"; then
    rm -f "$tmp_lock"
    return 1
  fi
  # Read back and verify we hold the lock (not a concurrent acquirer).
  local readback_pid
  readback_pid=$(jq -r '.pid' "$LOCK_FILE" 2>/dev/null || true)
  if [[ "$readback_pid" != "$LOCK_PID" ]]; then
    # Another process won the race; let the outer loop handle it.
    return 1
  fi
  return 0
}

case "$action" in
  acquire)
    mkdir -p "$(dirname "$LOCK_FILE")"
    elapsed=0

    while [[ $elapsed -lt $TIMEOUT ]]; do
      # Try to create lock atomically (noclobber: succeeds only when absent)
      if ( set -o noclobber; printf '{"pid":%d,"timestamp":"%s"}' "$LOCK_PID" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > "$LOCK_FILE" ) 2>/dev/null; then
        log_info "lock acquired (PID $LOCK_PID)"
        json_output locked "true" pid "$LOCK_PID" action "acquired"
        exit 0
      fi

      # Lock exists — check if it's ours (reentrant)
      info=$(_lock_info) || { sleep 1; elapsed=$((elapsed + 1)); continue; }
      holder_pid=$(printf '%s' "$info" | jq -r '.pid')

      if [[ "$holder_pid" == "$LOCK_PID" ]]; then
        log_info "lock already held by us (PID $LOCK_PID)"
        json_output locked "true" pid "$LOCK_PID" action "reentrant"
        exit 0
      fi

      # Check if holder is dead — auto-recover atomically.
      # Old path: rm -f + continue (two acquirers seeing the same dead PID both
      # remove the file, both then race the noclobber-write — benign but wasteful).
      # New path: atomic mv install + read-back verify. If we lose the race,
      # the loop continues and we either see our competitor's PID (alive → wait,
      # or dead → race again) or their lock becomes ours on the next noclobber.
      if ! _is_pid_alive "$holder_pid"; then
        log_warn "lock held by dead process $holder_pid, recovering atomically"
        payload=$(printf '{"pid":%d,"timestamp":"%s","recovered_from":%d}' \
          "$LOCK_PID" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$holder_pid")
        if _install_lock_atomically "$payload"; then
          log_info "lock acquired via dead-PID recovery (PID $LOCK_PID)"
          json_output locked "true" pid "$LOCK_PID" action "acquired"
          exit 0
        fi
        # Lost the race — retry the loop without sleeping (competitor just
        # installed a lock we can check on the next iteration).
        continue
      fi

      sleep 1
      elapsed=$((elapsed + 1))
    done

    info=$(_lock_info) || true
    if [[ -z "$info" ]]; then
      info='{}'
    fi
    holder_pid=$(printf '%s' "$info" | jq -r '.pid // "unknown"')
    log_error "lock acquisition timed out after ${TIMEOUT}s (held by PID $holder_pid)"
    json_output locked "false" holder_pid "$holder_pid" action "timeout"
    exit 1
    ;;

  release)
    if [[ ! -f "$LOCK_FILE" ]]; then
      log_warn "no lock to release"
      json_output locked "false" action "noop"
      exit 0
    fi

    # Ownership check: only refuse if the lockfile PID is CURRENTLY ALIVE and
    # not equal to the caller. A dead PID is an orphaned lock (normal after an
    # acquire subprocess exits) and any caller may clean it up. This prevents
    # stealing an active peer's lock while allowing idempotent cleanup.
    info=$(_lock_info) || {
      log_warn "lock file present but unreadable; treating as noop"
      json_output locked "false" action "noop"
      exit 0
    }
    holder_pid=$(printf '%s' "$info" | jq -r '.pid // empty')
    if [[ -n "$holder_pid" ]] && _is_pid_alive "$holder_pid" && [[ "$holder_pid" != "$LOCK_PID" ]]; then
      log_error "lock is actively held by alive PID $holder_pid; refusing release from PID $LOCK_PID"
      json_output locked "true" action "refused" reason "not_owner" \
                  owner_pid "$holder_pid" caller_pid "$LOCK_PID"
      exit 1
    fi

    rm -f "$LOCK_FILE"
    log_info "lock released (PID $LOCK_PID)"
    json_output locked "false" action "released" pid "$LOCK_PID"
    ;;

  recover)
    if [[ ! -f "$LOCK_FILE" ]]; then
      log_info "no lock exists"
      json_output locked "false" action "no_lock"
      exit 0
    fi

    info=$(_lock_info)
    holder_pid=$(printf '%s' "$info" | jq -r '.pid')
    timestamp=$(printf '%s' "$info" | jq -r '.timestamp')

    if _is_pid_alive "$holder_pid"; then
      log_info "lock holder PID $holder_pid is alive"
      json_output locked "true" holder_pid "$holder_pid" alive "true" timestamp "$timestamp" action "no_recovery"
      exit 1
    fi

    # Dead PID — take ownership atomically via shared _install_lock_atomically
    # helper (mv + read-back verify). If concurrent recoverers race, the last
    # mv wins; both see a valid lock file at all times (no window of absence).
    payload=$(printf '{"pid":%d,"timestamp":"%s","recovered_from":%d}' \
      "$LOCK_PID" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$holder_pid")
    if ! _install_lock_atomically "$payload"; then
      log_error "failed to install recovered lock (lost race to concurrent recoverer)"
      exit 1
    fi
    log_info "recovered lock from dead PID $holder_pid"
    json_output locked "true" pid "$LOCK_PID" recovered_from "$holder_pid" action "recovered"
    ;;

  status)
    if [[ ! -f "$LOCK_FILE" ]]; then
      json_output locked "false"
      exit 0
    fi

    info=$(_lock_info)
    holder_pid=$(printf '%s' "$info" | jq -r '.pid')
    timestamp=$(printf '%s' "$info" | jq -r '.timestamp')
    alive="false"
    if _is_pid_alive "$holder_pid"; then
      alive="true"
    fi

    # Calculate age in seconds
    if command -v gdate &>/dev/null; then
      lock_epoch=$(gdate -d "$timestamp" +%s 2>/dev/null || echo 0)
    else
      lock_epoch=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "$timestamp" +%s 2>/dev/null || echo 0)
    fi
    now_epoch=$(date +%s)
    age_seconds=$((now_epoch - lock_epoch))

    json_output locked "true" holder_pid "$holder_pid" alive "$alive" timestamp "$timestamp" age_seconds "$age_seconds"
    ;;

  *)
    log_error "unknown action: $action"
    echo "Usage: pipeline-lock <acquire|release|recover|status> [--timeout <seconds>]" >&2
    exit 1
    ;;
esac
