#!/usr/bin/env bash
# Wait for a PR to be merged, handling CI failures and conflicts.
# Usage: pipeline-wait-pr <pr-number> [--timeout <minutes>] [--interval <seconds>]
# Exit codes:
#   0 = merged
#   1 = timeout
#   2 = closed without merge
#   3 = CI failed (failure details on stdout)
#   4 = unresolvable merge conflict

source "$(dirname "$0")/pipeline-lib.sh"
require_command gh
require_command jq

pr="${1:?missing PR number}"
shift

# Defaults come from config (dependencies.prMergeTimeout / dependencies.pollInterval).
# CLI flags override. Empty config returns "" → fallback to the second read_config arg.
timeout_minutes=$(read_config '.dependencies.prMergeTimeout' '45')
interval_seconds=$(read_config '.dependencies.pollInterval' '60')

while [[ $# -gt 0 ]]; do
  case "$1" in
    --timeout) timeout_minutes="$2"; shift 2 ;;
    --interval) interval_seconds="$2"; shift 2 ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

# Validate numeric inputs
if ! [[ "$pr" =~ ^[0-9]+$ ]]; then
  log_error "invalid PR number: $pr"
  exit 1
fi

timeout_seconds=$((timeout_minutes * 60))
start_time=$(date +%s)

# Auto-safe rebase: files we know how to resolve
# - pnpm-lock.yaml, claude-progress.json, feature-status.json → ours
# - .gitignore → union merge
# - package.json → jq-normalized 3-way merge
SAFE_OURS_FILES="pnpm-lock.yaml claude-progress.json feature-status.json"
REBASE_MAX_ROUNDS="${PIPELINE_REBASE_MAX_ROUNDS:-30}"
# Count of UNKNOWN mergeable polls before treating as CONFLICTING.
MERGEABLE_UNKNOWN_MAX="${PIPELINE_MERGEABLE_UNKNOWN_MAX:-12}"

_elapsed() {
  local now
  now=$(date +%s)
  echo $(( now - start_time ))
}

# gh stderr is captured to a script-scoped file so the JSON-on-stdout
# contract stays clean while the poll loop can surface the actual error
# (rate limit, auth, network) when a fetch returns empty.
_GH_LAST_ERROR=""
_check_pr_status() {
  local out err
  err=$(mktemp)
  if out=$(gh pr view "$pr" --json state,mergedAt,mergeable,headRefName 2>"$err"); then
    rm -f "$err"
    _GH_LAST_ERROR=""
    printf '%s' "$out"
  else
    _GH_LAST_ERROR=$(<"$err")
    rm -f "$err"
    return 1
  fi
}

_check_pr_checks() {
  local out err
  err=$(mktemp)
  if out=$(gh pr checks "$pr" --json name,state,conclusion 2>"$err"); then
    rm -f "$err"
    _GH_LAST_ERROR=""
    printf '%s' "$out"
  else
    _GH_LAST_ERROR=$(<"$err")
    rm -f "$err"
    return 1
  fi
}

# === REBASE_HELPERS_START ===

# Run `git rebase --abort` and surface stderr if it fails. The previous
# `2>/dev/null || true` swallowed errors silently, leaving the worktree in a
# dirty rebase state that callers couldn't detect.
_safe_rebase_abort() {
  local _abort_err
  _abort_err=$(mktemp)
  if ! git rebase --abort 2>"$_abort_err"; then
    log_warn "git rebase --abort: $(cat "$_abort_err")"
  fi
  rm -f "$_abort_err"
}

# Check out the original branch and surface stderr/exit on failure. Callers
# must propagate the non-zero return — leaving the wrong branch checked out is
# an inconsistent worktree we cannot recover from automatically.
_safe_checkout_back() {
  local target="$1" _co_err
  [[ -z "$target" ]] && return 0
  _co_err=$(mktemp)
  if ! git checkout "$target" 2>"$_co_err"; then
    log_error "git checkout $target failed: $(cat "$_co_err")"
    rm -f "$_co_err"
    return 1
  fi
  rm -f "$_co_err"
  return 0
}

# Resolve one auto-safe conflict file in the current rebase. Returns 0 on
# success, 1 if the file is not auto-safe (caller must abort the rebase).
_resolve_safe_conflict() {
  local cf="$1"

  for sf in $SAFE_OURS_FILES; do
    if [[ "$cf" == "$sf" ]]; then
      git checkout --ours -- "$cf" 2>/dev/null || return 1
      git add -- "$cf" 2>/dev/null || return 1
      return 0
    fi
  done

  case "$cf" in
    .gitignore)
      local tmp_union
      tmp_union=$(mktemp)
      { git show REBASE_HEAD:.gitignore 2>/dev/null || true
        git show HEAD:.gitignore 2>/dev/null || true
      } > "$tmp_union"
      sort -u "$tmp_union" > "$cf"
      rm -f "$tmp_union"
      git add -- "$cf" 2>/dev/null || return 1
      return 0
      ;;
    package.json)
      # 3-way merge using jq --indent 4 to normalize formatting across
      # base/ours/theirs, then git merge-file. Preserves semantic changes,
      # resolves whitespace/indent-only conflicts.
      local _pkg_tmp
      _pkg_tmp=$(mktemp -d)
      if git show ":1:package.json" 2>/dev/null \
            | jq --indent 4 '.' > "$_pkg_tmp/base.json" 2>/dev/null \
         && git show ":2:package.json" 2>/dev/null \
            | jq --indent 4 '.' > "$_pkg_tmp/ours.json" 2>/dev/null \
         && git show ":3:package.json" 2>/dev/null \
            | jq --indent 4 '.' > "$_pkg_tmp/theirs.json" 2>/dev/null \
         && git merge-file -p \
              "$_pkg_tmp/ours.json" "$_pkg_tmp/base.json" "$_pkg_tmp/theirs.json" \
              > "$_pkg_tmp/merged.json" 2>/dev/null; then
        cp "$_pkg_tmp/merged.json" package.json
        git add -- package.json 2>/dev/null
        rm -rf "$_pkg_tmp"
        log_info "auto-resolved package.json formatting conflict"
        return 0
      fi
      rm -rf "$_pkg_tmp"
      log_warn "package.json has semantic conflicts — cannot auto-resolve"
      return 1
      ;;
  esac
  return 1
}

# Multi-round rebase loop. Runs up to REBASE_MAX_ROUNDS rounds of
# rebase/conflict-resolve/continue, handling auto-safe file conflicts each
# round. Returns 0 on success, 1 on abort.
_rebase_with_retries() {
  local base_ref="$1"

  if git rebase --empty=drop "$base_ref" 2>/dev/null; then
    return 0
  fi

  local round=0
  while (( round < REBASE_MAX_ROUNDS )); do
    round=$((round + 1))

    local conflict_files
    conflict_files=$(git diff --name-only --diff-filter=U 2>/dev/null) || true

    if [[ -z "$conflict_files" ]]; then
      # No conflict markers — commit became empty. Skip it.
      if GIT_EDITOR=true git rebase --skip 2>/dev/null; then
        return 0
      fi
      continue
    fi

    local has_unsafe=false
    while IFS= read -r cf; do
      [[ -z "$cf" ]] && continue
      local safe=false
      for sf in $SAFE_OURS_FILES; do
        if [[ "$cf" == "$sf" ]]; then safe=true; break; fi
      done
      [[ "$cf" == ".gitignore" || "$cf" == "package.json" ]] && safe=true
      if [[ "$safe" != "true" ]]; then
        has_unsafe=true
        break
      fi
    done <<< "$conflict_files"

    if [[ "$has_unsafe" == "true" ]]; then
      log_error "rebase round $round: unsafe conflict files: $conflict_files"
      _safe_rebase_abort
      return 1
    fi

    log_warn "rebase round $round: auto-resolving safe conflicts"
    local resolve_ok=true
    while IFS= read -r cf; do
      [[ -z "$cf" ]] && continue
      if ! _resolve_safe_conflict "$cf"; then
        resolve_ok=false
        break
      fi
    done <<< "$conflict_files"

    if [[ "$resolve_ok" != "true" ]]; then
      _safe_rebase_abort
      return 1
    fi

    if GIT_EDITOR=true git rebase --continue 2>/dev/null; then
      return 0
    fi

    # --continue failed — detect empty-commit case (no new conflict markers).
    local post
    post=$(git diff --name-only --diff-filter=U 2>/dev/null) || true
    if [[ -z "$post" ]]; then
      if GIT_EDITOR=true git rebase --skip 2>/dev/null; then
        return 0
      fi
    fi
    # Otherwise loop again to resolve the next round of conflicts.
  done

  log_error "rebase exceeded $REBASE_MAX_ROUNDS rounds"
  _safe_rebase_abort
  return 1
}
# === REBASE_HELPERS_END ===

_attempt_rebase() {
  local head_branch err
  head_branch=$(printf '%s' "$1" | jq -r '.headRefName')

  log_info "attempting rebase for $head_branch"

  # Fetch latest
  if ! err=$(git fetch origin 2>&1); then
    log_error "git fetch origin failed during rebase: $err"
    return 1
  fi

  local current_branch
  current_branch=$(git branch --show-current 2>/dev/null)

  # Check out the PR branch
  if ! err=$(git checkout "$head_branch" 2>&1); then
    log_error "git checkout $head_branch failed during rebase: $err"
    return 1
  fi

  if ! _rebase_with_retries "origin/staging"; then
    local conflicted_files
    conflicted_files=$(git diff --name-only --diff-filter=U 2>/dev/null)
    _safe_rebase_abort
    if ! _safe_checkout_back "$current_branch"; then
      # Worktree is now on $head_branch with no clear way back. Caller must
      # abort the wait loop — we cannot keep polling against an inconsistent
      # worktree.
      return 1
    fi

    jq -n \
      --arg branch "$head_branch" \
      --arg files "$conflicted_files" \
      '{branch: $branch, conflicted_files: ($files | split("\n") | map(select(length > 0)))}'
    return 1
  fi

  # Rebase succeeded locally, but publishing it requires rewriting the remote
  # branch. CLAUDE.md forbids all force-push variants from automated tooling,
  # so we refuse to push and surface the situation for an authorized human to
  # finish the rebase manually (or merge staging in instead).
  log_error "rebase succeeded locally for $head_branch; refusing to publish (CLAUDE.md forbids force-push). An authorized human must finish this rebase manually."
  _safe_checkout_back "$current_branch" || true
  return 1
}

# --- Main poll loop ---

rebase_attempted=false
unknown_count=0

while true; do
  elapsed=$(_elapsed)
  if [[ $elapsed -ge $timeout_seconds ]]; then
    log_error "timeout after ${timeout_minutes} minutes waiting for PR #${pr}"
    jq -n --arg pr "$pr" --argjson timeout "$timeout_minutes" \
      '{status: "timeout", pr: $pr, timeout_minutes: $timeout}'
    emit_ci_metric task "$pr" "timeout" '[]'
    exit 1
  fi

  # Check PR status
  if ! pr_data=$(_check_pr_status) || [[ -z "$pr_data" ]]; then
    log_warn "could not fetch PR #${pr} status (${_GH_LAST_ERROR:-empty response}); retrying in ${interval_seconds}s"
    sleep "$interval_seconds"
    continue
  fi

  state=$(printf '%s' "$pr_data" | jq -r '.state')
  merged_at=$(printf '%s' "$pr_data" | jq -r '.mergedAt')
  mergeable=$(printf '%s' "$pr_data" | jq -r '.mergeable')

  # Check if merged
  if [[ "$state" == "MERGED" ]] || [[ "$merged_at" != "null" && "$merged_at" != "" ]]; then
    log_info "PR #${pr} merged"
    jq -n --arg pr "$pr" --arg merged_at "$merged_at" \
      '{status: "merged", pr: $pr, merged_at: $merged_at}'
    emit_ci_metric task "$pr" "green" "${checks_data:-[]}"
    exit 0
  fi

  # Check if closed without merge
  if [[ "$state" == "CLOSED" ]]; then
    log_error "PR #${pr} closed without merge"
    jq -n --arg pr "$pr" '{status: "closed", pr: $pr}'
    exit 2
  fi

  # GitHub may return UNKNOWN for a few polls while it computes the merge
  # status (typical window: 5-30s after a push). Re-poll with a bounded
  # budget instead of treating UNKNOWN as a definitive state.
  if [[ "$mergeable" == "UNKNOWN" || -z "$mergeable" || "$mergeable" == "null" ]]; then
    unknown_count=$((unknown_count + 1))
    if (( unknown_count >= MERGEABLE_UNKNOWN_MAX )); then
      log_warn "PR #${pr} mergeable=UNKNOWN after $unknown_count polls — treating as CONFLICTING"
      mergeable="CONFLICTING"
    else
      log_info "PR #${pr} mergeable=UNKNOWN, waiting ($unknown_count/$MERGEABLE_UNKNOWN_MAX)"
      sleep 10
      continue
    fi
  else
    unknown_count=0
  fi

  # Check for merge conflicts
  if [[ "$mergeable" == "CONFLICTING" ]]; then
    if [[ "$rebase_attempted" == "true" ]]; then
      log_error "PR #${pr} has unresolvable merge conflict"
      jq -n --arg pr "$pr" '{status: "conflict", pr: $pr}'
      emit_ci_metric task "$pr" "red" '[]'
      exit 4
    fi

    rebase_attempted=true
    if ! _attempt_rebase "$pr_data"; then
      log_error "PR #${pr} rebase failed — conflict escalated"
      emit_ci_metric task "$pr" "red" '[]'
      exit 4
    fi

    # Check sooner after rebase
    sleep 10
    continue
  fi

  # Check CI status — exit 3 on failure so orchestrator can push a fix and re-invoke
  if ! checks_data=$(_check_pr_checks); then
    log_warn "could not fetch PR #${pr} checks (${_GH_LAST_ERROR:-empty response}); retrying in ${interval_seconds}s"
    sleep "$interval_seconds"
    continue
  fi
  if [[ -n "$checks_data" ]]; then
    # Treat any non-success terminal conclusion as red. GitHub uses several
    # conclusions for failure-equivalent states; restricting to FAILURE alone
    # silently ignored cancelled/timed-out/required runs.
    failed_checks=$(printf '%s' "$checks_data" | jq '[.[] | select(.conclusion == "FAILURE" or .conclusion == "CANCELLED" or .conclusion == "TIMED_OUT" or .conclusion == "STARTUP_FAILURE" or .conclusion == "ACTION_REQUIRED")] | length')

    if [[ "$failed_checks" -gt 0 ]]; then
      failed_names=$(printf '%s' "$checks_data" | jq -r '[.[] | select(.conclusion == "FAILURE" or .conclusion == "CANCELLED" or .conclusion == "TIMED_OUT" or .conclusion == "STARTUP_FAILURE" or .conclusion == "ACTION_REQUIRED") | "\(.name)=\(.conclusion)"] | join(", ")')
      log_error "PR #${pr} CI failed: $failed_names"
      jq -n \
        --arg pr "$pr" \
        --arg failed "$failed_names" \
        '{status: "ci_failed", pr: $pr, failed_checks: $failed}'
      emit_ci_metric task "$pr" "red" "$checks_data"
      exit 3
    fi

    # Distinguish "no checks defined" (defer to merge state) from "all passed".
    total_checks=$(printf '%s' "$checks_data" | jq 'length')
    pending_checks=$(printf '%s' "$checks_data" | jq '[.[] | select(.state == "IN_PROGRESS" or .state == "QUEUED" or .state == "PENDING")] | length')
    if (( total_checks == 0 )); then
      log_info "PR #${pr} has no checks defined; deferring to merge state"
    elif [[ "$pending_checks" -eq 0 ]]; then
      log_info "all $total_checks check(s) passed for PR #${pr}, waiting for merge..."
    fi
  fi

  remaining=$(( (timeout_seconds - elapsed) / 60 ))
  log_info "PR #${pr} state=$state mergeable=$mergeable — ${remaining}min remaining"
  sleep "$interval_seconds"
done
