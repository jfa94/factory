#!/usr/bin/env bash
# Classify task complexity → model/turns config.
# Usage: pipeline-classify-task <task-json>
# Exit: 0=success

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

task_json="${1:?missing task JSON}"

file_count=$(printf '%s' "$task_json" | jq '(.files // []) | length')
dep_count=$(printf '%s' "$task_json" | jq '(.depends_on // []) | length')

# File tier: 1=simple, 2=medium, 3+=complex
if [[ "$file_count" -le 1 ]]; then
  file_rank=0
elif [[ "$file_count" -le 2 ]]; then
  file_rank=1
else
  file_rank=2
fi

# Dep tier: 0=simple, 1-2=medium, 3+=complex
if [[ "$dep_count" -eq 0 ]]; then
  dep_rank=0
elif [[ "$dep_count" -le 2 ]]; then
  dep_rank=1
else
  dep_rank=2
fi

# Tier = max(file_rank, dep_rank)
if [[ "$file_rank" -ge "$dep_rank" ]]; then
  rank="$file_rank"
else
  rank="$dep_rank"
fi

case "$rank" in
  0) tier="simple"  ;;
  1) tier="medium"  ;;
  *) tier="complex" ;;
esac

# Model + maxTurns come from user config (with compiled-in defaults). This
# lets operators override the tier→model mapping and turn budgets without
# editing this script (task_16_09 / GAP-5).
case "$tier" in
  simple)
    model=$(read_config ".execution.modelByTier.simple" "haiku")
    max_turns=$(read_config ".execution.maxTurnsSimple" "40")
    ;;
  medium)
    model=$(read_config ".execution.modelByTier.medium" "sonnet")
    max_turns=$(read_config ".execution.maxTurnsMedium" "60")
    ;;
  complex)
    model=$(read_config ".execution.modelByTier.complex" "opus")
    max_turns=$(read_config ".execution.maxTurnsComplex" "80")
    ;;
esac

log_metric "task.classify" "tier=$tier" "model=\"$model\"" "max_turns=$max_turns" \
  "file_count=$file_count" "dep_count=$dep_count"

jq -n \
  --arg tier "$tier" \
  --arg model "$model" \
  --argjson maxTurns "$max_turns" \
  --arg reasoning "${file_count} file(s), ${dep_count} dep(s) → ${tier}" \
  '{tier: $tier, model: $model, maxTurns: $maxTurns, reasoning: $reasoning}'
