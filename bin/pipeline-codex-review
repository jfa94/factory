#!/usr/bin/env bash
# Codex exec wrapper for adversarial code review.
# Builds a review prompt, invokes `codex exec`, and maps Codex schema output
# to the normalized pipeline verdict JSON (same shape as pipeline-parse-review).
#
# Usage: pipeline-codex-review --base <ref> --task-id <id> --spec-dir <path>
# Exit: 0=success (normalized JSON on stdout), 1=failure

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq
require_command codex

PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# --- Arg parsing ---

base_ref="staging"
base_explicit=false
task_id=""
spec_dir=""
worktree=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --base)      base_ref="$2"; base_explicit=true; shift 2 ;;
    --task-id)   task_id="$2";  shift 2 ;;
    --spec-dir)  spec_dir="$2"; shift 2 ;;
    --worktree)  worktree="$2"; shift 2 ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

if [[ -z "$task_id" ]]; then
  log_error "--task-id is required"
  exit 1
fi

if [[ -n "$worktree" ]]; then
  if [[ ! -d "$worktree" ]]; then
    log_error "--worktree path does not exist or is not a directory: $worktree"
    exit 1
  fi
  if ! git -C "$worktree" rev-parse --show-toplevel >/dev/null 2>&1; then
    log_error "--worktree path is not a git repository: $worktree"
    exit 1
  fi
  cd "$worktree"
fi

if ! git rev-parse --verify "$base_ref" >/dev/null 2>&1; then
  if [[ "$base_explicit" == "false" ]] && git rev-parse --verify origin/staging >/dev/null 2>&1; then
    base_ref="origin/staging"
  else
    printf '{"ok":false,"error":"base_ref_not_found","base_ref":"%s"}\n' "$base_ref"
    exit 1
  fi
fi

# --- Build review prompt ---

schema_file="${PLUGIN_ROOT}/schemas/codex-review.schema.json"
if [[ ! -f "$schema_file" ]]; then
  log_error "output schema not found: $schema_file"
  exit 1
fi

skill_file="${PLUGIN_ROOT}/skills/review-protocol/SKILL.md"

# Gather diff (required)
diff_output=$(git diff --unified=5 "${base_ref}" HEAD 2>/dev/null) || {
  log_error "git diff failed (base ref: ${base_ref})"
  exit 1
}

if [[ -z "$diff_output" ]]; then
  log_warn "empty diff against ${base_ref} — nothing to review"
  jq -n \
    --arg task_id "$task_id" \
    --arg generator "pipeline-codex-review-v1" \
    '{
      verdict: "REQUEST_CHANGES",
      round: 1,
      confidence: "HIGH",
      findings: [],
      blocking_count: 0,
      non_blocking_count: 0,
      declared_blockers: 0,
      criteria_passed: 0,
      criteria_failed: 0,
      holdout_passed: 0,
      holdout_failed: 0,
      summary: "Empty diff: executor produced no commits; cannot review.",
      reviewer: "codex",
      generator: $generator
    }'
  exit 0
fi

# Build prompt file
prompt_file=$(temp_file ".prompt.md")
out_file=$(temp_file ".out.json")
diff_file=$(temp_file ".diff")
err_file=$(temp_file ".err.log")
# Per-invocation nonce makes UNTRUSTED fence tokens unguessable so injected
# content in a PRD or diff cannot close the fence and escape the trust boundary.
_review_nonce=$(LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom 2>/dev/null | head -c 16 || printf '%s' "$(date +%s%N)$$")
printf '%s\n' "$diff_output" > "$diff_file"
trap 'rm -f "$prompt_file" "$out_file" "$diff_file" "$err_file"' EXIT

{
  if [[ -f "$skill_file" ]]; then
    # Strip YAML frontmatter from skill file
    awk '/^---$/{n++; if(n==2){skip=0; next} else {skip=1; next}} !skip' "$skill_file"
    printf '\n\n---\n\n'
  fi

  printf '# Task: %s\n\n' "$task_id"

  # Per-task acceptance criteria extracted from tasks.json — presented before
  # the full spec dump so codex anchors scope to the structured list, not
  # narrative inference. tasks.json is authoritative; acceptance.md is context.
  if [[ -n "$spec_dir" && -f "${spec_dir}/tasks.json" ]]; then
    # Handle both schemas: bare-array root (outsidey) and {tasks:[...]} root.
    # `(.tasks // .)[]` errors on bare arrays (Cannot index array with string),
    # so discriminate on type first; matches the canonical .task_id field used
    # everywhere else (pipeline-run-task:246,624; SKILL.md:266).
    _task_ac=$(jq -r --arg id "$task_id" '
      (if type == "array" then .[] else (.tasks // [])[] end) |
      select(.task_id == $id) |
      (.acceptance_criteria // []) | map("- " + .) | join("\n")
    ' "${spec_dir}/tasks.json" 2>/dev/null || printf '')
    if [[ -n "$_task_ac" ]]; then
      printf '## Authoritative acceptance criteria for %s\n\n' "$task_id"
      printf 'Judge scope against THIS list, not narrative inference from spec.md.\n'
      printf 'Do not flag missing items that are not in this list.\n\n'
      printf '%s\n\n' "$_task_ac"
    fi
  fi

  # Spec files (acceptance criteria, holdout criteria) — wrapped in UNTRUSTED
  # fences so PRD content cannot inject reviewer instructions.
  if [[ -n "$spec_dir" && -d "$spec_dir" ]]; then
    for f in "${spec_dir}"/spec.md "${spec_dir}"/acceptance.md "${spec_dir}"/holdout.md; do
      if [[ -f "$f" ]]; then
        printf '<<<UNTRUSTED:SPEC:%s>>>\n' "$_review_nonce"
        printf '## %s\n\n' "$(basename "$f" .md)"
        cat "$f"
        printf '\n<<<END:UNTRUSTED:SPEC:%s>>>\n\n' "$_review_nonce"
      fi
    done
  fi

  printf '## Diff (base: %s)\n\n<<<UNTRUSTED:DIFF:%s>>>\n```diff\n' "$base_ref" "$_review_nonce"
  printf '%s\n' "$diff_output"
  printf '```\n<<<END:UNTRUSTED:DIFF:%s>>>\n\n' "$_review_nonce"

  printf '## Instructions\n\n'
  printf 'Review the diff above against the spec. Output ONLY valid JSON matching '
  printf 'the provided schema. Do not include any prose, markdown, or explanation '
  printf 'outside the JSON.\n\n'
  printf 'Map severity: critical/high findings are BLOCKING; medium/low are NON-BLOCKING.\n'
  printf 'Set overall_correctness to "patch is correct" only if there are zero BLOCKING findings.\n'
  printf 'When in conflict, the Authoritative acceptance criteria list above wins over narrative in spec.md.\n\n'
  printf 'Each finding MUST include verbatim_line — an exact 10+-character substring '
  printf 'copied verbatim from the diff above (a single line within a hunk, including '
  printf 'leading +/- if present). The harness drops findings whose verbatim_line does '
  printf 'not appear in the diff, so fabricating one is counterproductive — if you '
  printf 'cannot quote a real diff line for a finding, drop the finding.\n'
} > "$prompt_file"

# --- Sandbox support check (fail-closed: unsandboxed execution is not permitted) ---

if ! codex --help 2>&1 | grep -q -- '--sandbox'; then
  log_error "codex version does not support --sandbox flag — refusing to run unsandboxed. Upgrade codex."
  exit 1
fi

# --- Sandbox cascade: read-only → workspace-read (no unsandboxed fallback) ---

_run_codex() {
  local sandbox_flag="$1"
  local err_path="$2"
  local args=(exec
    --output-schema "$schema_file"
    --output-last-message "$out_file"
    --sandbox "$sandbox_flag")
  args+=(-)
  codex "${args[@]}" < "$prompt_file" >/dev/null 2>"$err_path"
}

if ! _run_codex "read-only" "$err_file"; then
  log_error "codex exec failed at read-only sandbox level (not retrying at lower isolation)"
  if [[ -s "$err_file" ]]; then
    log_error "codex stderr (tail 2KB): $(tail -c 2000 "$err_file")"
  fi
  exit 1
fi

if [[ ! -s "$out_file" ]]; then
  log_error "codex exec produced empty output"
  exit 1
fi

if ! jq empty "$out_file" 2>/dev/null; then
  log_error "codex output is not valid JSON"
  exit 1
fi

# --- Map Codex schema → normalized pipeline verdict JSON ---

jq -r '
  # Determine verdict from overall_correctness
  def verdict:
    if .overall_correctness == "patch is correct" then "APPROVE"
    else "REQUEST_CHANGES"
    end;

  # Classify confidence from overall_confidence_score
  def confidence:
    if .overall_confidence_score >= 0.8 then "HIGH"
    elif .overall_confidence_score >= 0.5 then "MEDIUM"
    else "LOW"
    end;

  # Is this finding blocking?
  def is_blocking(f): f.priority == "critical" or f.priority == "high";

  # Map findings to normalized shape
  def map_findings:
    [.findings[] | {
      title: .title,
      file: (.code_location.absolute_file_path // ""),
      severity: .priority,
      category: "codex",
      description: .body,
      suggestion: "",
      verbatim_line: (.verbatim_line // ""),
      blocking: (. | is_blocking(.))
    }];

  {
    verdict: verdict,
    round: 1,
    confidence: confidence,
    findings: map_findings,
    blocking_count: ([.findings[] | select(. | is_blocking(.))] | length),
    non_blocking_count: ([.findings[] | select(. | is_blocking(.) | not)] | length),
    declared_blockers: ([.findings[] | select(. | is_blocking(.))] | length),
    criteria_passed: 0,
    criteria_failed: 0,
    holdout_passed: 0,
    holdout_failed: 0,
    summary: (.overall_explanation // ""),
    reviewer: "codex",
    generator: "pipeline-codex-review-v1"
  }
' "$out_file" | validate_findings "$diff_file"
