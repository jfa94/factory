#!/usr/bin/env bash
# Run a project's quality commands and write a structured result to state.
# Usage: pipeline-quality-gate <run-id> <task-id> [<worktree>]
#
# Discovers the command list from package.json `factory.quality` (an array
# of npm script names), or falls back to ["lint","typecheck","test"]. Each
# command is executed with the detected package manager; per-command stdout
# and stderr are captured to a log file in the run directory so reviewers can
# inspect failures without re-running.
#
# Output: structured JSON on stdout — `{ok: bool, checks: [{command, status,
# duration_s, log}]}` — and the same object written to state under
# `.tasks.<task-id>.quality_gate`. Exit 0 if every check passed, 1 otherwise.

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

run_id="${1:?missing run-id}"
task_id="${2:?missing task-id}"
worktree="${3:-$PWD}"

if [[ ! -d "$worktree" ]]; then
  log_error "worktree does not exist: $worktree"
  printf '{"ok":false,"error":"worktree_missing","checks":[]}\n'
  exit 1
fi

cd "$worktree"

if [[ ! -f package.json ]]; then
  log_info "no package.json in $worktree — quality gate not applicable; recording skipped"
  result='{"ok":true,"skipped":true,"reason":"no-package-json","checks":[]}'
  run_dir="${CLAUDE_PLUGIN_DATA}/runs/${run_id}"
  if [[ -f "$run_dir/state.json" ]]; then
    if ! pipeline-state task-write "$run_id" "$task_id" quality_gate "$result" >/dev/null; then
      log_error "failed to record quality_gate result for $task_id (state.json present but write failed)"
      exit 1
    fi
  fi
  printf '%s\n' "$result"
  exit 0
fi

pkg_mgr=$(detect_pkg_manager "$worktree")

# Discover the command list. Prefer the factory.quality override; fall
# back to npm scripts that actually exist (lint / typecheck|tsc /
# test:coverage|test). Skip cleanly if none are configured — a JS repo
# without any quality scripts is a real config, not a failure.
commands=$(jq -r '.["factory"].quality // empty | .[]?' package.json 2>/dev/null || true)
if [[ -z "$commands" ]]; then
  commands=""
  jq -e '.scripts.lint' package.json >/dev/null 2>&1 && commands+="lint"$'\n'
  jq -e '.scripts.typecheck // .scripts.tsc' package.json >/dev/null 2>&1 && commands+="typecheck"$'\n'
  jq -e '.scripts."test:coverage" // .scripts.test' package.json >/dev/null 2>&1 && commands+="test:coverage"$'\n'
  if [[ -z "$commands" ]]; then
    log_info "no factory.quality override and no recognized scripts in $worktree — skipping"
    result='{"ok":true,"skipped":true,"reason":"no-quality-scripts","checks":[]}'
    run_dir="${CLAUDE_PLUGIN_DATA}/runs/${run_id}"
    if [[ -f "$run_dir/state.json" ]]; then
      if ! pipeline-state task-write "$run_id" "$task_id" quality_gate "$result" >/dev/null; then
        log_error "failed to record quality_gate result for $task_id (state.json present but write failed)"
        exit 1
      fi
    fi
    printf '%s\n' "$result"
    exit 0
  fi
fi

run_dir="${CLAUDE_PLUGIN_DATA}/runs/${run_id}"
mkdir -p "$run_dir"

# Determine attempt number for log file naming (preserves per-attempt forensics).
# Falls back to timestamp when state is unavailable (e.g. test fixtures without state.json).
_attempt_raw=$(pipeline-state task-read "$run_id" "$task_id" review_attempts 2>/dev/null || printf 'err')
if [[ "$_attempt_raw" == "err" || -z "$_attempt_raw" || "$_attempt_raw" == "null" ]]; then
  _log_suffix=$(date +%s)
else
  _log_suffix="$_attempt_raw"
fi

results_json='[]'
overall_ok=true

while IFS= read -r cmd; do
  [[ -z "$cmd" ]] && continue

  # Include attempt (or timestamp fallback) in filename so re-runs don't overwrite prior logs.
  log_file="$run_dir/${task_id}.${cmd}.${_log_suffix}.log"
  start=$(date +%s)
  set +e
  "$pkg_mgr" run "$cmd" > "$log_file" 2>&1
  rc=$?
  set -e
  duration=$(( $(date +%s) - start ))

  if [[ $rc -eq 0 ]]; then
    status="passed"
  else
    status="failed"
    overall_ok=false
  fi

  results_json=$(printf '%s' "$results_json" | jq \
    --arg c "$cmd" \
    --arg s "$status" \
    --arg log "$log_file" \
    --argjson d "$duration" \
    '. + [{command:$c, status:$s, duration_s:$d, log:$log}]')
done <<< "$commands"

if [[ "$overall_ok" == "true" ]]; then
  ok_json=true
else
  ok_json=false
fi

summary=$(jq -n --argjson ok "$ok_json" --argjson checks "$results_json" \
  '{ok:$ok, checks:$checks}')

# Write to state. If state.json exists, the write must succeed — silently
# discarding it would leave the orchestrator's view of the run inconsistent
# with what actually ran. Test fixtures that set up a run dir without a
# state.json (e.g. integration tests for this script in isolation) are the
# only legitimate skip path.
if [[ -f "$run_dir/state.json" ]]; then
  if ! pipeline-state task-write "$run_id" "$task_id" quality_gate "$summary" >/dev/null; then
    log_error "failed to record quality_gate result for $task_id"
    exit 1
  fi
fi

printf '%s\n' "$summary"

log_metric "task.gate.quality" "task_id=\"$task_id\"" \
  "status=\"$([[ "$overall_ok" == "true" ]] && echo pass || echo fail)\""

if [[ "$overall_ok" == "true" ]]; then
  exit 0
else
  exit 1
fi
