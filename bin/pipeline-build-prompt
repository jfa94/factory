#!/usr/bin/env bash
# Build structured prompt for task executor.
# Usage:
#   pipeline-build-prompt <task-json> [<spec-path>] [--spec-path <path>] [--holdout <percent>] [--fix-instructions <json>]
#
# spec-path resolution order:
#   1. --spec-path flag
#   2. positional 2nd argument (legacy form)
#   3. .spec.path on the current run's state.json (via current_run_id)
# If none of these yields a usable path, the spec section is emitted empty with
# a pointer for the executor to fetch it from `origin/staging`.
# Exit: 0=success

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

task_json="${1:?missing task JSON}"
shift

spec_path=""
# Legacy positional form: pipeline-build-prompt <task-json> <spec-path>
if [[ $# -gt 0 && "$1" != --* ]]; then
  spec_path="$1"
  shift
fi

holdout_percent=0
fix_instructions=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --spec-path) spec_path="$2"; shift 2 ;;
    --holdout) holdout_percent="$2"; shift 2 ;;
    --fix-instructions) fix_instructions="$2"; shift 2 ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

# If still unset, resolve via current run's state.json (.spec.path).
if [[ -z "$spec_path" ]]; then
  state_run_id=$(current_run_id 2>/dev/null || true)
  if [[ -n "${state_run_id:-}" ]]; then
    resolved=$(pipeline-state read "$state_run_id" '.spec.path' 2>/dev/null || true)
    # jq renders missing keys as literal "null"; treat that as absent
    if [[ -n "$resolved" && "$resolved" != "null" ]]; then
      spec_path="$resolved"
    fi
  fi
fi

# Parse task metadata
task_id=$(printf '%s' "$task_json" | jq -r '.task_id')
title=$(printf '%s' "$task_json" | jq -r '.title')
description=$(printf '%s' "$task_json" | jq -r '.description')
files=$(printf '%s' "$task_json" | jq -r '(.files // []) | join(", ")')
tests_to_write=$(printf '%s' "$task_json" | jq -r '(.tests_to_write // []) | map("- " + .) | join("\n")')

# Get acceptance criteria
all_criteria=$(printf '%s' "$task_json" | jq '(.acceptance_criteria // [])')
total_criteria=$(printf '%s' "$all_criteria" | jq 'length')

# Handle holdout
visible_criteria="$all_criteria"
if [[ "$holdout_percent" -gt 0 ]] && [[ "$total_criteria" -gt 1 ]]; then
  holdout_count=$(( total_criteria * holdout_percent / 100 ))
  [[ "$holdout_count" -lt 1 ]] && holdout_count=1
  [[ "$holdout_count" -ge "$total_criteria" ]] && holdout_count=$(( total_criteria - 1 ))

  # Generate shuffled indices via awk (proper PRNG, avoids jq linear-hash bias)
  holdout_indices=$(awk -v n="$total_criteria" -v k="$holdout_count" '
    BEGIN {
      srand()
      for (i = 0; i < n; i++) a[i] = i
      for (i = n - 1; i > 0; i--) {
        j = int(rand() * (i + 1))
        tmp = a[i]; a[i] = a[j]; a[j] = tmp
      }
      for (i = 0; i < k; i++) printf "%d\n", a[i]
    }
  ' | jq -R -s 'split("\n") | map(select(length > 0) | tonumber)')

  holdout_criteria=$(printf '%s' "$all_criteria" | jq --argjson idx "$holdout_indices" '
    [to_entries[] | select(.key as $k | $idx | index($k) != null) | .value]
  ')
  visible_criteria=$(printf '%s' "$all_criteria" | jq --argjson idx "$holdout_indices" '
    [to_entries[] | select(.key as $k | $idx | index($k) == null) | .value]
  ')

  # Save holdout to file (only if active run exists)
  run_id=$(current_run_id 2>/dev/null) || true
  if [[ -z "$run_id" ]]; then
    log_warn "no active run, holdout file not saved"
  else
    holdout_dir="${CLAUDE_PLUGIN_DATA}/runs/${run_id}/holdouts"
    mkdir -p "$holdout_dir"
    jq -n \
      --arg task_id "$task_id" \
      --argjson criteria "$holdout_criteria" \
      --argjson total "$total_criteria" \
      --argjson withheld "$holdout_count" \
      '{task_id: $task_id, withheld_criteria: $criteria, total_criteria: $total, withheld_count: $withheld}' \
      > "$holdout_dir/${task_id}.json"
  fi

  log_info "holdout: withheld $holdout_count of $total_criteria criteria for $task_id"
fi

# Resolve spec location into an absolute path (task-executor runs in a different
# worktree, so relative paths are meaningless to it).
resolved_spec_abs=""
if [[ -n "$spec_path" ]]; then
  if [[ -d "$spec_path" ]]; then
    resolved_spec_abs=$(cd "$spec_path" 2>/dev/null && pwd) || resolved_spec_abs="$spec_path"
  elif [[ -f "$spec_path" ]]; then
    resolved_spec_abs=$(cd "$(dirname "$spec_path")" 2>/dev/null && pwd)/$(basename "$spec_path") || resolved_spec_abs="$spec_path"
  else
    resolved_spec_abs="$spec_path"
  fi
fi

# Read spec content
spec_content=""
if [[ -f "$spec_path/spec.md" ]]; then
  spec_content=$(<"$spec_path/spec.md")
elif [[ -f "$spec_path" ]]; then
  spec_content=$(<"$spec_path")
fi

# Format criteria list
criteria_list=$(printf '%s' "$visible_criteria" | jq -r '.[] | "- " + .')

# Detect prior work (commits ahead of staging)
prior_work=""
if git rev-parse --git-dir &>/dev/null; then
  ahead=$(git log staging..HEAD --oneline 2>/dev/null || true)
  if [[ -n "$ahead" ]]; then
    prior_work="
## Prior Work
The following commits already exist on this branch. Do NOT redo this work:
\`\`\`
${ahead}
\`\`\`
Review the existing changes before implementing anything new."
  fi
fi

# Build prompt
prompt="# Task: ${title}

## Task ID
${task_id}

## Description
${description}

## Files to Modify
${files}

## Acceptance Criteria
${criteria_list}

## Tests to Write
${tests_to_write}

## Spec Location
${resolved_spec_abs}

Read the spec directly via one of:
  git fetch origin staging && git show origin/staging:${resolved_spec_abs#${PWD}/}/spec.md
  (or, if running on the orchestrator filesystem) ${resolved_spec_abs}/spec.md

## Spec Context
${spec_content}
${prior_work}"

# Append fix instructions if provided
if [[ -n "$fix_instructions" ]]; then
  findings=$(printf '%s' "$fix_instructions" | jq -r '
    .findings // [] | .[] | "- [\(.severity // "unknown")] \(.title // "untitled"): \(.description // "no description")"
  ' 2>/dev/null || echo "$fix_instructions")
  prompt+="

## Review Feedback (Fix Required)
The following issues were found in a previous review. Address ALL blocking findings:

${findings}"
fi

printf '%s' "$prompt"
