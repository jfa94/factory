#!/usr/bin/env bash
# Post structured comments and labels to GitHub issues.
# Usage: pipeline-gh-comment <issue-number> <comment-type> [--repo owner/name] [--update] [--data <json>]
# Comment types: spec-failure, run-summary, ci-escalation, conflict-escalated, review-escalation, human-gate, final-rollup-pending
# Exit: 0=success, 1=failure

source "$(dirname "$0")/pipeline-lib.sh"
require_command gh
require_command jq

issue="${1:?missing issue number}"
comment_type="${2:?missing comment type}"
shift 2

# Validate issue is numeric
if ! [[ "$issue" =~ ^[0-9]+$ ]]; then
  log_error "invalid issue number: $issue"
  exit 1
fi

update=false
data="{}"
repo_override=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --update) update=true; shift ;;
    --data) data="$2"; shift 2 ;;
    --repo) repo_override="$2"; shift 2 ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

# Resolve owner/repo explicitly
if [[ -n "$repo_override" ]]; then
  REPO_SLUG="$repo_override"
elif REPO_SLUG=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null) && [[ -n "$REPO_SLUG" ]]; then
  :
else
  log_error "could not resolve repository — pass --repo owner/name or run from a git checkout"
  exit 1
fi

# Validate comment type
case "$comment_type" in
  spec-failure|run-summary|ci-escalation|conflict-escalated|review-escalation|human-gate|final-rollup-pending) ;;
  *) log_error "invalid comment type: $comment_type"; exit 1 ;;
esac

# Marker for deduplication
MARKER="<!-- dark-factory:${comment_type} -->"

_build_body() {
  local body=""
  case "$comment_type" in
    spec-failure)
      local reason
      reason=$(printf '%s' "$data" | jq -r '.reason // "unknown"')
      local run_id
      run_id=$(printf '%s' "$data" | jq -r '.run_id // "unknown"')
      body="${MARKER}
## Spec Generation Failed

**Run:** \`${run_id}\`
**Reason:** ${reason}

The autonomous pipeline was unable to generate a valid spec from this PRD after exhausting all retries.

### Next Steps
1. Review the PRD for clarity and completeness
2. Run the pipeline again with \`/factory:run prd --issue ${issue}\`
3. Or create the spec manually and run \`/factory:run task --spec-dir <path>\`

---
*Posted by dark-factory pipeline*"
      ;;

    human-gate)
      local gate_run_id gate_stage gate_level gate_threshold
      gate_run_id=$(printf '%s' "$data" | jq -r '.run_id // "unknown"')
      gate_stage=$(printf '%s' "$data" | jq -r '.stage // "unknown"')
      gate_level=$(printf '%s' "$data" | jq -r '.humanReviewLevel // 1')
      gate_threshold=$(printf '%s' "$data" | jq -r '.threshold // 1')
      body="${MARKER}
## Pipeline Paused — Human Approval Required

**Run:** \`${gate_run_id}\`
**Stage:** \`${gate_stage}\`
**humanReviewLevel:** ${gate_level} (threshold for this stage: ${gate_threshold})

The pipeline reached a checkpoint that requires your approval because \`humanReviewLevel >= ${gate_threshold}\` for stage \`${gate_stage}\`.

### Next Steps
1. Inspect the run state under \`runs/${gate_run_id}/\` and the latest changes
2. Approve by resuming: \`/factory:run resume\`
3. Or lower \`humanReviewLevel\` via \`/factory:configure\` to let the pipeline proceed automatically in the future

---
*Posted by dark-factory pipeline*"
      ;;

    run-summary)
      local summary
      summary=$(printf '%s' "$data" | jq -r '.summary // "no summary available"')
      local status
      status=$(printf '%s' "$data" | jq -r '.status // "unknown"')
      local tasks_done
      tasks_done=$(printf '%s' "$data" | jq -r '.tasks_done // 0')
      local tasks_total
      tasks_total=$(printf '%s' "$data" | jq -r '.tasks_total // 0')
      body="${MARKER}
## Pipeline Run Summary

**Status:** ${status}
**Tasks:** ${tasks_done}/${tasks_total} completed

${summary}

---
*Posted by dark-factory pipeline*"
      ;;

    ci-escalation)
      local log_excerpt
      log_excerpt=$(printf '%s' "$data" | jq -r '.log_excerpt // "no log available"')
      local pr_number
      pr_number=$(printf '%s' "$data" | jq -r '.pr_number // "unknown"')
      local attempts
      attempts=$(printf '%s' "$data" | jq -r '.attempts // 0')
      body="${MARKER}
## CI Failure — Manual Fix Required

**PR:** #${pr_number}
**Auto-fix attempts:** ${attempts}

The pipeline attempted to fix CI failures automatically but was unable to resolve them.

<details>
<summary>CI Log Excerpt</summary>

\`\`\`
${log_excerpt}
\`\`\`

</details>

### Next Steps
1. Check the CI logs for the full error
2. Fix the issue locally and push
3. Resume the pipeline with \`/factory:run resume\`

---
*Posted by dark-factory pipeline*"
      ;;

    review-escalation)
      local run_id task_id review_attempts verdict reason
      run_id=$(printf '%s' "$data" | jq -r '.run_id // "unknown"')
      task_id=$(printf '%s' "$data" | jq -r '.task_id // "unknown"')
      review_attempts=$(printf '%s' "$data" | jq -r '.review_attempts // 0')
      verdict=$(printf '%s' "$data" | jq -r '.verdict // "unknown"')
      reason=$(printf '%s' "$data" | jq -r '.reason // "adversarial reviewer blocked merge"')
      body="${MARKER}
## Review Escalation — Human Attention Required

**Run:** \`${run_id}\`
**Task:** \`${task_id}\`
**Review attempts:** ${review_attempts}
**Final verdict:** ${verdict}

${reason}

The adversarial reviewer could not be satisfied after the configured number of fix attempts, or returned a \`NEEDS_DISCUSSION\` verdict. This task has been marked \`needs_human_review\`.

### Next Steps
1. Inspect the full review transcripts under \`runs/${run_id}/reviews/${task_id}/\`
2. Either hand-edit the task branch \`task/${task_id}\` and push a resolution, or re-scope the task in the PRD
3. Resume the pipeline with \`/factory:run resume\`

---
*Posted by dark-factory pipeline*"
      ;;

    final-rollup-pending)
      local rp_run_id rp_summary_url
      rp_run_id=$(printf '%s' "$data" | jq -r '.run_id // "unknown"')
      rp_summary_url=$(printf '%s' "$data" | jq -r '.summary_url // ""')
      body="${MARKER}
## Final Rollup PR — Human Approval Required

**Run:** \`${rp_run_id}\`

All task PRs merged into \`staging\` and scribe finished any doc updates. The rollup PR from \`staging\` to \`develop\` was not opened automatically because \`humanReviewLevel >= 2\`.

### Next Steps
1. Inspect the staged changes on the \`staging\` branch
2. Open the rollup PR manually: \`gh pr create --base develop --head staging\`
3. Or lower \`humanReviewLevel\` via \`/factory:configure\` to let the pipeline open the rollup PR automatically
${rp_summary_url:+
Run summary: ${rp_summary_url}}

---
*Posted by factory pipeline*"
      ;;

    conflict-escalated)
      local files
      files=$(printf '%s' "$data" | jq -r '.files // [] | join("\n- ")' 2>/dev/null)
      local branch
      branch=$(printf '%s' "$data" | jq -r '.branch // "unknown"')
      body="${MARKER}
## Merge Conflict — Manual Resolution Required

**Branch:** \`${branch}\`

The pipeline attempted to rebase but encountered conflicts that could not be auto-resolved.

**Conflicting files:**
- ${files}

### Next Steps
1. Check out the branch: \`git checkout ${branch}\`
2. Rebase onto staging: \`git rebase staging\`
3. Resolve conflicts and push
4. Resume the pipeline with \`/factory:run resume\`

---
*Posted by dark-factory pipeline*"
      ;;
  esac

  printf '%s' "$body"
}

body=$(_build_body)

# Add labels for specific types
case "$comment_type" in
  spec-failure)
    gh issue edit "$issue" --repo "$REPO_SLUG" --add-label "needs-manual-spec" 2>/dev/null || \
      log_warn "could not add label 'needs-manual-spec' (may not exist)"
    ;;
esac

# Check for existing comment to update
if [[ "$update" == "true" ]]; then
  existing_id=$(gh api "repos/${REPO_SLUG}/issues/${issue}/comments" \
    --jq "[.[] | select(.body | contains(\"${MARKER}\")) | .id] | first // empty" 2>/dev/null)

  if [[ -n "$existing_id" ]]; then
    gh api "repos/${REPO_SLUG}/issues/comments/${existing_id}" \
      -X PATCH \
      -f body="$body" &>/dev/null
    log_info "updated existing $comment_type comment on issue $issue"
    json_output action "updated" issue "$issue" type "$comment_type" comment_id "$existing_id"
    exit 0
  fi
fi

# Post new comment
gh issue comment "$issue" --repo "$REPO_SLUG" --body "$body" &>/dev/null || {
  log_error "failed to post comment on issue $issue"
  exit 1
}

log_info "posted $comment_type comment on issue $issue"
json_output action "created" issue "$issue" type "$comment_type"
