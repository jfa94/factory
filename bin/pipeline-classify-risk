#!/usr/bin/env bash
# Classify task risk from file paths → review rounds + extra reviewers.
# Usage: pipeline-classify-risk <task-json>
# Exit: 0=success

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

task_json="${1:?missing task JSON}"

files=$(printf '%s' "$task_json" | jq -r '(.files // [])[]')

tier="routine"
tier_trigger=""
matched=()

while IFS= read -r file; do
  [[ -z "$file" ]] && continue

  pattern=""
  new_tier=""
  case "$file" in
    auth/*|*/auth/*)                     pattern="auth/*";            new_tier="security" ;;
    security/*|*/security/*)             pattern="security/*";        new_tier="security" ;;
    migration/*|*/migration/*)           pattern="migration/*";       new_tier="security" ;;
    payment/*|*/payment/*)               pattern="payment/*";         new_tier="security" ;;
    crypto/*|*/crypto/*)                 pattern="crypto/*";          new_tier="security" ;;
    .env|.env.*|*/.env|*/.env.*)         pattern=".env*";             new_tier="security" ;;
    middleware/auth*|*/middleware/auth*)  pattern="middleware/auth*";   new_tier="security" ;;
    api/*|*/api/*)                       pattern="api/*";             new_tier="feature" ;;
    routes/*|*/routes/*)                 pattern="routes/*";          new_tier="feature" ;;
    models/*|*/models/*)                 pattern="models/*";          new_tier="feature" ;;
    services/*|*/services/*)             pattern="services/*";        new_tier="feature" ;;
    hooks/*|*/hooks/*)                   pattern="hooks/*";           new_tier="feature" ;;
  esac

  [[ -n "$pattern" ]] && matched+=("$pattern")

  if [[ "$new_tier" == "security" && "$tier" != "security" ]]; then
    tier="security"; tier_trigger="$file"
  elif [[ "$new_tier" == "feature" && "$tier" == "routine" ]]; then
    tier="feature"; tier_trigger="$file"
  fi
done <<< "$files"

case "$tier" in
  security) review_rounds=6; extra_reviewers='["security-reviewer","architecture-reviewer"]' ;;
  feature)  review_rounds=4; extra_reviewers='["architecture-reviewer"]' ;;
  routine)  review_rounds=2; extra_reviewers='[]' ;;
esac

if [[ ${#matched[@]} -gt 0 ]]; then
  matched_json=$(printf '%s\n' "${matched[@]}" | jq -R -s 'split("\n") | map(select(length > 0)) | unique')
else
  matched_json='[]'
fi

if [[ -n "$tier_trigger" ]]; then
  reasoning_str="${tier_trigger} → ${tier} tier"
else
  reasoning_str="no matching patterns → ${tier} tier"
fi

jq -n \
  --arg tier "$tier" \
  --argjson review_rounds "$review_rounds" \
  --argjson extra_reviewers "$extra_reviewers" \
  --argjson matched_patterns "$matched_json" \
  --arg reasoning "$reasoning_str" \
  '{tier: $tier, review_rounds: $review_rounds, extra_reviewers: $extra_reviewers, matched_patterns: $matched_patterns, reasoning: $reasoning}'
