#!/usr/bin/env bash
# Branch and worktree management for pipeline.
# Usage: pipeline-branch <action> [options]
# Actions: staging-init, commit-spec, create, worktree-create, worktree-remove, exists, naming, task-commit
# Exit: 0=success, 1=failure

source "$(dirname "$0")/pipeline-lib.sh"
require_command git

action="${1:?missing action}"
shift

case "$action" in
  staging-init)
    base_branch="${DARK_FACTORY_BASE_BRANCH:-develop}"
    reconcile_status="skipped"

    if git ls-remote --exit-code --heads origin staging &>/dev/null; then
      git fetch origin staging &>/dev/null || true
      git checkout staging &>/dev/null
      git pull origin staging &>/dev/null || true

      # Reconcile staging with base branch to prevent drift between runs.
      # Fast-forward if possible, otherwise non-ff merge, otherwise fail cleanly.
      base_ref=""
      if git ls-remote --exit-code --heads origin "$base_branch" &>/dev/null; then
        git fetch origin "$base_branch" &>/dev/null || true
        base_ref="origin/$base_branch"
      elif git rev-parse --verify "$base_branch" >/dev/null 2>&1; then
        base_ref="$base_branch"
      fi

      if [[ -n "$base_ref" ]]; then
        behind=$(git rev-list --count "HEAD..$base_ref" 2>/dev/null || echo 0)
        if [[ "$behind" -eq 0 ]]; then
          reconcile_status="up-to-date"
        elif git merge --ff-only "$base_ref" --quiet &>/dev/null; then
          reconcile_status="fast-forwarded"
        elif git -c user.email=dark-factory@local \
                 -c user.name="dark-factory" \
                 merge --no-ff "$base_ref" \
                 -m "chore: reconcile staging with $base_branch" --quiet &>/dev/null; then
          reconcile_status="merged"
        else
          git merge --abort &>/dev/null || true
          json_output error "staging_reconcile_conflict" \
                      base "$base_branch" \
                      behind "$behind"
          exit 1
        fi
      fi

      json_output staging_branch "staging" \
                  base "existing" \
                  created "false" \
                  reconcile "$reconcile_status"
    else
      if git ls-remote --exit-code --heads origin "$base_branch" &>/dev/null; then
        base="$base_branch"
        git fetch origin "$base_branch" &>/dev/null
        git checkout -b staging "origin/$base_branch" &>/dev/null
      else
        base="main"
        git fetch origin main &>/dev/null
        git checkout -b staging "origin/main" &>/dev/null
      fi
      git push -u origin staging &>/dev/null || true
      json_output staging_branch "staging" \
                  base "$base" \
                  created "true" \
                  reconcile "fresh"
    fi
    ;;

  commit-spec)
    spec_dir="${1:?missing spec dir}"
    if [[ ! -d "$spec_dir" ]]; then
      log_error "spec dir not found: $spec_dir"
      exit 1
    fi

    # Must be on staging (let the orchestrator decide when to call this).
    current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
    if [[ "$current_branch" != "staging" ]]; then
      git checkout staging &>/dev/null || {
        log_error "cannot checkout staging branch"
        exit 1
      }
    fi

    git add -- "$spec_dir" 2>/dev/null || true

    if git diff --cached --quiet 2>/dev/null; then
      json_output action "commit-spec" \
                  result "no-op" \
                  spec_dir "$spec_dir" \
                  branch "staging"
    else
      git -c user.email=dark-factory@local \
          -c user.name="dark-factory" \
          commit -m "chore: add spec directory $spec_dir" --quiet
      sha=$(git rev-parse HEAD)
      json_output action "commit-spec" \
                  result "committed" \
                  spec_dir "$spec_dir" \
                  branch "staging" \
                  sha "$sha"
    fi
    ;;

  create)
    name="${1:?missing branch name}"
    shift
    base="staging"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --base) base="$2"; shift 2 ;;
        *) log_error "unknown flag: $1"; exit 1 ;;
      esac
    done

    _create_resume_rebase() {
      # Try to rebase onto $base; emit a structured action=conflict on failure.
      # Route git's own stderr to the script's stderr via log_* so it never
      # contaminates the JSON on stdout.
      if ! git rebase "$base" >&2; then
        git rebase --abort >&2 2>/dev/null || true
        json_output branch "$name" base "$base" action "conflict" \
                    error "rebase_conflict"
        exit 1
      fi
    }

    if git show-ref --verify --quiet "refs/heads/$name"; then
      # Local branch exists — resume path: check out + rebase.
      if ! git checkout "$name" >&2; then
        json_output branch "$name" base "$base" action "checkout_failed" \
                    error "checkout_failed"
        exit 1
      fi
      _create_resume_rebase
      json_output branch "$name" base "$base" action "resumed"
    elif git ls-remote --exit-code --heads origin "$name" &>/dev/null; then
      # Remote-only branch — fetch, track, rebase.
      if ! git fetch origin "$name" >&2; then
        json_output branch "$name" base "$base" action "fetch_failed" \
                    error "fetch_failed"
        exit 1
      fi
      if ! git checkout -b "$name" "origin/$name" >&2; then
        json_output branch "$name" base "$base" action "checkout_failed" \
                    error "checkout_failed"
        exit 1
      fi
      _create_resume_rebase
      json_output branch "$name" base "$base" action "resumed"
    else
      # Fresh branch from base.
      if ! git checkout -b "$name" "$base" >&2; then
        json_output branch "$name" base "$base" action "create_failed" \
                    error "checkout_failed"
        exit 1
      fi
      json_output branch "$name" base "$base" action "created"
    fi
    ;;

  worktree-create)
    name="${1:?missing branch name}"
    path="${2:?missing worktree path}"
    base="${3:-staging}"
    git worktree add -b "$name" "$path" "$base" &>/dev/null
    json_output branch "$name" path "$path" base "$base" action "created"
    ;;

  worktree-remove)
    path="${1:?missing worktree path}"
    git worktree remove "$path" &>/dev/null || {
      log_warn "force-removing worktree at $path"
      git worktree remove --force "$path" &>/dev/null
    }
    json_output path "$path" action "removed"
    ;;

  exists)
    name="${1:?missing branch name}"
    if git show-ref --verify --quiet "refs/heads/$name" 2>/dev/null; then
      exit 0
    elif git ls-remote --exit-code --heads origin "$name" &>/dev/null; then
      exit 0
    else
      exit 1
    fi
    ;;

  naming)
    task_id="${1:?missing task-id}"
    issue="${2:?missing issue number}"
    slug=$(slugify "$task_id")
    printf 'dark-factory/%s/%s' "$issue" "$slug"
    ;;

  task-commit)
    task_id="${1:?missing task-id}"
    shift
    worktree=""
    message=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --worktree) worktree="$2"; shift 2 ;;
        --message)  message="$2";  shift 2 ;;
        *) log_error "unknown flag: $1"; exit 1 ;;
      esac
    done
    if [[ -z "$worktree" ]]; then
      log_error "task-commit requires --worktree <path>"
      exit 1
    fi
    if [[ ! -d "$worktree" ]]; then
      log_error "worktree path does not exist: $worktree"
      exit 1
    fi

    expected_branch="task/${task_id}"
    current_branch=$(git -C "$worktree" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
    if [[ "$current_branch" != "$expected_branch" ]]; then
      log_error "worktree is on branch '$current_branch', expected '$expected_branch'"
      exit 1
    fi

    git -C "$worktree" add -A 2>/dev/null || true

    if git -C "$worktree" diff --cached --quiet 2>/dev/null; then
      json_output action "task-commit" \
                  result "no-op" \
                  task_id "$task_id" \
                  branch "$expected_branch"
    else
      if [[ -z "$message" ]]; then
        message="chore(dark-factory): finalize task ${task_id}"
      fi
      git -C "$worktree" \
          -c user.email=dark-factory@local \
          -c user.name="dark-factory" \
          commit -m "$message" --quiet
      sha=$(git -C "$worktree" rev-parse HEAD)
      json_output action "task-commit" \
                  result "committed" \
                  task_id "$task_id" \
                  branch "$expected_branch" \
                  sha "$sha"
    fi
    ;;

  *)
    log_error "unknown action: $action"
    echo "Usage: pipeline-branch <staging-init|commit-spec|create|worktree-create|worktree-remove|exists|naming|task-commit> [options]" >&2
    exit 1
    ;;
esac
