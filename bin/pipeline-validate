#!/usr/bin/env bash
# Pre-flight validation: checks git, gh auth, required agents/skills, data dir.
# Usage: pipeline-validate [--strict] [--no-clean-check]
# Exit: 0=all pass, 1=failure

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

strict=false
clean_check=true

while [[ $# -gt 0 ]]; do
  case "$1" in
    --strict) strict=true; shift ;;
    --no-clean-check) clean_check=false; shift ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

checks=()
failed=false

_add_check() {
  local name="$1" status="$2" detail="$3"
  checks+=("$(jq -n --arg n "$name" --arg s "$status" --arg d "$detail" \
    '{name: $n, status: $s, detail: $d}')")
  if [[ "$status" == "fail" ]]; then
    failed=true
    log_error "check failed: $name — $detail"
  fi
}

# 1. Git remote
if git remote get-url origin &>/dev/null; then
  _add_check "git_remote" "pass" "origin configured"
else
  _add_check "git_remote" "fail" "no git remote 'origin' configured"
fi

# 2. Clean working tree
if [[ "$clean_check" == "true" ]]; then
  if [[ -z "$(git status --porcelain 2>/dev/null)" ]]; then
    _add_check "clean_tree" "pass" "working tree clean"
  else
    _add_check "clean_tree" "fail" "uncommitted changes in working tree"
  fi
else
  _add_check "clean_tree" "skip" "skipped via --no-clean-check"
fi

# 3. gh installed + authenticated
if ! command -v gh &>/dev/null; then
  _add_check "gh_cli" "fail" "gh CLI not installed"
elif ! gh auth status &>/dev/null; then
  _add_check "gh_cli" "fail" "gh not authenticated — run 'gh auth login'"
else
  _add_check "gh_cli" "pass" "gh installed and authenticated"
fi

# 4. Required agents — bundled by plugin (spec-reviewer, quality-reviewer, implementation-reviewer, etc.)
# No user-side check needed: plugin install guarantees presence.

# 5. Required skills — check project-local, home-global, and plugin-bundled
_found_skill=""
_plugin_root="$(cd "$(dirname "$0")/.." 2>/dev/null && pwd)"
for loc in ".claude/skills/prd-to-spec" "$HOME/.claude/skills/prd-to-spec" "$_plugin_root/skills/prd-to-spec"; do
  if [[ -d "$loc" ]]; then
    _found_skill="$loc/"
    break
  fi
done

if [[ -n "$_found_skill" ]]; then
  _add_check "skill_prd_to_spec" "pass" "found $_found_skill"
else
  _add_check "skill_prd_to_spec" "fail" "missing prd-to-spec skill (checked project, home, plugin)"
fi

# 6. CLAUDE_PLUGIN_DATA writable
if [[ -z "$CLAUDE_PLUGIN_DATA" ]]; then
  _add_check "plugin_data" "fail" "CLAUDE_PLUGIN_DATA not set"
elif [[ -w "$CLAUDE_PLUGIN_DATA" ]] || mkdir -p "$CLAUDE_PLUGIN_DATA" 2>/dev/null; then
  _add_check "plugin_data" "pass" "CLAUDE_PLUGIN_DATA writable"
else
  _add_check "plugin_data" "fail" "CLAUDE_PLUGIN_DATA not writable: $CLAUDE_PLUGIN_DATA"
fi

# 7. Strict mode: optional agents — search project, home, and plugin locations
if [[ "$strict" == "true" ]]; then
  optional_agents=("scout")
  for agent in "${optional_agents[@]}"; do
    _agent_found=""
    for loc in ".claude/agents/${agent}.md" "$HOME/.claude/agents/${agent}.md"; do
      if [[ -f "$loc" ]]; then
        _agent_found="$loc"
        break
      fi
    done
    if [[ -n "$_agent_found" ]]; then
      _add_check "agent_${agent}" "pass" "found $_agent_found"
    else
      _add_check "agent_${agent}" "warn" "missing optional ${agent}.md (checked project and home)"
    fi
  done
fi

# Build output
checks_json=$(printf '%s\n' "${checks[@]}" | jq -s '.')
valid=true
if [[ "$failed" == "true" ]]; then
  valid=false
fi

jq -n \
  --argjson valid "$valid" \
  --argjson checks "$checks_json" \
  '{valid: $valid, checks: $checks}'

if [[ "$failed" == "true" ]]; then
  exit 1
fi
