#!/usr/bin/env bash
# Route model selection based on quota utilization.
# Usage: pipeline-model-router --quota <json> --tier <routine|feature|security>
# Output: JSON with provider, action, review_cap, and (on wait) wait_minutes
# Exit: 0=routed, 1=error

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

quota=""
tier="routine"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --quota) quota="$2"; shift 2 ;;
    --tier) tier="$2"; shift 2 ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

if [[ -z "$quota" ]]; then
  log_error "missing --quota argument"
  exit 1
fi

# Validate tier
case "$tier" in
  routine|feature|security) ;;
  *) log_error "invalid tier: $tier (expected routine|feature|security)"; exit 1 ;;
esac

# Parse quota data
five_hour_over=$(printf '%s' "$quota" | jq -r '.five_hour.over_threshold')
seven_day_over=$(printf '%s' "$quota" | jq -r '.seven_day.over_threshold')

# Standard review caps (from config or defaults)
routine_cap=$(read_config '.review.routineRounds' '2')
feature_cap=$(read_config '.review.featureRounds' '4')
security_cap=$(read_config '.review.securityRounds' '6')

# Get review cap for current tier
_review_cap() {
  case "$tier" in
    routine)  echo "$routine_cap" ;;
    feature)  echo "$feature_cap" ;;
    security) echo "$security_cap" ;;
  esac
}

# --- Routing logic ---

# Both within limits → proceed with Anthropic
if [[ "$five_hour_over" != "true" ]] && [[ "$seven_day_over" != "true" ]]; then
  cap=$(_review_cap)
  jq -n \
    --arg action "proceed" \
    --arg provider "anthropic" \
    --argjson review_cap "$cap" \
    --arg tier "$tier" \
    '{provider: $provider, action: $action, review_cap: $review_cap, tier: $tier}'
  exit 0
fi

# 7d over → end gracefully (cannot wait for 7d reset mid-run)
if [[ "$seven_day_over" == "true" ]]; then
  jq -n \
    --arg action "end_gracefully" \
    --arg trigger "7d_over" \
    --arg tier "$tier" \
    '{provider: "anthropic", action: $action, trigger: $trigger, tier: $tier}'
  exit 0
fi

# 5h over, 7d within → wait for 5h window reset
# Use resets_at_epoch from quota output (session-anchored, not UTC-boundary math)
resets_at=$(printf '%s' "$quota" | jq -r '.five_hour.resets_at_epoch // empty')
now=$(date +%s)

if [[ -n "$resets_at" ]]; then
  minutes_remaining=$(( (resets_at - now + 59) / 60 ))
else
  # Fallback: 5h window is at most 300 minutes; use half as conservative estimate
  minutes_remaining=150
fi
if (( minutes_remaining < 1 )); then minutes_remaining=1; fi

jq -n \
  --arg action "wait" \
  --arg trigger "5h_over" \
  --argjson wait_minutes "$minutes_remaining" \
  --arg tier "$tier" \
  '{provider: "anthropic", action: $action, trigger: $trigger, wait_minutes: $wait_minutes, tier: $tier}'
