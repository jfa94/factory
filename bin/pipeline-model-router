#!/usr/bin/env bash
# Route model selection based on quota utilization and Ollama availability.
# Usage: pipeline-model-router --quota <json> --tier <routine|feature|security>
# Output: JSON with provider, model, base_url, action, review_cap
# Exit: 0=routed, 1=error

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

quota=""
tier="routine"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --quota) quota="$2"; shift 2 ;;
    --tier) tier="$2"; shift 2 ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

if [[ -z "$quota" ]]; then
  log_error "missing --quota argument"
  exit 1
fi

# Validate tier
case "$tier" in
  routine|feature|security) ;;
  *) log_error "invalid tier: $tier (expected routine|feature|security)"; exit 1 ;;
esac

# Parse quota data
five_hour_over=$(printf '%s' "$quota" | jq -r '.five_hour.over_threshold')
seven_day_over=$(printf '%s' "$quota" | jq -r '.seven_day.over_threshold')

# Standard review caps (from config or defaults)
routine_cap=$(read_config '.review.routineRounds' '2')
feature_cap=$(read_config '.review.featureRounds' '4')
security_cap=$(read_config '.review.securityRounds' '6')

# Elevated review caps for Ollama (compensate for lower quality)
ollama_routine_cap=$(read_config '.review.ollamaRoutineRounds' '15')
ollama_feature_cap=$(read_config '.review.ollamaFeatureRounds' '20')
ollama_security_cap=$(read_config '.review.ollamaSecurityRounds' '25')

# Get review cap for current tier
_review_cap() {
  local provider="$1"
  if [[ "$provider" == "ollama" ]]; then
    case "$tier" in
      routine) echo "$ollama_routine_cap" ;;
      feature) echo "$ollama_feature_cap" ;;
      security) echo "$ollama_security_cap" ;;
    esac
  else
    case "$tier" in
      routine) echo "$routine_cap" ;;
      feature) echo "$feature_cap" ;;
      security) echo "$security_cap" ;;
    esac
  fi
}

# Check Ollama availability
_check_ollama() {
  local ollama_enabled ollama_url ollama_model

  ollama_enabled=$(read_config '.localLlm.enabled' 'false')
  if [[ "$ollama_enabled" != "true" ]]; then
    return 1
  fi

  ollama_url=$(read_config '.localLlm.ollamaUrl' 'http://localhost:11434')
  ollama_model=$(read_config '.localLlm.model' 'qwen2.5-coder:14b')

  # Check if Ollama is running (3s connect timeout)
  if ! curl -sf --connect-timeout 3 "${ollama_url}/api/tags" >/dev/null 2>&1; then
    log_warn "Ollama not reachable at $ollama_url"
    return 1
  fi

  # Check if model is available (or auto-pull)
  local model_available
  model_available=$(curl -sf --connect-timeout 3 "${ollama_url}/api/tags" 2>/dev/null \
    | jq -r --arg m "$ollama_model" '.models[]? | select(.name == $m) | .name' 2>/dev/null)

  if [[ -z "$model_available" ]]; then
    # Try auto-pull (with 24h cache check)
    local pull_cache="${CLAUDE_PLUGIN_DATA}/ollama-pull-cache"
    local now_epoch
    now_epoch=$(date +%s)

    local should_pull=true
    if [[ -f "$pull_cache" ]]; then
      local last_pull
      last_pull=$(cat "$pull_cache" 2>/dev/null)
      if [[ -n "$last_pull" ]]; then
        local age
        age=$(( now_epoch - last_pull ))
        if [[ $age -lt 86400 ]]; then
          should_pull=false
        fi
      fi
    fi

    if [[ "$should_pull" == "true" ]]; then
      log_info "pulling Ollama model: $ollama_model"
      # Build JSON body via jq --arg to avoid injection through model names
      # containing special characters (quotes, backslashes, control chars).
      local pull_body
      pull_body=$(jq -cn --arg name "$ollama_model" '{name:$name}')
      if curl -sf -X POST "${ollama_url}/api/pull" \
        -H "Content-Type: application/json" \
        -d "$pull_body" >/dev/null 2>&1; then
        printf '%s' "$now_epoch" > "$pull_cache"
      else
        log_warn "could not pull model $ollama_model"
        return 1
      fi
    else
      log_warn "model $ollama_model not available, pull attempted recently"
      return 1
    fi
  fi

  # Output Ollama config
  local cap
  cap=$(_review_cap "ollama")

  jq -n \
    --arg provider "ollama" \
    --arg model "$ollama_model" \
    --arg base_url "$ollama_url" \
    --arg action "proceed" \
    --arg trigger "rate_limit_fallback" \
    --argjson review_cap "$cap" \
    --arg tier "$tier" \
    '{
      provider: $provider,
      model: $model,
      base_url: $base_url,
      action: $action,
      trigger: $trigger,
      review_cap: $review_cap,
      tier: $tier
    }'
  return 0
}

# --- Routing logic ---

# Both within limits → proceed with Anthropic
if [[ "$five_hour_over" != "true" ]] && [[ "$seven_day_over" != "true" ]]; then
  cap=$(_review_cap "anthropic")
  jq -n \
    --arg action "proceed" \
    --arg provider "anthropic" \
    --argjson review_cap "$cap" \
    --arg tier "$tier" \
    '{provider: $provider, action: $action, review_cap: $review_cap, tier: $tier}'
  exit 0
fi

# 5h over, 7d within → try Ollama, else wait
if [[ "$five_hour_over" == "true" ]] && [[ "$seven_day_over" != "true" ]]; then
  if _check_ollama 2>/dev/null; then
    exit 0
  fi

  # No Ollama — compute wait time to next 5-hour window boundary from midnight UTC.
  # Force base-10 with 10# prefix to avoid bash interpreting leading zeros as octal.
  hour_now=$(date -u +%H)
  min_now=$(date -u +%M)
  min_in_day=$(( 10#$hour_now * 60 + 10#$min_now ))
  next_boundary_min=$(( ((min_in_day / 300) + 1) * 300 ))
  minutes_remaining=$(( next_boundary_min - min_in_day ))

  jq -n \
    --arg action "wait" \
    --arg trigger "5h_over_no_ollama" \
    --argjson wait_minutes "$minutes_remaining" \
    --arg tier "$tier" \
    '{provider: "anthropic", action: $action, trigger: $trigger, wait_minutes: $wait_minutes, tier: $tier}'
  exit 0
fi

# 7d over → try Ollama, else end gracefully
if [[ "$seven_day_over" == "true" ]]; then
  if _check_ollama 2>/dev/null; then
    exit 0
  fi

  jq -n \
    --arg action "end_gracefully" \
    --arg trigger "7d_over_no_ollama" \
    --arg tier "$tier" \
    '{provider: "anthropic", action: $action, trigger: $trigger, tier: $tier}'
  exit 0
fi
