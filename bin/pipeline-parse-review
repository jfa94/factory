#!/usr/bin/env bash
# Parse structured review output into normalized JSON.
# Usage: pipeline-parse-review [--reviewer claude-code] [--base <ref>]
# Input: stdin (raw reviewer output — JSON-block or prose format)
# Codex reviews must go through pipeline-codex-review, not this script.
# Exit: 0=parsed, 1=parse failure

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

reviewer="claude-code"
base_ref=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --reviewer) reviewer="$2"; shift 2 ;;
    --base)     base_ref="$2"; shift 2 ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

raw=$(cat)

if [[ -z "$raw" ]]; then
  log_error "empty review input"
  exit 1
fi

# Save raw to temp file for multi-pass parsing
tmpfile=$(mktemp)
printf '%s' "$raw" > "$tmpfile"
trap 'rm -f "$tmpfile"' EXIT

# =============================================================================
# --- JSON schema path: extract last ```json ... ``` block ---
# =============================================================================

# Extract the last JSON code block from the review text
json_block=$(awk '
  /^```json/ { in_block=1; buf=""; next }
  /^```/ && in_block { last=buf; in_block=0; next }
  in_block { buf = buf $0 "\n" }
  END { printf "%s", last }
' "$tmpfile")

if [[ -n "$json_block" ]] && printf '%s' "$json_block" | jq empty 2>/dev/null; then
  # Validate required keys
  has_verdict=$(printf '%s' "$json_block" | jq 'has("verdict")' 2>/dev/null)
  has_findings=$(printf '%s' "$json_block" | jq 'has("findings")' 2>/dev/null)

  if [[ "$has_verdict" == "true" && "$has_findings" == "true" ]]; then
    # Validate verdict value
    json_verdict=$(printf '%s' "$json_block" | jq -r '.verdict // ""')
    case "$json_verdict" in
      APPROVED|REQUEST_CHANGES|NEEDS_DISCUSSION) ;;
      *)
        log_error "invalid verdict in JSON block (got: '${json_verdict:-<empty>}')"
        exit 1
        ;;
    esac

    # Validate findings is array
    findings_type=$(printf '%s' "$json_block" | jq -r '.findings | type' 2>/dev/null)
    if [[ "$findings_type" != "array" ]]; then
      log_error "findings must be an array in JSON block"
      exit 1
    fi

    # Strip findings missing evidence (length < 5), log warnings.
    # Normalize legacy `.evidence` field into `.verbatim_line` so downstream
    # validate_findings (which reads .verbatim_line) can grep it against the diff.
    valid_findings=$(printf '%s' "$json_block" | jq '[
      .findings[] |
      . as $f |
      ((.verbatim_line // .evidence // "")) as $vl |
      if ($vl | length) >= 5 then ($f + {verbatim_line: $vl}) else empty end
    ]')

    # Count stripped findings and warn
    total_findings=$(printf '%s' "$json_block" | jq '.findings | length')
    valid_count=$(printf '%s' "$valid_findings" | jq 'length')
    if (( valid_count < total_findings )); then
      stripped=$(( total_findings - valid_count ))
      log_warn "stripped $stripped finding(s) missing required evidence (>= 5 chars)"
    fi

    # Normalize verdict: map APPROVED -> APPROVE for pipeline-run-task compat
    # pipeline-run-task reads .verdict and expects APPROVE|REQUEST_CHANGES|NEEDS_DISCUSSION
    normalized_verdict="$json_verdict"
    if [[ "$json_verdict" == "APPROVED" ]]; then
      normalized_verdict="APPROVE"
    fi

    # Extract summary
    json_summary=$(printf '%s' "$json_block" | jq -r '.summary // ""')

    # Cross-field consistency: APPROVED with any findings violates the reviewer contract
    # (quality-reviewer.md: "findings must be empty array [] when APPROVED").
    if [[ "$normalized_verdict" == "APPROVE" ]] && (( valid_count > 0 )); then
      log_warn "parser-downgrade: APPROVED verdict with $valid_count finding(s) — downgrading to REQUEST_CHANGES"
      normalized_verdict="REQUEST_CHANGES"
      json_summary="[parser-downgrade: APPROVED with findings] ${json_summary}"
    fi

    # REQUEST_CHANGES with no valid findings is an inverse hallucination — reject.
    if [[ "$normalized_verdict" == "REQUEST_CHANGES" && "$valid_count" -eq 0 ]]; then
      log_error "REQUEST_CHANGES verdict with no valid findings (all stripped or empty)"
      exit 1
    fi

    # Build normalized output matching the prose parser's schema
    blocking_count=$(printf '%s' "$valid_findings" | jq '[.[] | select(.severity == "critical" or .severity == "high")] | length')
    non_blocking_count=$(printf '%s' "$valid_findings" | jq '[.[] | select(.severity != "critical" and .severity != "high")] | length')

    out_json=$(jq -n \
      --arg verdict "$normalized_verdict" \
      --argjson round 1 \
      --arg confidence "HIGH" \
      --argjson findings "$valid_findings" \
      --argjson blocking_count "$blocking_count" \
      --argjson non_blocking_count "$non_blocking_count" \
      --argjson declared_blockers "$blocking_count" \
      --argjson criteria_passed 0 \
      --argjson criteria_failed 0 \
      --argjson holdout_passed 0 \
      --argjson holdout_failed 0 \
      --arg summary "$json_summary" \
      --arg reviewer "$reviewer" \
      '{
        verdict: $verdict,
        round: $round,
        confidence: $confidence,
        findings: $findings,
        blocking_count: $blocking_count,
        non_blocking_count: $non_blocking_count,
        declared_blockers: $declared_blockers,
        criteria_passed: $criteria_passed,
        criteria_failed: $criteria_failed,
        holdout_passed: $holdout_passed,
        holdout_failed: $holdout_failed,
        summary: $summary,
        reviewer: $reviewer
      }')

    if [[ -n "$base_ref" ]]; then
      diff_file=$(mktemp)
      trap 'rm -f "$tmpfile" "$diff_file"' EXIT
      if git diff --unified=5 "$base_ref" HEAD > "$diff_file" 2>/dev/null && [[ -s "$diff_file" ]]; then
        printf '%s' "$out_json" | validate_findings "$diff_file"
      else
        log_error "git diff failed or produced empty diff (base: $base_ref)"
        exit 1
      fi
    else
      printf '%s' "$out_json"
    fi
    exit 0
  fi
fi

# =============================================================================
# --- Prose fallback: legacy ## Verdict block parser ---
# =============================================================================

# Extract the anchored Verdict block (everything between `## Verdict` and the
# next top-level `## ` heading). The block is the *only* place where verdict,
# confidence, and blocker count are read from — this prevents prose like
# "I would not approve this approach" from being mis-parsed as a verdict.
verdict_section=$(awk '
  /^## Verdict$/ { flag=1; next }
  /^## / { flag=0 }
  flag
' "$tmpfile")

if [[ -z "$verdict_section" ]]; then
  log_error "could not extract verdict block (missing '## Verdict' heading)"
  exit 1
fi

verdict=$(printf '%s\n' "$verdict_section" | awk -F: '/^VERDICT:/{gsub(/[ \t]/,"",$2); print $2; exit}')
case "$verdict" in
  APPROVE|REQUEST_CHANGES|NEEDS_DISCUSSION) ;;
  *)
    log_error "invalid or missing VERDICT in verdict block (got: '${verdict:-<empty>}')"
    exit 1
    ;;
esac

confidence=$(printf '%s\n' "$verdict_section" | awk -F: '/^CONFIDENCE:/{gsub(/[ \t]/,"",$2); print $2; exit}')
case "$confidence" in
  HIGH|MEDIUM|LOW) ;;
  *) confidence="MEDIUM" ;;
esac

# BLOCKERS is the count declared by the reviewer in the verdict block. The
# parser still tallies BLOCKING findings independently below; the two MUST
# agree but we keep both for diagnostics.
declared_blockers=$(printf '%s\n' "$verdict_section" | awk -F: '/^BLOCKERS:/{gsub(/[ \t]/,"",$2); print $2; exit}')
[[ -z "$declared_blockers" ]] && declared_blockers=0

# Round is informational and may appear in the body or block — accept either.
round=$(printf '%s' "$raw" | grep 'ROUND:' | grep -oE '[0-9]+' | head -1)
round="${round:-1}"

# Parse findings by iterating line-by-line through the file
findings='[]'
blocking_count=0
non_blocking_count=0

current_type=""  # BLOCKING or NON-BLOCKING
current_title=""
current_file=""
current_severity=""
current_category=""
current_description=""
current_suggestion=""
current_verbatim=""

_flush_finding() {
  [[ -z "$current_title" ]] && return
  local is_blocking="false"
  [[ "$current_type" == "BLOCKING" ]] && is_blocking="true"
  findings=$(printf '%s' "$findings" | jq \
    --arg title "$current_title" \
    --arg file "$current_file" \
    --arg severity "$current_severity" \
    --arg category "$current_category" \
    --arg description "$current_description" \
    --arg suggestion "$current_suggestion" \
    --arg verbatim_line "$current_verbatim" \
    --argjson blocking "$is_blocking" \
    '. + [{title: $title, file: $file, severity: $severity, category: $category, description: $description, suggestion: $suggestion, verbatim_line: $verbatim_line, blocking: $blocking}]')
  if [[ "$current_type" == "BLOCKING" ]]; then
    blocking_count=$((blocking_count + 1))
  else
    non_blocking_count=$((non_blocking_count + 1))
  fi
  current_title=""
  current_file=""
  current_severity=""
  current_category=""
  current_description=""
  current_suggestion=""
  current_verbatim=""
  current_type=""
}

in_findings=false
while IFS= read -r line; do
  # Track section
  if [[ "$line" == "## Findings" ]]; then
    in_findings=true
    continue
  fi
  if [[ "$line" == "## "* ]] && [[ "$line" != "## Findings" ]]; then
    _flush_finding
    in_findings=false
    continue
  fi

  [[ "$in_findings" != "true" ]] && continue

  # New finding header
  if [[ "$line" == "### [BLOCKING] "* ]]; then
    _flush_finding
    current_type="BLOCKING"
    current_title="${line#"### [BLOCKING] "}"
  elif [[ "$line" == "### [NON-BLOCKING] "* ]]; then
    _flush_finding
    current_type="NON-BLOCKING"
    current_title="${line#"### [NON-BLOCKING] "}"
  elif [[ -n "$current_title" ]]; then
    # Parse metadata lines
    case "$line" in
      "- **File:** "*) current_file="${line#"- **File:** "}" ;;
      "- **Severity:** "*) current_severity="${line#"- **Severity:** "}" ;;
      "- **Category:** "*) current_category="${line#"- **Category:** "}" ;;
      "- **Description:** "*) current_description="${line#"- **Description:** "}" ;;
      "- **Suggestion:** "*) current_suggestion="${line#"- **Suggestion:** "}" ;;
      "- **Verbatim:** "*) current_verbatim="${line#"- **Verbatim:** "}" ;;
    esac
  fi
done < "$tmpfile"
_flush_finding

# Parse acceptance criteria check
criteria_passed=0
criteria_failed=0
in_criteria=false
while IFS= read -r line; do
  if [[ "$line" == "## Acceptance Criteria Check"* ]]; then
    in_criteria=true
    continue
  fi
  if [[ "$in_criteria" == "true" ]] && [[ "$line" == "## "* ]]; then
    break
  fi
  if [[ "$in_criteria" == "true" ]]; then
    case "$line" in
      *"| PASS |"*) criteria_passed=$((criteria_passed + 1)) ;;
      *"| FAIL |"*) criteria_failed=$((criteria_failed + 1)) ;;
    esac
  fi
done < "$tmpfile"

# Parse holdout criteria check
holdout_passed=0
holdout_failed=0
in_holdout=false
while IFS= read -r line; do
  if [[ "$line" == "## Holdout Criteria Check"* ]]; then
    in_holdout=true
    continue
  fi
  if [[ "$in_holdout" == "true" ]] && [[ "$line" == "## "* ]]; then
    break
  fi
  if [[ "$in_holdout" == "true" ]]; then
    case "$line" in
      *"| PASS |"*) holdout_passed=$((holdout_passed + 1)) ;;
      *"| FAIL |"*) holdout_failed=$((holdout_failed + 1)) ;;
    esac
  fi
done < "$tmpfile"

# Extract summary (portable: awk instead of GNU sed)
summary=$(awk '/^## Summary$/{found=1; next} found{print}' "$tmpfile" | head -5 | tr '\n' ' ' | sed 's/  */ /g; s/^ //; s/ $//')

# Enforce declared_blockers == blocking_count. Reviewer MUST agree with parser tally.
if [[ "${declared_blockers:-0}" != "$blocking_count" ]]; then
  log_warn "declared_blockers ($declared_blockers) ≠ blocking_count ($blocking_count) — downgrading to REQUEST_CHANGES"
  verdict="REQUEST_CHANGES"
  summary="[parser-downgrade: declared/observed blocker mismatch] ${summary}"
fi

# Build output JSON
out_json=$(jq -n \
  --arg verdict "$verdict" \
  --argjson round "$round" \
  --arg confidence "$confidence" \
  --argjson findings "$findings" \
  --argjson blocking_count "$blocking_count" \
  --argjson non_blocking_count "$non_blocking_count" \
  --argjson declared_blockers "${declared_blockers:-0}" \
  --argjson criteria_passed "$criteria_passed" \
  --argjson criteria_failed "$criteria_failed" \
  --argjson holdout_passed "$holdout_passed" \
  --argjson holdout_failed "$holdout_failed" \
  --arg summary "$summary" \
  --arg reviewer "$reviewer" \
  '{
    verdict: $verdict,
    round: $round,
    confidence: $confidence,
    findings: $findings,
    blocking_count: $blocking_count,
    non_blocking_count: $non_blocking_count,
    declared_blockers: $declared_blockers,
    criteria_passed: $criteria_passed,
    criteria_failed: $criteria_failed,
    holdout_passed: $holdout_passed,
    holdout_failed: $holdout_failed,
    summary: $summary,
    reviewer: $reviewer
  }')

# Validate findings against the diff if a base ref was provided. Findings whose
# verbatim_line does not appear in `git diff <base> HEAD` are dropped; if all
# blockers were dropped, the verdict is downgraded to APPROVE (see
# validate_findings in pipeline-lib.sh).
if [[ -n "$base_ref" ]]; then
  diff_file=$(mktemp)
  trap 'rm -f "$tmpfile" "$diff_file"' EXIT
  if git diff --unified=5 "$base_ref" HEAD > "$diff_file" 2>/dev/null && [[ -s "$diff_file" ]]; then
    printf '%s' "$out_json" | validate_findings "$diff_file"
  else
    log_error "git diff failed or produced empty diff (base: $base_ref)"
    exit 1
  fi
else
  printf '%s' "$out_json"
fi
