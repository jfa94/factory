#!/usr/bin/env bash
# Check Claude API quota utilization.
#
# Data source: ${CLAUDE_PLUGIN_DATA}/usage-cache.json, written by
# bin/statusline-wrapper.sh on every Claude Code statusline update. This file
# contains real-time rate_limits data from the Claude Code process — no API
# calls, no token cost.
#
# The statusline wrapper is auto-installed for pipeline sessions via
# templates/settings.autonomous.json — no user setup required.
#
# Freshness: if captured_at is >120s old, a warning is logged but the data is
# still used — statusline can stall during long Agent() tool calls, but the
# cached values are still the most recent available.
#
# Fail-closed: on missing/malformed/stale cache, exits 0 with sentinel JSON:
#   {"detection_method":"unavailable","reason":"...","five_hour":{"over_threshold":true},...}
# The sentinel's over_threshold=true routes through pipeline-model-router's
# `detection_method==unavailable` branch to end_gracefully — production path.
#
# --strict flag is for tests only — it restores legacy exit 1 behavior for
# assertions that depend on a non-zero exit. No production caller uses it.
#
# Usage: pipeline-quota-check [--strict]
# Exit: 0=data retrieved (JSON on stdout), 1=detection failed (--strict only)

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

strict=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --strict) strict=true; shift ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

PLUGIN_DATA="${CLAUDE_PLUGIN_DATA:-${HOME}/.claude/plugins/data/factory-jfa94}"
cache_file="${PLUGIN_DATA}/usage-cache.json"

_sentinel() {
  local reason="$1"
  jq -n --arg reason "$reason" '{
    detection_method: "unavailable",
    reason: $reason,
    five_hour: {
      utilization: null,
      over_threshold: true,
      hourly_threshold: null,
      window_hour: null,
      resets_at_epoch: null
    },
    seven_day: {
      utilization: null,
      over_threshold: true,
      daily_threshold: null,
      window_day: null,
      resets_at_epoch: null
    },
    captured_at: null
  }'
}

# --- Validate cache file ---

if [[ ! -f "$cache_file" ]]; then
  if $strict; then
    log_error "usage-cache.json not found: $cache_file"
    log_error "statusLine.command in ~/.claude/settings.json must point to statusline-wrapper.sh"
    exit 1
  fi
  log_warn "usage-cache.json not found; emitting unavailable sentinel (pipeline will halt)"
  _sentinel "usage-cache-missing"
  exit 0
fi

if ! jq -e . "$cache_file" >/dev/null 2>&1; then
  if $strict; then
    log_error "usage-cache.json is not valid JSON: $cache_file"
    exit 1
  fi
  log_warn "usage-cache.json is malformed; emitting unavailable sentinel"
  _sentinel "usage-cache-malformed"
  exit 0
fi

# --- Freshness check ---

now_epoch=$(date +%s)
captured_at=$(jq -r '.captured_at // 0' "$cache_file")
age=$(( now_epoch - captured_at ))
if (( age > 120 )); then
  log_warn "usage-cache.json is ${age}s old (>120s) — data may be stale"
fi
# Hard ceiling: a cache older than 1h is from a previous session, not a paused
# statusline tick. Treat it as unavailable so gates fail-closed rather than
# proceeding on stale 0% data.
if (( age > 3600 )); then
  if $strict; then
    log_error "usage-cache.json is ${age}s old (>3600s) — too stale to use"
    exit 1
  fi
  log_warn "usage-cache.json is ${age}s old (>3600s) — treating as unavailable; pipeline will halt"
  _sentinel "usage-cache-too-stale"
  exit 0
fi

# --- Parse utilization and resets_at ---

# used_percentage may be a float (e.g. 45.2) — truncate to integer
five_hour_pct=$(jq -r '.five_hour.used_percentage // empty' "$cache_file" 2>/dev/null)
seven_day_pct=$(jq -r '.seven_day.used_percentage // empty' "$cache_file" 2>/dev/null)

if [[ -z "$five_hour_pct" || -z "$seven_day_pct" ]]; then
  if $strict; then
    log_error "usage-cache.json missing five_hour or seven_day data"
    exit 1
  fi
  log_warn "usage-cache.json missing rate_limit fields; emitting unavailable sentinel"
  _sentinel "usage-cache-malformed"
  exit 0
fi

# Normalize to integer percent
five_hour=$(jq -n --argjson v "$five_hour_pct" '$v | round | tonumber' 2>/dev/null) || five_hour="${five_hour_pct%%.*}"
seven_day=$(jq -n --argjson v "$seven_day_pct" '$v | round | tonumber' 2>/dev/null) || seven_day="${seven_day_pct%%.*}"

# resets_at from statusline JSON is already epoch seconds
resets_5h_epoch=$(jq -r '.five_hour.resets_at // empty' "$cache_file" 2>/dev/null)
resets_7d_epoch=$(jq -r '.seven_day.resets_at // empty' "$cache_file" 2>/dev/null)

# Fall back to sensible defaults if missing
[[ -z "$resets_5h_epoch" ]] && resets_5h_epoch=$(( now_epoch + 18000 ))
[[ -z "$resets_7d_epoch" ]] && resets_7d_epoch=$(( now_epoch + 604800 ))

# --- Compute window position and thresholds ---

window_hour=$(compute_window_hour "$resets_5h_epoch" "$now_epoch")
window_day=$(compute_window_day "$resets_7d_epoch" "$now_epoch")
hourly_threshold=$(compute_hourly_threshold "$window_hour")
daily_threshold=$(compute_daily_threshold "$window_day")

five_hour_over=$(jq -n --argjson a "$five_hour" --argjson b "$hourly_threshold" \
  'if $a > $b then true else false end')
seven_day_over=$(jq -n --argjson a "$seven_day" --argjson b "$daily_threshold" \
  'if $a > $b then true else false end')

# --- Emit output ---

jq -n \
  --argjson five_hour      "$five_hour" \
  --argjson hourly_threshold "$hourly_threshold" \
  --argjson five_hour_over "$five_hour_over" \
  --argjson window_hour    "$window_hour" \
  --argjson resets_5h_epoch "$resets_5h_epoch" \
  --argjson seven_day      "$seven_day" \
  --argjson daily_threshold "$daily_threshold" \
  --argjson seven_day_over "$seven_day_over" \
  --argjson window_day     "$window_day" \
  --argjson resets_7d_epoch "$resets_7d_epoch" \
  '{
    five_hour: {
      utilization: $five_hour,
      hourly_threshold: $hourly_threshold,
      over_threshold: $five_hour_over,
      window_hour: $window_hour,
      resets_at_epoch: $resets_5h_epoch
    },
    seven_day: {
      utilization: $seven_day,
      daily_threshold: $daily_threshold,
      over_threshold: $seven_day_over,
      window_day: $window_day,
      resets_at_epoch: $resets_7d_epoch
    },
    detection_method: "statusline"
  }'
