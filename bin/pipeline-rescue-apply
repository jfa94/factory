#!/usr/bin/env bash
# Apply rescue remediations. Idempotent per action.
# Usage:
#   pipeline-rescue-apply --tier=safe --plan=<report.json>
#   pipeline-rescue-apply --tier=risky --plan=<approved.json>
#   pipeline-rescue-apply --plans=<approved-plans.json>        (investigation)
#   pipeline-rescue-apply --dry-run ...
# Exit: 0 on success (even with per-action errors logged), 1 on fatal.

set -euo pipefail

source "$(dirname "$0")/pipeline-lib.sh"
source "$(dirname "$0")/pipeline-rescue-lib.sh"
require_command jq

tier=""
plan=""
plans=""
dry_run=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --tier) tier="$2"; shift 2 ;;
    --tier=*) tier="${1#--tier=}"; shift ;;
    --plan) plan="$2"; shift 2 ;;
    --plan=*) plan="${1#--plan=}"; shift ;;
    --plans) plans="$2"; shift 2 ;;
    --plans=*) plans="${1#--plans=}"; shift ;;
    --dry-run) dry_run=1; shift ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

if [[ -z "$plan" && -z "$plans" ]]; then
  log_error "must pass --plan or --plans"
  exit 1
fi

_apply_I_03() {
  local run_id="$1" task_id="$2"
  local cur
  cur=$(pipeline-state read "$run_id" ".tasks.${task_id}.status" 2>/dev/null || echo '')
  if [[ "$cur" == 'done' ]]; then
    rescue_audit "$run_id" safe I-03 "$task_id" mark_pr_merged skipped ""
    return 0
  fi
  if (( dry_run )); then
    rescue_audit "$run_id" safe I-03 "$task_id" mark_pr_merged dry_run ""
    return 0
  fi
  local err=0
  pipeline-state task-status "$run_id" "$task_id" done >/dev/null || err=1
  if (( err == 0 )); then
    pipeline-state task-write "$run_id" "$task_id" stage '"ship_done"' >/dev/null || err=1
  fi
  if (( err )); then
    rescue_audit "$run_id" safe I-03 "$task_id" mark_pr_merged partial_failure "write failed"
  else
    rescue_audit "$run_id" safe I-03 "$task_id" mark_pr_merged ok ""
  fi
}

_apply_I_01() {
  local run_id="$1"
  local lock="$CLAUDE_PLUGIN_DATA/runs/$run_id/state.lock"
  if [[ ! -d "$lock" ]]; then
    rescue_audit "$run_id" safe I-01 "" clear_stale_lock skipped ""
    return 0
  fi
  if (( dry_run )); then
    rescue_audit "$run_id" safe I-01 "" clear_stale_lock dry_run ""
    return 0
  fi
  [[ -f "$lock/pid" ]] && rm -f "$lock/pid"
  rmdir "$lock" 2>/dev/null || true
  rescue_audit "$run_id" safe I-01 "" clear_stale_lock ok ""
}

_apply_I_02() {
  local run_id="$1" wt_path="$2"
  if [[ ! -d "$wt_path" ]]; then
    rescue_audit "$run_id" safe I-02 "" remove_orphan_worktree skipped ""
    return 0
  fi
  if (( dry_run )); then
    rescue_audit "$run_id" safe I-02 "" remove_orphan_worktree dry_run ""
    return 0
  fi
  git worktree remove --force "$wt_path" 2>/dev/null || true
  rescue_audit "$run_id" safe I-02 "" remove_orphan_worktree ok "$wt_path"
}

_apply_I_04() {
  local run_id="$1" task_id="$2" pr_url="$3"
  local cur
  cur=$(pipeline-state read "$run_id" ".tasks.${task_id}.pr_url" 2>/dev/null || echo '')
  if [[ -n "$cur" && "$cur" != "null" ]]; then
    rescue_audit "$run_id" safe I-04 "$task_id" backfill_pr_url skipped ""
    return 0
  fi
  if (( dry_run )); then
    rescue_audit "$run_id" safe I-04 "$task_id" backfill_pr_url dry_run ""
    return 0
  fi
  local pr_num
  if [[ "$pr_url" =~ /pull/([0-9]+) ]]; then
    pr_num="${BASH_REMATCH[1]}"
  else
    pr_num=''
  fi
  pipeline-state task-write "$run_id" "$task_id" pr_url "\"$pr_url\"" >/dev/null
  [[ -n "$pr_num" ]] && pipeline-state task-write "$run_id" "$task_id" pr_number "$pr_num" >/dev/null
  rescue_audit "$run_id" safe I-04 "$task_id" backfill_pr_url ok ""
}

_apply_I_05() {
  local run_id="$1" task_id="$2" latest="$3"
  if (( dry_run )); then
    rescue_audit "$run_id" safe I-05 "$task_id" refresh_ci_status dry_run ""
    return 0
  fi
  pipeline-state task-write "$run_id" "$task_id" ci_status "\"$latest\"" >/dev/null
  rescue_audit "$run_id" safe I-05 "$task_id" refresh_ci_status ok ""
}

_dispatch_safe() {
  local run_id="$1" plan_file="$2"
  while IFS=$'\t' read -r id task_id detail; do
    case "$id" in
      I-01) _apply_I_01 "$run_id" ;;
      I-02) _apply_I_02 "$run_id" "$task_id" ;;
      I-03) _apply_I_03 "$run_id" "$task_id" ;;
      I-04) _apply_I_04 "$run_id" "$task_id" "$detail" ;;
      I-05) _apply_I_05 "$run_id" "$task_id" "$detail" ;;
    esac
  done < <(jq -r '.mechanical_issues[] | select(.tier == 1) | [.id, (.task_id // ""), (.description // "")] | @tsv' "$plan_file")
}

if [[ -n "$plans" && -z "$plan" ]]; then
  log_warn "--plans mode not yet implemented"
  exit 0
fi

run_id=$(jq -r '.run_id' "$plan")
if [[ "$tier" == "safe" ]]; then
  _dispatch_safe "$run_id" "$plan"
elif [[ "$tier" == "risky" ]]; then
  log_warn "risky-tier apply not implemented in this task; no-op"
fi

printf '{"run_id":"%s","tier":"%s"}\n' "$run_id" "${tier:-plans}"
