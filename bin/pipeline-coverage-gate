#!/usr/bin/env bash
# Compare before/after coverage reports. Block if coverage decreased.
# Usage: pipeline-coverage-gate <before-json> <after-json>
# Input: vitest coverage-v8 JSON summary files
# Exit: 0=passed (no decrease), 1=failed (coverage decreased)

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

before_file="${1:?missing before coverage JSON path}"
after_file="${2:?missing after coverage JSON path}"
shift 2

tolerance=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --tolerance) tolerance="$2"; shift 2 ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

if [[ -z "$tolerance" ]]; then
  tolerance=$(read_config '.quality.coverageRegressionTolerancePct' '0.5')
fi

# Validate inputs exist
if [[ ! -f "$before_file" ]]; then
  log_error "before coverage file not found: $before_file"
  jq -n '{passed: false, error: "before coverage file not found", before: {}, after: {}, delta: {}}'
  exit 1
fi

if [[ ! -f "$after_file" ]]; then
  log_error "after coverage file not found: $after_file"
  jq -n '{passed: false, error: "after coverage file not found", before: {}, after: {}, delta: {}}'
  exit 1
fi

# Validate JSON
if ! jq empty "$before_file" 2>/dev/null; then
  log_error "before coverage file is not valid JSON"
  jq -n '{passed: false, error: "before coverage file is not valid JSON", before: {}, after: {}, delta: {}}'
  exit 1
fi

if ! jq empty "$after_file" 2>/dev/null; then
  log_error "after coverage file is not valid JSON"
  jq -n '{passed: false, error: "after coverage file is not valid JSON", before: {}, after: {}, delta: {}}'
  exit 1
fi

# Extract total coverage metrics (vitest coverage-v8 summary format)
# Supports both {total: {lines: {pct: N}}} and {total: {lines: N}} shapes
extract_metrics() {
  local file="$1"
  jq '{
    lines: (if .total.lines | type == "object" then .total.lines.pct else .total.lines end // 0),
    branches: (if .total.branches | type == "object" then .total.branches.pct else .total.branches end // 0),
    functions: (if .total.functions | type == "object" then .total.functions.pct else .total.functions end // 0),
    statements: (if .total.statements | type == "object" then .total.statements.pct else .total.statements end // 0)
  }' "$file"
}

before=$(extract_metrics "$before_file")
after=$(extract_metrics "$after_file")

# Compute deltas
delta=$(jq -n \
  --argjson b "$before" \
  --argjson a "$after" \
  '{
    lines: (($a.lines - $b.lines) * 100 | round | . / 100),
    branches: (($a.branches - $b.branches) * 100 | round | . / 100),
    functions: (($a.functions - $b.functions) * 100 | round | . / 100),
    statements: (($a.statements - $b.statements) * 100 | round | . / 100)
  }')

# Check for decrease beyond tolerance
decreased=$(jq -n --argjson d "$delta" --argjson t "$tolerance" '
  ($d.lines < (-1 * $t)) or ($d.branches < (-1 * $t)) or ($d.functions < (-1 * $t)) or ($d.statements < (-1 * $t))
')

delta_lines=$(printf '%s' "$delta" | jq -r '.lines')
log_metric "task.gate.coverage" "status=\"$([[ "$decreased" == "true" ]] && echo fail || echo pass)\"" \
  "delta_lines=$delta_lines" "tolerance=$tolerance"

if [[ "$decreased" == "true" ]]; then
  decreased_metrics=$(jq -n --argjson d "$delta" --argjson t "$tolerance" '
    [
      (if $d.lines < (-1 * $t) then "lines (\($d.lines)%)" else empty end),
      (if $d.branches < (-1 * $t) then "branches (\($d.branches)%)" else empty end),
      (if $d.functions < (-1 * $t) then "functions (\($d.functions)%)" else empty end),
      (if $d.statements < (-1 * $t) then "statements (\($d.statements)%)" else empty end)
    ] | join(", ")
  ')
  log_error "coverage decreased beyond tolerance (${tolerance}%): $decreased_metrics"

  jq -n \
    --argjson passed false \
    --argjson before "$before" \
    --argjson after "$after" \
    --argjson delta "$delta" \
    --argjson tolerance "$tolerance" \
    '{passed: $passed, before: $before, after: $after, delta: $delta, tolerance: $tolerance}'
  exit 1
fi

log_info "coverage gate passed (tolerance: ${tolerance}%)"
jq -n \
  --argjson passed true \
  --argjson before "$before" \
  --argjson after "$after" \
  --argjson delta "$delta" \
  --argjson tolerance "$tolerance" \
  '{passed: $passed, before: $before, after: $after, delta: $delta, tolerance: $tolerance}'
