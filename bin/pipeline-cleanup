#!/usr/bin/env bash
# Clean up after a pipeline run: branches, worktrees, issues, spec, state archive.
# Usage: pipeline-cleanup <run-id> [flags]
# Flags:
#   --close-issues      Close GitHub issues (only if ALL tasks for issue merged)
#   --delete-branches   Delete local+remote branches for merged PRs
#   --remove-worktrees  Remove git worktrees for merged tasks
#   --clean-spec        Remove spec dir after all tasks merged
#   --spec-dir <path>   Spec directory path (required for --clean-spec)
# Exit: 0=success, 1=failure

source "$(dirname "$0")/pipeline-lib.sh"
require_command jq

run_id="${1:?missing run-id}"
shift

close_issues=false
delete_branches=false
remove_worktrees=false
clean_spec=false
spec_dir=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --close-issues) close_issues=true; shift ;;
    --delete-branches) delete_branches=true; shift ;;
    --remove-worktrees) remove_worktrees=true; shift ;;
    --clean-spec) clean_spec=true; shift ;;
    --spec-dir) spec_dir="$2"; shift 2 ;;
    *) log_error "unknown flag: $1"; exit 1 ;;
  esac
done

# Read state
state_file="${CLAUDE_PLUGIN_DATA}/runs/${run_id}/state.json"
if [[ ! -f "$state_file" ]]; then
  log_error "state file not found: $state_file"
  exit 1
fi

state=$(cat "$state_file")

# Collect results for output
branches_deleted=0
branches_skipped=0
worktrees_removed=0
issues_closed=0
issue_errors=()
worktree_errors=()
spec_cleaned=false
branch_warnings=()

# --- Delete branches ---
if [[ "$delete_branches" == "true" ]]; then
  require_command gh
  log_info "cleaning up branches..."

  # Iterate tasks, delete branches only for tasks whose PR is MERGED.
  # Task status of `done` can mean "review approved" — with humanReviewLevel
  # >= 1 the PR is still open at that point. Deleting then would break the PR.
  while IFS= read -r task_entry; do
    task_id=$(printf '%s' "$task_entry" | jq -r '.key')
    task_status=$(printf '%s' "$task_entry" | jq -r '.value.status')
    branch=$(printf '%s' "$task_entry" | jq -r '.value.branch // empty')
    pr_number=$(printf '%s' "$task_entry" | jq -r '.value.pr_number // empty')

    if [[ -z "$branch" ]]; then
      continue
    fi

    if [[ "$task_status" != "done" ]]; then
      log_warn "skipping unfinished branch: $branch (task $task_id status=$task_status)"
      branches_skipped=$((branches_skipped + 1))
      branch_warnings+=("task=$task_id branch=$branch status=$task_status")
      continue
    fi

    # Task is done — but only delete if the PR is actually MERGED.
    if [[ -z "$pr_number" || "$pr_number" == "null" ]]; then
      log_warn "skipping branch with no PR: $branch (task $task_id)"
      branches_skipped=$((branches_skipped + 1))
      branch_warnings+=("task=$task_id branch=$branch reason=no_pr")
      continue
    fi

    pr_state=$(gh pr view "$pr_number" --json state -q .state 2>/dev/null || echo "UNKNOWN")
    if [[ "$pr_state" != "MERGED" ]]; then
      log_warn "skipping branch with $pr_state PR #$pr_number: $branch"
      branches_skipped=$((branches_skipped + 1))
      branch_warnings+=("task=$task_id branch=$branch pr=$pr_number state=$pr_state")
      continue
    fi

    deleted_any=false

    # Delete remote branch
    if git push origin --delete "$branch" 2>/dev/null; then
      log_info "deleted remote branch: $branch"
      deleted_any=true
    fi

    # Delete local branch
    if git branch -d "$branch" 2>/dev/null; then
      log_info "deleted local branch: $branch"
      deleted_any=true
    fi

    if [[ "$deleted_any" == "true" ]]; then
      branches_deleted=$((branches_deleted + 1))
    fi
  done < <(printf '%s' "$state" | jq -c '.tasks | to_entries[]')
fi

# --- Remove worktrees ---
if [[ "$remove_worktrees" == "true" ]]; then
  log_info "cleaning up worktrees..."

  while IFS= read -r task_entry; do
    task_id=$(printf '%s' "$task_entry" | jq -r '.key')
    task_status=$(printf '%s' "$task_entry" | jq -r '.value.status')
    worktree=$(printf '%s' "$task_entry" | jq -r '.value.worktree // empty')

    if [[ -z "$worktree" ]]; then
      continue
    fi

    if [[ "$task_status" == "done" ]]; then
      if [[ -d "$worktree" ]]; then
        if err=$(git worktree remove "$worktree" --force 2>&1); then
          log_info "removed worktree: $worktree"
          worktrees_removed=$((worktrees_removed + 1))
        else
          log_warn "could not remove worktree $worktree: $err"
          worktree_errors+=("${task_id}:${worktree}")
          continue
        fi
      fi
    else
      log_warn "skipping worktree for unmerged task: $task_id"
    fi
  done < <(printf '%s' "$state" | jq -c '.tasks | to_entries[]')
fi

# --- Delete orphan worktree-agent-* branches ---
# Claude Code's isolation:worktree harness creates branches named worktree-agent-*
# for each sub-agent spawn. It removes the worktree directory but leaves the branch.
# Sweep any such branch that is not currently backing a live worktree.
agent_branches_deleted=0
agent_branch_errors=()
live_wt_branches=()

if [[ "$remove_worktrees" == "true" ]]; then
  # Collect branches held by active worktrees (refs/heads/ prefix stripped).
  mapfile -t live_wt_branches < <(
    git worktree list --porcelain 2>/dev/null \
      | awk '/^branch /{sub("refs/heads/", "", $2); print $2}'
  )

  while IFS= read -r orphan_branch; do
    [[ -z "$orphan_branch" ]] && continue

    # Skip if branch is still held by a live worktree.
    skip=false
    for live in "${live_wt_branches[@]}"; do
      if [[ "$live" == "$orphan_branch" ]]; then
        skip=true
        break
      fi
    done
    if [[ "$skip" == "true" ]]; then
      log_info "keeping worktree-agent branch (live worktree): $orphan_branch"
      continue
    fi

    if err=$(git branch -D "$orphan_branch" 2>&1); then
      log_info "deleted orphan agent branch: $orphan_branch"
      agent_branches_deleted=$((agent_branches_deleted + 1))
    else
      log_warn "could not delete orphan agent branch $orphan_branch: $err"
      agent_branch_errors+=("$orphan_branch")
    fi
  done < <(git branch --list 'worktree-agent-*' --format='%(refname:short)' 2>/dev/null)
fi

# --- Delete spec-handoff/<run_id> branch (current run) ---
spec_handoff_branch="spec-handoff/${run_id}"
spec_handoff_deleted=0

if git show-ref --verify --quiet "refs/heads/${spec_handoff_branch}" 2>/dev/null; then
  if git merge-base --is-ancestor "$spec_handoff_branch" "origin/staging" 2>/dev/null; then
    if git branch -d "$spec_handoff_branch" 2>/dev/null; then
      log_info "deleted local spec-handoff branch: $spec_handoff_branch"
      spec_handoff_deleted=1
    fi
  else
    log_warn "spec-handoff branch '$spec_handoff_branch' is not an ancestor of origin/staging — skipping local delete"
  fi
fi
if git ls-remote --exit-code --heads origin "$spec_handoff_branch" &>/dev/null; then
  # Refresh staging tracking ref so ancestor check is not stale.
  git fetch --quiet origin staging 2>/dev/null || true
  remote_ref="refs/remotes/origin/${spec_handoff_branch}"
  # Mirror the remote ref locally for is-ancestor; if absent, fetch it.
  git fetch --quiet origin "$spec_handoff_branch:$remote_ref" 2>/dev/null || true
  if git merge-base --is-ancestor "$remote_ref" "origin/staging" 2>/dev/null; then
    if git push origin --delete "$spec_handoff_branch" 2>/dev/null; then
      log_info "deleted remote spec-handoff branch: $spec_handoff_branch"
      spec_handoff_deleted=1
    fi
  else
    log_warn "remote spec-handoff branch '$spec_handoff_branch' is not an ancestor of origin/staging — skipping remote delete"
  fi
fi

# --- Sweep orphan spec-handoff/* branches (other runs) ---
# Cross-reference active runs so we don't delete a branch mid spec-generation.
mapfile -t active_runs < <(pipeline-state list 2>/dev/null | jq -r '.[]' 2>/dev/null)
orphan_spec_deleted=0

while IFS= read -r sh_branch; do
  [[ -z "$sh_branch" ]] && continue
  sh_run_id="${sh_branch#spec-handoff/}"
  skip=false
  for ar in "${active_runs[@]}"; do
    [[ "$ar" == "$sh_run_id" ]] && { skip=true; break; }
  done
  [[ "$skip" == "true" ]] && { log_info "keeping spec-handoff branch (active run): $sh_branch"; continue; }
  if git branch -D "$sh_branch" 2>/dev/null; then
    log_info "deleted orphan spec-handoff branch: $sh_branch"
    orphan_spec_deleted=$((orphan_spec_deleted + 1))
  fi
  git push origin --delete "$sh_branch" 2>/dev/null || true
done < <(git branch --list 'spec-handoff/*' --format='%(refname:short)' 2>/dev/null)

# --- Sweep orphan orchestrator-run-* worktrees and branches ---
# Happy-path removal runs at SKILL.md after finalize-run; this catches crash/abort leftovers.
orchestrator_branches_deleted=0
orchestrator_wts_removed=0
orchestrator_errors=()

if [[ ${#live_wt_branches[@]} -eq 0 ]]; then
  mapfile -t live_wt_branches < <(
    git worktree list --porcelain 2>/dev/null \
      | awk '/^branch /{sub("refs/heads/", "", $2); print $2}'
  )
fi
project_root=$(git rev-parse --show-toplevel 2>/dev/null)

while IFS= read -r orch_branch; do
  [[ -z "$orch_branch" ]] && continue
  skip=false
  for live in "${live_wt_branches[@]}"; do
    [[ "$live" == "$orch_branch" ]] && { skip=true; break; }
  done
  [[ "$skip" == "true" ]] && { log_info "keeping orchestrator branch (live worktree): $orch_branch"; continue; }

  orch_wt="${project_root}/.claude/worktrees/${orch_branch}"
  if [[ -d "$orch_wt" ]]; then
    if err=$(git worktree remove "$orch_wt" --force 2>&1); then
      log_info "removed orphan orchestrator worktree: $orch_wt"
      orchestrator_wts_removed=$((orchestrator_wts_removed + 1))
    else
      log_warn "could not remove orchestrator worktree $orch_wt: $err"
      orchestrator_errors+=("worktree:${orch_branch}:${err}")
    fi
  fi

  if err=$(git branch -D "$orch_branch" 2>&1); then
    log_info "deleted orphan orchestrator branch: $orch_branch"
    orchestrator_branches_deleted=$((orchestrator_branches_deleted + 1))
  else
    log_warn "could not delete orphan orchestrator branch $orch_branch: $err"
    orchestrator_errors+=("branch:${orch_branch}:${err}")
  fi
done < <(git branch --list 'orchestrator-run-*' --format='%(refname:short)' 2>/dev/null)

# --- Close issues ---
if [[ "$close_issues" == "true" ]]; then
  require_command gh
  log_info "checking issues for closure..."

  # E2: use while+read to avoid word-splitting, and validate each issue number
  # is purely numeric before passing to gh — defence-in-depth against malformed
  # state (e.g. injection via a non-validating writer in the future).
  while IFS= read -r issue_number; do
    [[ -z "$issue_number" ]] && continue
    if ! [[ "$issue_number" =~ ^[0-9]+$ ]]; then
      log_warn "skipping non-numeric issue_number from state: $issue_number"
      continue
    fi
    # Check if ALL tasks are done
    total_tasks=$(printf '%s' "$state" | jq '.tasks | length')
    done_tasks=$(printf '%s' "$state" | jq '[.tasks | to_entries[] | select(.value.status == "done")] | length')

    if [[ "$done_tasks" -eq "$total_tasks" ]] && [[ "$total_tasks" -gt 0 ]]; then
      if err=$(gh issue close "$issue_number" 2>&1); then
        log_info "closed issue #$issue_number"
        issues_closed=$((issues_closed + 1))
      else
        log_warn "could not close issue #$issue_number: $err"
        issue_errors+=("$issue_number")
      fi
    else
      log_warn "not closing issue #$issue_number ($done_tasks/$total_tasks tasks done)"
    fi
  done < <(printf '%s' "$state" | jq -r '.input.issue_numbers[]' 2>/dev/null)
fi

# --- Clean spec ---
if [[ "$clean_spec" == "true" ]]; then
  if [[ -z "$spec_dir" ]]; then
    log_warn "no --spec-dir specified, skipping spec cleanup"
  elif [[ ! -d "$spec_dir" ]]; then
    log_warn "spec dir not found: $spec_dir"
  else
    # Only clean if all tasks done
    total_tasks=$(printf '%s' "$state" | jq '.tasks | length')
    done_tasks=$(printf '%s' "$state" | jq '[.tasks | to_entries[] | select(.value.status == "done")] | length')

    if [[ "$done_tasks" -eq "$total_tasks" ]] && [[ "$total_tasks" -gt 0 ]]; then
      # --- Refuse-list: reject sensitive / out-of-project paths before rm -rf ---
      resolved=$(cd "$spec_dir" 2>/dev/null && pwd -P) || {
        log_error "spec dir could not be resolved to an absolute path: $spec_dir"
        exit 1
      }
      home_resolved=$(cd "$HOME" 2>/dev/null && pwd -P) || home_resolved="$HOME"

      case "$resolved" in
        "" | "/" | "/bin" | "/boot" | "/dev" | "/etc" | "/home" | "/lib" | \
        "/opt" | "/proc" | "/root" | "/sbin" | "/srv" | "/sys" | "/tmp" | \
        "/usr" | "/var" | "/Users" | "/Applications" | "/Library" | "/System" | \
        "/private" | "/Volumes")
          log_error "refusing to rm -rf system path: $resolved"
          exit 1
          ;;
      esac

      if [[ "$resolved" == "$home_resolved" ]]; then
        log_error "refusing to rm -rf \$HOME: $resolved"
        exit 1
      fi
      case "$home_resolved/" in
        "$resolved"/*)
          log_error "refusing to rm -rf an ancestor of \$HOME: $resolved"
          exit 1
          ;;
      esac

      if project_root=$(git rev-parse --show-toplevel 2>/dev/null); then
        project_root_resolved=$(cd "$project_root" && pwd -P)
        if [[ "$resolved" == "$project_root_resolved" ]]; then
          log_error "refusing to rm -rf the project root: $resolved"
          exit 1
        fi
        case "$resolved" in
          "$project_root_resolved"/*)  ;;
          *)
            log_error "refusing to rm -rf path outside the project root: $resolved (project=$project_root_resolved)"
            exit 1
            ;;
        esac
      else
        log_error "refusing to rm -rf when not inside a git repo"
        exit 1
      fi

      rm -rf "$resolved"
      log_info "cleaned spec dir: $spec_dir"
      spec_cleaned=true
    else
      log_warn "not cleaning spec ($done_tasks/$total_tasks tasks done)"
    fi
  fi
fi

# --- Archive run state ---
archive_dir="${CLAUDE_PLUGIN_DATA}/archive/${run_id}"
run_dir="${CLAUDE_PLUGIN_DATA}/runs/${run_id}"

if [[ -d "$run_dir" ]]; then
  mkdir -p "$archive_dir"

  # Copy state and logs to archive
  cp "$run_dir/state.json" "$archive_dir/" 2>/dev/null || true
  cp "$run_dir/audit.jsonl" "$archive_dir/" 2>/dev/null || true
  cp "$run_dir/metrics.jsonl" "$archive_dir/" 2>/dev/null || true

  # Copy reviews and holdouts
  if [[ -d "$run_dir/reviews" ]]; then
    cp -r "$run_dir/reviews" "$archive_dir/" 2>/dev/null || true
  fi
  if [[ -d "$run_dir/holdouts" ]]; then
    cp -r "$run_dir/holdouts" "$archive_dir/" 2>/dev/null || true
  fi

  # Remove current symlink if it points to this run
  current_link="${CLAUDE_PLUGIN_DATA}/runs/current"
  if [[ -L "$current_link" ]]; then
    current_target=$(readlink "$current_link")
    if [[ "$current_target" == "$run_dir" ]] || [[ "$(basename "$current_target")" == "$run_id" ]]; then
      rm -f "$current_link"
    fi
  fi

  # Remove the run directory — guard against empty CLAUDE_PLUGIN_DATA,
  # symlink escapes, and system paths via assert_in_plugin_data.
  if ! assert_in_plugin_data "$run_dir"; then
    log_error "refusing to rm run_dir (failed assert_in_plugin_data): $run_dir"
    exit 1
  fi
  rm -rf "$run_dir"
  log_info "archived run $run_id to $archive_dir"
fi

# --- task_16_11: retention trim on audit/metrics JSONL under archive ---
# Drops lines older than observability.metricsRetentionDays (default 90).
# Only runs when observability.auditLog is true (matches run-tracker gate).
# Read the boolean directly so a configured `false` isn't swallowed by
# jq's `// empty` default in read_config.
audit_enabled="true"
config_file="${CLAUDE_PLUGIN_DATA}/config.json"
if [[ -f "$config_file" ]]; then
  audit_enabled=$(jq -r '.observability.auditLog | if . == null then "true" else tostring end' "$config_file" 2>/dev/null || printf 'true')
fi
if [[ "$audit_enabled" == "true" ]]; then
  retention_days=$(read_config '.observability.metricsRetentionDays' '90')
  if [[ "$retention_days" =~ ^[0-9]+$ ]] && [[ "$retention_days" -gt 0 ]]; then
    cutoff_epoch=$(( $(date +%s) - retention_days * 86400 ))
    # Trim every audit.jsonl / metrics.jsonl under $CLAUDE_PLUGIN_DATA. Lines
    # missing a .ts field are kept (can't judge their age safely).
    while IFS= read -r -d '' jsonl; do
      # Guard destructive edits via the same helper.
      assert_in_plugin_data "$jsonl" || continue
      tmp_trim=$(mktemp "${jsonl}.trim.XXXXXX")
      jq -c --argjson cutoff "$cutoff_epoch" '
        . as $row
        | (.ts // "") as $t
        | if $t == "" then $row
          else
            ($t | fromdateiso8601?) as $epoch
            | if $epoch == null then $row
              elif $epoch >= $cutoff then $row
              else empty
              end
          end
      ' "$jsonl" > "$tmp_trim" 2>/dev/null && mv -f "$tmp_trim" "$jsonl" \
        || rm -f "$tmp_trim"
    done < <(find "${CLAUDE_PLUGIN_DATA}" \( -name 'audit.jsonl' -o -name 'metrics.jsonl' \) -type f -print0 2>/dev/null || true)
  fi
fi

# Output results
warnings_json="[]"
if (( ${#branch_warnings[@]} > 0 )); then
  warnings_json=$(printf '%s\n' "${branch_warnings[@]}" | jq -R . | jq -s .)
fi

worktree_errors_json='[]'
if (( ${#worktree_errors[@]} > 0 )); then
  worktree_errors_json=$(printf '%s\n' "${worktree_errors[@]}" | jq -R . | jq -s .)
fi
issue_errors_json='[]'
if (( ${#issue_errors[@]} > 0 )); then
  issue_errors_json=$(printf '%s\n' "${issue_errors[@]}" | jq -R 'tonumber? // .' | jq -s .)
fi
agent_branch_errors_json='[]'
if (( ${#agent_branch_errors[@]} > 0 )); then
  agent_branch_errors_json=$(printf '%s\n' "${agent_branch_errors[@]}" | jq -R . | jq -s .)
fi
orchestrator_errors_json='[]'
if (( ${#orchestrator_errors[@]} > 0 )); then
  orchestrator_errors_json=$(printf '%s\n' "${orchestrator_errors[@]}" | jq -R . | jq -s .)
fi

cleanup_status="ok"
if (( ${#worktree_errors[@]} > 0 || ${#issue_errors[@]} > 0 || ${#agent_branch_errors[@]} > 0 || ${#orchestrator_errors[@]} > 0 )); then
  cleanup_status="partial"
fi

jq -n \
  --arg run_id "$run_id" \
  --arg cleanup_status "$cleanup_status" \
  --argjson branches_deleted "$branches_deleted" \
  --argjson branches_skipped "$branches_skipped" \
  --argjson worktrees_removed "$worktrees_removed" \
  --argjson agent_branches_deleted "$agent_branches_deleted" \
  --argjson spec_handoff_deleted "$spec_handoff_deleted" \
  --argjson orphan_spec_deleted "$orphan_spec_deleted" \
  --argjson orchestrator_branches_deleted "$orchestrator_branches_deleted" \
  --argjson orchestrator_wts_removed "$orchestrator_wts_removed" \
  --argjson issues_closed "$issues_closed" \
  --argjson spec_cleaned "$spec_cleaned" \
  --arg archive_path "$archive_dir" \
  --argjson warnings "$warnings_json" \
  --argjson worktree_errors "$worktree_errors_json" \
  --argjson issue_errors "$issue_errors_json" \
  --argjson agent_branch_errors "$agent_branch_errors_json" \
  --argjson orchestrator_errors "$orchestrator_errors_json" \
  '{
    run_id: $run_id,
    cleanup_status: $cleanup_status,
    branches_deleted: $branches_deleted,
    branches_skipped: $branches_skipped,
    worktrees_removed: $worktrees_removed,
    agent_branches_deleted: $agent_branches_deleted,
    spec_handoff_deleted: $spec_handoff_deleted,
    orphan_spec_deleted: $orphan_spec_deleted,
    orchestrator_branches_deleted: $orchestrator_branches_deleted,
    orchestrator_wts_removed: $orchestrator_wts_removed,
    issues_closed: $issues_closed,
    spec_cleaned: $spec_cleaned,
    archive_path: $archive_path,
    warnings: $warnings,
    worktree_errors: $worktree_errors,
    issue_errors: $issue_errors,
    agent_branch_errors: $agent_branch_errors,
    orchestrator_errors: $orchestrator_errors
  }'

if [[ "$cleanup_status" == "partial" ]]; then
  exit 1
fi
