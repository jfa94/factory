#!/usr/bin/env bash
# Verify that the current session has up-to-date autonomous-mode settings.
# Usage: pipeline-ensure-autonomy
#
# Checks whether $CLAUDE_PLUGIN_DATA/merged-settings.json exists and was
# generated from the current plugin version. Regenerates the file if it is
# missing or stale, then emits a JSON result on stdout and exits:
#
#   ok          – file is current and FACTORY_AUTONOMOUS_MODE=1; proceed.
#   bypass      – FACTORY_AUTONOMOUS_MODE=1 but no merged file (CI/env path).
#   stale       – file existed but was regenerated; session must relaunch.
#   missing     – no file (first run); file was generated; session must relaunch.
#   stale-cache – settings ok but usage-cache.json missing or >3600s old;
#                 caller should re-invoke (next agent turn fires statusline)
#                 or relaunch with --settings if cache stays stale.
#
# Exit codes:
#   0 – ok or bypass (pipeline may continue)
#   2 – stale, missing, or stale-cache (pipeline must halt; caller shows msg)

set -euo pipefail

source "$(dirname "$0")/pipeline-lib.sh"

PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PLUGIN_JSON="$PLUGIN_ROOT/.claude-plugin/plugin.json"
TEMPLATE="$PLUGIN_ROOT/templates/settings.autonomous.json"

# Self-heal exec bits on entry-point scripts. Source is tracked as 100755 in
# git, but some packaging paths (zip without -X, npm pack, mirror caches) can
# strip the bit. statusline-wrapper.sh going non-exec is silent and corrosive:
# Claude Code skips the statusline, usage-cache.json never updates, quota
# gates fail-closed at every task. Cheap and idempotent — fix here before any
# downstream code depends on it.
for _script in "$PLUGIN_ROOT/bin/statusline-wrapper.sh" \
               "$PLUGIN_ROOT/bin"/pipeline-*; do
  [[ -f "$_script" ]] || continue
  case "$_script" in *-lib.sh|*-steps.sh) continue ;; esac
  [[ -x "$_script" ]] || chmod +x "$_script" 2>/dev/null || true
done

# Current plugin version
current_version=$(jq -r '.version // empty' "$PLUGIN_JSON" 2>/dev/null)
if [[ -z "$current_version" ]]; then
  log_error "cannot read version from $PLUGIN_JSON"
  exit 1
fi

merged_settings="${CLAUDE_PLUGIN_DATA:-}/merged-settings.json"

_emit() {
  local status="$1" message="$2"
  printf '{"status":"%s","message":"%s","settings_path":"%s"}\n' \
    "$status" "$message" "$merged_settings"
}

_regenerate() {
  mkdir -p "${CLAUDE_PLUGIN_DATA:-}"
  local tmp user_cmd expanded_cmd
  tmp=$(mktemp)

  # Detect user's existing statusLine.command so the wrapper can chain to it.
  # Read from ~/.claude/settings.json only (project-level statuslines are rare
  # and pipeline runs in the project root with the merged file taking precedence).
  user_cmd=$(jq -r '.statusLine.command // empty' "$HOME/.claude/settings.json" 2>/dev/null || true)
  # Skip injection only when the user's command resolves to THIS install's wrapper
  # (path compare, not basename — different plugin installs can share the name).
  local user_cmd_path="" our_wrapper_real="" user_cmd_real=""
  if [[ -n "$user_cmd" ]]; then
    user_cmd_path="${user_cmd/#\~/$HOME}"
    user_cmd_path="${user_cmd_path%% *}"  # strip args for path compare
    our_wrapper_real=$(cd "$PLUGIN_ROOT/bin" 2>/dev/null && pwd)/statusline-wrapper.sh
    if [[ -f "$user_cmd_path" ]]; then
      user_cmd_real=$(cd "$(dirname "$user_cmd_path")" 2>/dev/null && pwd)/"$(basename "$user_cmd_path")"
    fi
  fi
  if [[ -n "$user_cmd" ]] && [[ "$user_cmd_real" != "$our_wrapper_real" ]]; then
    expanded_cmd="${user_cmd/#\~/$HOME}"
    jq --arg root "$PLUGIN_ROOT" --arg ver "$current_version" \
       --arg original_statusline "$expanded_cmd" '
      walk(
        if type == "string" and test("\\$\\{CLAUDE_PLUGIN_ROOT\\}")
        then gsub("\\$\\{CLAUDE_PLUGIN_ROOT\\}"; $root)
        else . end
      ) | . + {_factoryVersion: $ver}
        | .env.FACTORY_ORIGINAL_STATUSLINE = $original_statusline
    ' "$TEMPLATE" > "$tmp"
    log_info "detected user statusline; will chain via FACTORY_ORIGINAL_STATUSLINE=$expanded_cmd"
  else
    jq --arg root "$PLUGIN_ROOT" --arg ver "$current_version" '
      walk(
        if type == "string" and test("\\$\\{CLAUDE_PLUGIN_ROOT\\}")
        then gsub("\\$\\{CLAUDE_PLUGIN_ROOT\\}"; $root)
        else . end
      ) | . + {_factoryVersion: $ver}
    ' "$TEMPLATE" > "$tmp"
  fi
  mv "$tmp" "$merged_settings"

  # asyncRewake compat probe. Feature requires Claude Code >= 2.1.116.
  # On older installs, strip the hook entry so the PostToolUse ship watcher
  # falls back to the wrapper's synchronous FACTORY_ASYNC_CI=off path.
  local cc_ver cc_major cc_minor cc_patch
  cc_ver=$(claude --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || printf '')
  if [[ -n "$cc_ver" ]]; then
    IFS=. read -r cc_major cc_minor cc_patch <<< "$cc_ver"
    if (( cc_major < 2 )) \
       || (( cc_major == 2 && cc_minor < 1 )) \
       || (( cc_major == 2 && cc_minor == 1 && cc_patch < 116 )); then
      log_warn "Claude Code $cc_ver < 2.1.116; stripping asyncRewake hook from merged settings (falling back to FACTORY_ASYNC_CI=off)"
      local tmp2; tmp2=$(mktemp)
      jq '.hooks.PostToolUse |= map(.hooks |= map(select((.asyncRewake // false) != true)) | select(.hooks | length > 0))' \
        "$merged_settings" > "$tmp2" && mv "$tmp2" "$merged_settings"
    fi
  else
    log_warn "could not detect Claude Code version; leaving asyncRewake hook in place"
  fi

  log_info "wrote $merged_settings (version $current_version)"
}

# ── Main ──────────────────────────────────────────────────────────────────────

if [[ ! -f "$merged_settings" ]]; then
  if [[ "${FACTORY_AUTONOMOUS_MODE:-}" == "1" ]]; then
    _emit "bypass" "no merged settings file; FACTORY_AUTONOMOUS_MODE bypass active"
    exit 0
  fi
  _regenerate
  _emit "missing" "generated merged-settings.json for the first time; relaunch required"
  exit 2
fi

# File exists — check version
file_version=$(jq -r '._factoryVersion // empty' "$merged_settings" 2>/dev/null || true)

if [[ "$file_version" != "$current_version" ]]; then
  _regenerate
  _emit "stale" "merged-settings.json was version ${file_version:-unknown}; regenerated to $current_version; relaunch required"
  exit 2
fi

# Version matches — must also have FACTORY_AUTONOMOUS_MODE set (loaded from settings)
if [[ "${FACTORY_AUTONOMOUS_MODE:-}" != "1" ]]; then
  # Settings file is current but session wasn't launched with --settings.
  # Treat as missing (user needs to relaunch).
  _emit "missing" "merged-settings.json is current but FACTORY_AUTONOMOUS_MODE not set; relaunch with --settings"
  exit 2
fi

# Cache freshness check.
#
# The statusline-wrapper writes usage-cache.json on every Claude Code statusline
# tick (one per agent turn). pipeline-quota-check enforces a hard ceiling at
# 3600s — beyond that, every per-task quota gate fails closed and halts mid-run.
#
# Failing closed at startup is far better UX than failing closed mid-pipeline:
# the user gets one clear message and one corrective action instead of a halt
# after N tasks have already burned tokens. Thresholds:
#   - >300s        → soft warning (statusline may have skipped a tick)
#   - >3600s       → hard halt with status=stale-cache (matches quota-check)
#   - missing file → hard halt with status=stale-cache
now_epoch=$(date +%s)
cache_file="${merged_settings%/*}/usage-cache.json"
cache_age=-1
cache_state="ok"
if [[ ! -f "$cache_file" ]]; then
  cache_state="missing"
else
  captured_at=$(jq -r '(.captured_at // 0) | tonumber? // 0' "$cache_file" 2>/dev/null || printf '0')
  cache_age=$(( now_epoch - captured_at ))
  if (( cache_age > 3600 )); then
    cache_state="too-stale"
  elif (( cache_age > 300 )); then
    cache_state="warn"
  fi
fi

if [[ "$cache_state" == "missing" || "$cache_state" == "too-stale" ]]; then
  if [[ "$cache_state" == "missing" ]]; then
    msg="usage-cache.json absent; statusline has not ticked yet. Re-run /factory:run after a moment so the statusline can fire, or relaunch with claude --settings $merged_settings if the session was not started with --settings."
  else
    msg="usage-cache.json is ${cache_age}s old (>3600s); statusline is not ticking. Re-run /factory:run; the next agent turn will refresh the cache. If this repeats, the session was not launched with --settings — relaunch with claude --settings $merged_settings."
  fi
  log_warn "$msg"
  printf '{"status":"stale-cache","reason":"%s","message":"%s","settings_path":"%s","cache_age":%d}\n' \
    "$cache_state" "$msg" "$merged_settings" "$cache_age"
  exit 2
fi

if [[ "$cache_state" == "warn" ]]; then
  log_warn "usage-cache.json is ${cache_age}s old (>300s); statusline may have skipped a tick"
  printf '{"status":"ok","message":"autonomous mode active (version %s)","settings_path":"%s","cache_warning":"usage-cache.json is %ds old","cache_age":%d}\n' \
    "$current_version" "$merged_settings" "$cache_age" "$cache_age"
else
  _emit "ok" "autonomous mode active (version $current_version)"
fi
exit 0
