+/** e2e.startCommand/baseURL configured — the readiness gate `runE2eEmit` checks. */
+function e2eConfig(): Config {
+  const base = defaultConfig();
+  return {
+    ...base,
+    e2e: { ...base.e2e, startCommand: "npm start", baseURL: "http://localhost:3000" },
