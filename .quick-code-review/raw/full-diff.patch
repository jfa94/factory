+} {
+  const calls: Array<{ path: string; setupCommand?: string }> = [];
+  const fn: ProvisionWorktreeFn = async (args) => {
+    calls.push({ path: args.path, setupCommand: args.setupCommand });
+  };
+  return { calls, fn };
+}
