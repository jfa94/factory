+
+const SPEC_SUB_HELP = `factory debug spec — thin pass-through to 'factory spec' fed a synthetic PRD
+
+Usage:
+  factory debug spec resolve --run <id>
+  factory debug spec gate    --run <id>
+  factory debug spec store   --run <id>
