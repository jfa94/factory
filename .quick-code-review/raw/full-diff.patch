+          { title: "b", file: "e2e/b.spec.ts", tests: [{ status: "flaky" }] },
+          { title: "c", file: "e2e/c.spec.ts", tests: [{ status: "skipped" }] },
+        ],
+      },
+    ]);
+    expect(parseE2eReport(report).ok).toBe(true);
+  });
