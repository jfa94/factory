{
  "name": "factory-plugin",
  "version": "1.8.0",
  "private": true,
  "type": "module",
  "description": "Factory plugin build tooling (Node + TypeScript rewrite). NOT the scaffold shipped into target repos (see templates/package.scaffold.json).",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "factory": "dist/factory.js",
    "factory-hook": "dist/factory-hook.js"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "check:circular": "madge --circular --extensions ts src/",
    "verify": "npm run typecheck && npm run check:circular && npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "madge": "^8.0.0",
    "prettier": "^3.0.0",
    "proper-lockfile": "^4.1.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  }
}
